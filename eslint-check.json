expiry?: string;\r\n  card_cvv?: string;\r\n  card_name?: string;\r\n  cpf?: string;\r\n}\r\n\r\nexport function SubscriptionPayment() {\r\n  const { plans, loading } = useSubscriptionPlans();\r\n  const { user } = useAuth();\r\n  const [formData, setFormData] = useState<PaymentFormData>({\r\n    plan_id: '',\r\n    payment_method: 'credit_card'\r\n  });\r\n  const [processing, setProcessing] = useState(false);\r\n  const [step, setStep] = useState<'plan' | 'payment' | 'processing' | 'success'>('plan');\r\n\r\n  const handlePlanSelect = (planId: string) => {\r\n    setFormData(prev => ({ ...prev, plan_id }));\r\n    setStep('payment');\r\n  };\r\n\r\n  const handlePaymentSubmit = async () => {\r\n    if (!user) {\r\n      toast.error('Vocâ”œآ¬ precisa estar logado');\r\n      return;\r\n    }\r\n\r\n    if (!formData.plan_id) {\r\n      toast.error('Selecione um plano');\r\n      return;\r\n    }\r\n\r\n    setProcessing(true);\r\n    setStep('processing');\r\n\r\n    try {\r\n      // Simular processamento de pagamento\r\n      await new Promise(resolve => setTimeout(resolve, 3000));\r\n\r\n      // Criar assinatura\r\n      const result = await createSubscription();\r\n      \r\n      if (result) {\r\n        setStep('success');\r\n        toast.success('Assinatura criada com sucesso!');\r\n      } else {\r\n        setStep('payment');\r\n        toast.error('Erro ao processar pagamento');\r\n      }\r\n    } catch (error) {\r\n      console.error('Erro no pagamento:', error);\r\n      setStep('payment');\r\n      toast.error('Erro ao processar pagamento');\r\n    } finally {\r\n      setProcessing(false);\r\n    }\r\n  };\r\n\r\n  const createSubscription = async () => {\r\n    // Implementar lâ”œâ”‚gica real de criaâ”œآ؛â”œأ؛o de assinatura\r\n    // Por enquanto, simula sucesso\r\n    return true;\r\n  };\r\n\r\n  if (loading) {\r\n    return (\r\n      <div className=\"flex items-center justify-center p-8\">\r\n        <div className=\"animate-spin rounded-full h-8 w-8 border-b-2 border-primary\"></div>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  if (step === 'success') {\r\n    return (\r\n      <Card className=\"max-w-md mx-auto\">\r\n        <CardContent className=\"p-8 text-center\">\r\n          <CheckCircle className=\"w-16 h-16 text-green-500 mx-auto mb-4\" />\r\n          <h2 className=\"text-2xl font-bold mb-2\">Pagamento Aprovado!</h2>\r\n          <p className=\"text-muted-foreground mb-6\">\r\n            Sua assinatura foi ativada com sucesso. Vocâ”œآ¬ jâ”œأ­ pode usar todas as funcionalidades do sistema.\r\n          </p>\r\n          <Button onClick={() => window.location.href = '/dashboard'}>\r\n            Ir para o Dashboard\r\n          </Button>\r\n        </CardContent>\r\n      </Card>\r\n    );\r\n  }\r\n\r\n  if (step === 'processing') {\r\n    return (\r\n      <Card className=\"max-w-md mx-auto\">\r\n        <CardContent className=\"p-8 text-center\">\r\n          <div className=\"animate-spin rounded-full h-12 w-12 border-b-2 border-primary mx-auto mb-4\"></div>\r\n          <h2 className=\"text-xl font-bold mb-2\">Processando Pagamento</h2>\r\n          <p className=\"text-muted-foreground\">\r\n            Estamos processando sua assinatura. Por favor, aguarde...\r\n          </p>\r\n        </CardContent>\r\n      </Card>\r\n    );\r\n  }\r\n\r\n  if (step === 'payment') {\r\n    const selectedPlan = plans.find(p => p.id === formData.plan_id);\r\n\r\n    return (\r\n      <Card className=\"max-w-md mx-auto\">\r\n        <CardHeader>\r\n          <CardTitle>Finalizar Assinatura</CardTitle>\r\n          <CardDescription>\r\n            Complete seu pagamento para ativar a assinatura\r\n          </CardDescription>\r\n        </CardHeader>\r\n        \r\n        <CardContent className=\"space-y-6\">\r\n          {/* Resumo do Plano */}\r\n          <div className=\"bg-muted/50 rounded-lg p-4\">\r\n            <div className=\"flex items-center justify-between mb-2\">\r\n              <span className=\"font-medium\">Plano Selecionado</span>\r\n              <Badge variant=\"secondary\">{selectedPlan?.name}</Badge>\r\n            </div>\r\n            <div className=\"flex items-center justify-between\">\r\n              <span className=\"text-2xl font-bold\">\r\n                R$ {selectedPlan?.price.toFixed(2)}\r\n              </span>\r\n              <span className=\"text-sm text-muted-foreground\">\r\n                {selectedPlan?.duration_months === 1 && '/mâ”œآ¬s'}\r\n                {selectedPlan?.duration_months === 3 && '/trimestre'}\r\n                {selectedPlan?.duration_months === 12 && '/ano'}\r\n              </span>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Mâ”œآ®todo de Pagamento */}\r\n          <div className=\"space-y-3\">\r\n            <Label>Mâ”œآ®todo de Pagamento</Label>\r\n            <Select\r\n              value={formData.payment_method}\r\n              onValueChange={(value: 'credit_card' | 'pix' | 'debit_card') =>\r\n                setFormData(prev => ({ ...prev, payment_method: value }))\r\n              }\r\n            >\r\n              <SelectTrigger>\r\n                <SelectValue />\r\n              </SelectTrigger>\r\n              <SelectContent>\r\n                <SelectItem value=\"credit_card\">\r\n                  <div className=\"flex items-center gap-2\">\r\n                    <CreditCard className=\"w-4 h-4\" />\r\n                    Cartâ”œأ؛o de Crâ”œآ®dito\r\n                  </div>\r\n                </SelectItem>\r\n                <SelectItem value=\"debit_card\">\r\n                  <div className=\"flex items-center gap-2\">\r\n                    <Wallet className=\"w-4 h-4\" />\r\n                    Cartâ”œأ؛o de Dâ”œآ®bito\r\n                  </div>\r\n                </SelectItem>\r\n                <SelectItem value=\"pix\">\r\n                  <div className=\"flex items-center gap-2\">\r\n                    <Smartphone className=\"w-4 h-4\" />\r\n                    PIX\r\n                  </div>\r\n                </SelectItem>\r\n              </SelectContent>\r\n            </Select>\r\n          </div>\r\n\r\n          {/* Dados do Cartâ”œأ؛o */}\r\n          {(formData.payment_method === 'credit_card' || formData.payment_method === 'debit_card') && (\r\n            <div className=\"space-y-4\">\r\n              <div className=\"space-y-2\">\r\n                <Label htmlFor=\"card_name\">Nome no Cartâ”œأ؛o</Label>\r\n                <Input\r\n                  id=\"card_name\"\r\n                  placeholder=\"Joâ”œأ؛o da Silva\"\r\n                  value={formData.card_name || ''}\r\n                  onChange={(e) => setFormData(prev => ({ ...prev, card_name: e.target.value }))}\r\n                />\r\n              </div>\r\n              \r\n              <div className=\"space-y-2\">\r\n                <Label htmlFor=\"card_number\">Nâ”œâ•‘mero do Cartâ”œأ؛o</Label>\r\n                <Input\r\n                  id=\"card_number\"\r\n                  placeholder=\"0000 0000 0000 0000\"\r\n                  value={formData.card_number || ''}\r\n                  onChange={(e) => setFormData(prev => ({ ...prev, card_number: e.target.value }))}\r\n                />\r\n              </div>\r\n\r\n              <div className=\"grid grid-cols-2 gap-4\">\r\n                <div className=\"space-y-2\">\r\n                  <Label htmlFor=\"card_expiry\">Validade</Label>\r\n                  <Input\r\n                    id=\"card_expiry\"\r\n                    placeholder=\"MM/AA\"\r\n                    value={formData.card_expiry || ''}\r\n                    onChange={(e) => setFormData(prev => ({ ...prev, card_expiry: e.target.value }))}\r\n                  />\r\n                </div>\r\n                <div className=\"space-y-2\">\r\n                  <Label htmlFor=\"card_cvv\">CVV</Label>\r\n                  <Input\r\n                    id=\"card_cvv\"\r\n                    placeholder=\"123\"\r\n                    value={formData.card_cvv || ''}\r\n                    onChange={(e) => setFormData(prev => ({ ...prev, card_cvv: e.target.value }))}\r\n                  />\r\n                </div>\r\n              </div>\r\n\r\n              <div className=\"space-y-2\">\r\n                <Label htmlFor=\"cpf\">CPF do Titular</Label>\r\n                <Input\r\n                  id=\"cpf\"\r\n                  placeholder=\"000.000.000-00\"\r\n                  value={formData.cpf || ''}\r\n                  onChange={(e) => setFormData(prev => ({ ...prev, cpf: e.target.value }))}\r\n                />\r\n              </div>\r\n            </div>\r\n          )}\r\n\r\n          {/* PIX */}\r\n          {formData.payment_method === 'pix' && (\r\n            <div className=\"space-y-4\">\r\n              <Alert>\r\n                <QrCode className=\"w-4 h-4\" />\r\n                <AlertDescription>\r\n                  Apâ”œâ”‚s confirmar, vocâ”œآ¬ serâ”œأ­ redirecionado para gerar o QR Code PIX.\r\n                </AlertDescription>\r\n              </Alert>\r\n            </div>\r\n          )}\r\n\r\n          {/* Botâ”œأپes */}\r\n          <div className=\"flex gap-3\">\r\n            <Button\r\n              variant=\"outline\"\r\n              className=\"flex-1\"\r\n              onClick={() => setStep('plan')}\r\n              disabled={processing}\r\n            >\r\n              Voltar\r\n            </Button>\r\n            <Button\r\n              className=\"flex-1\"\r\n              onClick={handlePaymentSubmit}\r\n              disabled={processing}\r\n            >\r\n              {processing ? 'Processando...' : 'Pagar Agora'}\r\n            </Button>\r\n          </div>\r\n\r\n          {/* Seguranâ”œآ؛a */}\r\n          <div className=\"text-center text-xs text-muted-foreground\">\r\n            <div className=\"flex items-center justify-center gap-2 mb-2\">\r\n              <CheckCircle className=\"w-3 h-3\" />\r\n              <span>Pagamento 100% seguro</span>\r\n            </div>\r\n            <p>Seus dados sâ”œأ؛o criptografados e protegidos</p>\r\n          </div>\r\n        </CardContent>\r\n      </Card>\r\n    );\r\n  }\r\n\r\n  return (\r\n    <Card className=\"max-w-4xl mx-auto\">\r\n      <CardHeader>\r\n        <CardTitle>Escolha seu Plano</CardTitle>\r\n        <CardDescription>\r\n          Comece com nosso plano trial de 7 dias grâ”œأ­tis\r\n        </CardDescription>\r\n      </CardHeader>\r\n      \r\n      <CardContent>\r\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\r\n          {plans.map((plan) => {\r\n            const isTrial = plan.duration_months === 0;\r\n            const isPopular = plan.sort_order === 2;\r\n            const isAnnual = plan.duration_months === 12;\r\n            \r\n            return (\r\n              <Card\r\n                key={plan.id}\r\n                className={`relative cursor-pointer transition-all hover:shadow-lg ${\r\n                  isPopular ? 'border-primary ring-2 ring-primary/20' : ''\r\n                }`}\r\n                onClick={() => handlePlanSelect(plan.id)}\r\n              >\r\n                {isPopular && (\r\n                  <div className=\"absolute -top-3 left-1/2 -translate-x-1/2\">\r\n                    <Badge className=\"bg-primary text-primary-foreground\">\r\n                      Mais Popular\r\n                    </Badge>\r\n                  </div>\r\n                )}\r\n\r\n                <CardContent className=\"p-6\">\r\n                  <div className=\"text-center space-y-4\">\r\n                    <h3 className=\"text-xl font-bold\">{plan.name}</h3>\r\n                    \r\n                    <div className=\"space-y-1\">\r\n                      <div className=\"text-3xl font-bold\">\r\n                        {isTrial ? 'GRâ”œأ¼TIS' : `R$ ${plan.price.toFixed(2)}`}\r\n                      </div>\r\n                      {!isTrial && (\r\n                        <div className=\"text-sm text-muted-foreground\">\r\n                          {plan.duration_months === 1 && 'por mâ”œآ¬s'}\r\n                          {plan.duration_months === 3 && `R$ ${(plan.price / 3).toFixed(2)} por mâ”œآ¬s`}\r\n                          {plan.duration_months === 12 && `R$ ${(plan.price / 12).toFixed(2)} por mâ”œآ¬s`}\r\n                        </div>\r\n                      )}\r\n                    </div>\r\n\r\n                    <div className=\"space-y-2 text-sm\">\r\n                      <div className=\"flex items-center gap-2\">\r\n                        <CheckCircle className=\"w-4 h-4 text-green-500\" />\r\n                        <span>Dashboard Completo</span>\r\n                      </div>\r\n                      <div className=\"flex items-center gap-2\">\r\n                        <CheckCircle className=\"w-4 h-4 text-green-500\" />\r\n                        <span>Agendamentos Ilimitados</span>\r\n                      </div>\r\n                      <div className=\"flex items-center gap-2\">\r\n                        <CheckCircle className=\"w-4 h-4 text-green-500\" />\r\n                        <span>Pagamentos PIX e Cartâ”œأ؛o</span>\r\n                      </div>\r\n                      {!isTrial && (\r\n                        <div className=\"flex items-center gap-2\">\r\n                          <CheckCircle className=\"w-4 h-4 text-blue-500\" />\r\n                          <span>Acesso â”œأ، API</span>\r\n                        </div>\r\n                      )}\r\n                    </div>\r\n\r\n                    <Button className=\"w-full\" variant={isPopular ? 'default' : 'outline'}>\r\n                      {isTrial ? 'Comeâ”œآ؛ar Grâ”œأ­tis' : 'Assinar Agora'}\r\n                    </Button>\r\n                  </div>\r\n                </CardContent>\r\n              </Card>\r\n            );\r\n          })}\r\n        </div>\r\n      </CardContent>\r\n    </Card>\r\n  );\r\n}\r\n","usedDe
g;\r\n  auto_booking: boolean;\r\n  auto_register_client: boolean;\r\n  auto_reactivation: boolean;\r\n  auto_billing: boolean;\r\n  greeting_message: string;\r\n}\r\n\r\nconst defaultConfig: AIConfig = {\r\n  response_type: \"text\",\r\n  personality: \"friendly\",\r\n  voice_id: null,\r\n  language: \"pt-BR\",\r\n  auto_booking: true,\r\n  auto_register_client: true,\r\n  auto_reactivation: true,\r\n  auto_billing: false,\r\n  greeting_message: \"Olâ”œأ­! Sou o assistente virtual. Como posso ajudar?\",\r\n};\r\n\r\nexport function AIAudioConfigPanel({ barbershopId }: AIAudioConfigPanelProps) {\r\n  const [config, setConfig] = useState<AIConfig>(defaultConfig);\r\n  const [loading, setLoading] = useState(true);\r\n  const [saving, setSaving] = useState(false);\r\n\r\n  useEffect(() => {\r\n    loadConfig();\r\n  }, [barbershopId]);\r\n\r\n  const loadConfig = async () => {\r\n    try {\r\n      const { data, error } = await (supabase as any)\r\n        .from(\"ai_config\")\r\n        .select(\"*\")\r\n        .eq(\"barbershop_id\", barbershopId)\r\n        .maybeSingle();\r\n\r\n      if (data) {\r\n        setConfig({\r\n          response_type: data.response_type,\r\n          personality: data.personality,\r\n          voice_id: data.voice_id,\r\n          language: data.language,\r\n          auto_booking: data.auto_booking,\r\n          auto_register_client: data.auto_register_client,\r\n          auto_reactivation: data.auto_reactivation,\r\n          auto_billing: data.auto_billing,\r\n          greeting_message: data.greeting_message,\r\n        });\r\n      }\r\n    } catch (err) {\r\n      console.error(\"Error loading AI config:\", err);\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  const saveConfig = async () => {\r\n    setSaving(true);\r\n    try {\r\n      const { error } = await (supabase as any)\r\n        .from(\"ai_config\")\r\n        .upsert({\r\n          barbershop_id: barbershopId,\r\n          ...config,\r\n          updated_at: new Date().toISOString(),\r\n        }, { onConflict: \"barbershop_id\" });\r\n\r\n      if (error) throw error;\r\n      toast({ title: \"Configuraâ”œآ؛â”œأپes salvas!\", description: \"A IA foi atualizada com sucesso.\" });\r\n    } catch (err: any) {\r\n      toast({ title: \"Erro ao salvar\", description: err.message, variant: \"destructive\" });\r\n    } finally {\r\n      setSaving(false);\r\n    }\r\n  };\r\n\r\n  if (loading) {\r\n    return <div className=\"flex items-center justify-center p-8\"><div className=\"animate-spin rounded-full h-8 w-8 border-b-2 border-primary\" /></div>;\r\n  }\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <div className=\"flex items-center justify-between\">\r\n        <div>\r\n          <h2 className=\"text-2xl font-bold flex items-center gap-2\">\r\n            <Bot className=\"w-6 h-6 text-primary\" />\r\n            Assistente Inteligente\r\n          </h2>\r\n          <p className=\"text-muted-foreground\">Configure a IA de atendimento automâ”œأ­tico do seu negâ”œâ”‚cio</p>\r\n        </div>\r\n        <Button onClick={saveConfig} disabled={saving}>\r\n          {saving ? \"Salvando...\" : \"Salvar Configuraâ”œآ؛â”œأپes\"}\r\n        </Button>\r\n      </div>\r\n\r\n      <Tabs defaultValue=\"response\">\r\n        <TabsList className=\"grid w-full grid-cols-3\">\r\n          <TabsTrigger value=\"response\"><MessageSquare className=\"w-4 h-4 mr-1\" />Resposta</TabsTrigger>\r\n          <TabsTrigger value=\"automation\"><Zap className=\"w-4 h-4 mr-1\" />Automaâ”œآ؛â”œأپes</TabsTrigger>\r\n          <TabsTrigger value=\"voice\"><Volume2 className=\"w-4 h-4 mr-1\" />Voz</TabsTrigger>\r\n        </TabsList>\r\n\r\n        <TabsContent value=\"response\" className=\"space-y-4\">\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle className=\"text-lg\">Tipo de Resposta</CardTitle>\r\n              <CardDescription>Como a IA deve responder aos clientes no WhatsApp</CardDescription>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-4\">\r\n              <div className=\"space-y-2\">\r\n                <Label>Formato de resposta</Label>\r\n                <Select value={config.response_type} onValueChange={(v) => setConfig(p => ({ ...p, response_type: v }))}>\r\n                  <SelectTrigger><SelectValue /></SelectTrigger>\r\n                  <SelectContent>\r\n                    <SelectItem value=\"text\">آ­ئ’أ´أک Apenas Texto</SelectItem>\r\n                    <SelectItem value=\"audio\">آ­ئ’أ„أ± Apenas â”œأ¼udio</SelectItem>\r\n                    <SelectItem value=\"auto\">آ­ئ’أ±أ» Automâ”œأ­tico (detecta se cliente enviou â”œأ­udio)</SelectItem>\r\n                  </SelectContent>\r\n                </Select>\r\n              </div>\r\n\r\n              <div className=\"space-y-2\">\r\n                <Label>Personalidade da IA</Label>\r\n                <Select value={config.personality} onValueChange={(v) => setConfig(p => ({ ...p, personality: v }))}>\r\n                  <SelectTrigger><SelectValue /></SelectTrigger>\r\n                  <SelectContent>\r\n                    <SelectItem value=\"formal\">آ­ئ’أ¦أ¶ Formal e Profissional</SelectItem>\r\n                    <SelectItem value=\"friendly\">آ­ئ’أ؟أ¨ Amigâ”œأ­vel e Caloroso</SelectItem>\r\n                    <SelectItem value=\"premium\">أ”آ£آ؟ Premium e Exclusivo</SelectItem>\r\n                  </SelectContent>\r\n                </Select>\r\n              </div>\r\n\r\n              <div className=\"space-y-2\">\r\n                <Label>Mensagem de Boas-vindas</Label>\r\n                <Textarea\r\n                  value={config.greeting_message}\r\n                  onChange={(e) => setConfig(p => ({ ...p, greeting_message: e.target.value }))}\r\n                  placeholder=\"Mensagem inicial quando o cliente entra em contato\"\r\n                  rows={3}\r\n                />\r\n              </div>\r\n            </CardContent>\r\n          </Card>\r\n        </TabsContent>\r\n\r\n        <TabsContent value=\"automation\" className=\"space-y-4\">\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle className=\"text-lg\">Funâ”œآ؛â”œأپes Automâ”œأ­ticas</CardTitle>\r\n              <CardDescription>O que a IA pode fazer automaticamente</CardDescription>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-4\">\r\n              {[\r\n                { key: \"auto_booking\" as const, label: \"Agendamento Automâ”œأ­tico\", desc: \"IA pode marcar horâ”œأ­rios diretamente\", icon: \"آ­ئ’أ´أ \" },\r\n                { key: \"auto_register_client\" as const, label: \"Cadastro de Clientes\", desc: \"Registrar novos clientes durante conversa\", icon: \"آ­ئ’أ¦أ±\" },\r\n                { key: \"auto_reactivation\" as const, label: \"Reativaâ”œآ؛â”œأ؛o de Inativos\", desc: \"Enviar mensagens para clientes que nâ”œأ؛o voltaram\", icon: \"آ­ئ’أ¶أ¤\" },\r\n                { key: \"auto_billing\" as const, label: \"Envio de Cobranâ”œآ؛as\", desc: \"Gerar e enviar links de pagamento\", icon: \"آ­ئ’أ†â–‘\" },\r\n              ].map(item => (\r\n                <div key={item.key} className=\"flex items-center justify-between p-3 rounded-lg border\">\r\n                  <div className=\"flex items-center gap-3\">\r\n                    <span className=\"text-xl\">{item.icon}</span>\r\n                    <div>\r\n                      <p className=\"font-medium\">{item.label}</p>\r\n                      <p className=\"text-sm text-muted-foreground\">{item.desc}</p>\r\n                    </div>\r\n                  </div>\r\n                  <Switch\r\n                    checked={config[item.key]}\r\n                    onCheckedChange={(v) => setConfig(p => ({ ...p, [item.key]: v }))}\r\n                  />\r\n                </div>\r\n              ))}\r\n            </CardContent>\r\n          </Card>\r\n        </TabsContent>\r\n\r\n        <TabsContent value=\"voice\" className=\"space-y-4\">\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle className=\"text-lg flex items-center gap-2\">\r\n                <Mic className=\"w-5 h-5\" />\r\n                Configuraâ”œآ؛â”œأ؛o de Voz\r\n              </CardTitle>\r\n              <CardDescription>Personalize a voz da IA para respostas em â”œأ­udio</CardDescription>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-4\">\r\n              <div className=\"space-y-2\">\r\n                <Label>Voz (OpenAI TTS)</Label>\r\n                <Select value={config.voice_id || \"nova\"} onValueChange={(v) => setConfig(p => ({ ...p, voice_id: v }))}>\r\n                  <SelectTrigger><SelectValue /></SelectTrigger>\r\n                  <SelectContent>\r\n                    <SelectItem value=\"alloy\">Alloy (Neutro)</SelectItem>\r\n                    <SelectItem value=\"echo\">Echo (Masculino)</SelectItem>\r\n                    <SelectItem value=\"fable\">Fable (Narrativo)</SelectItem>\r\n                    <SelectItem value=\"onyx\">Onyx (Masculino Grave)</SelectItem>\r\n                    <SelectItem value=\"nova\">Nova (Feminino)</SelectItem>\r\n                    <SelectItem value=\"shimmer\">Shimmer (Feminino Suave)</SelectItem>\r\n                  </SelectContent>\r\n                </Select>\r\n              </div>\r\n\r\n              <div className=\"space-y-2\">\r\n                <Label>Idioma</Label>\r\n                <Select value={config.language} onValueChange={(v) => setConfig(p => ({ ...p, language: v }))}>\r\n                  <SelectTrigger><SelectValue /></SelectTrigger>\r\n                  <SelectContent>\r\n                    <SelectItem value=\"pt-BR\">آ­ئ’أ§آ؛آ­ئ’أ§أ€ Portuguâ”œآ¬s (Brasil)</SelectItem>\r\n                    <SelectItem value=\"en\">آ­ئ’أ§â•‘آ­ئ’أ§آ© English</SelectItem>\r\n                    <SelectItem value=\"es\">آ­ئ’أ§آ¬آ­ئ’أ§آ© Espaâ”œâ–’ol</SelectItem>\r\n                  </SelectContent>\r\n                </Select>\r\n              </div>\r\n\r\n              <div className=\"p-4 bg-muted/50 rounded-lg\">\r\n                <div className=\"flex items-center gap-2 mb-2\">\r\n                  <Badge variant=\"outline\">IA de â”œأ¼udio</Badge>\r\n                </div>\r\n                <p className=\"text-sm text-muted-foreground\">\r\n                  Quando um cliente envia um â”œأ­udio no WhatsApp, a IA converte para texto (Speech-to-Text), \r\n                  processa a intenâ”œآ؛â”œأ؛o e responde conforme o formato configurado acima.\r\n                </p>\r\n              </div>\r\n            </CardContent>\r\n          </Card>\r\n        </TabsContent>\r\n      </Tabs>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\components\\atendimento\\FinalizarAtendimentoModal.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":10,"column":24,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":10,"endColumn":27,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[574,577],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[574,577],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":60,"column":42,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":60,"endColumn":45,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1721,1724],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type 
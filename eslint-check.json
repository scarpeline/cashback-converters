text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":4,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/**\r\n * Utilitâ”œأ­rio para exportar dados em CSV\r\n */\r\n\r\nexport interface CSVExportOptions {\r\n  filename: string;\r\n  headers: string[];\r\n  data: any[][];\r\n}\r\n\r\nexport function exportToCSV({ filename, headers, data }: CSVExportOptions) {\r\n  // Escapar valores que contâ”œآ¬m aspas ou quebras de linha\r\n  const escapeCSV = (value: any): string => {\r\n    if (value === null || value === undefined) return '';\r\n    const stringValue = String(value);\r\n    if (stringValue.includes(',') || stringValue.includes('\"') || stringValue.includes('\\n')) {\r\n      return `\"${stringValue.replace(/\"/g, '\"\"')}\"`;\r\n    }\r\n    return stringValue;\r\n  };\r\n\r\n  // Montar CSV\r\n  const csvContent = [\r\n    headers.map(escapeCSV).join(','),\r\n    ...data.map(row => row.map(escapeCSV).join(','))\r\n  ].join('\\n');\r\n\r\n  // Criar blob e download\r\n  const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });\r\n  const link = document.createElement('a');\r\n  const url = URL.createObjectURL(blob);\r\n\r\n  link.setAttribute('href', url);\r\n  link.setAttribute('download', `${filename}.csv`);\r\n  link.style.visibility = 'hidden';\r\n\r\n  document.body.appendChild(link);\r\n  link.click();\r\n  document.body.removeChild(link);\r\n}\r\n\r\n/**\r\n * Exportar parceiros para CSV\r\n */\r\nexport function exportPartnersToCSV(partners: any[]) {\r\n  const headers = ['Nome', 'Email', 'WhatsApp', 'Tipo', 'Status', 'Indicados', 'Nâ”œآ،vel', 'Câ”œâ”‚digo Referâ”œآ¬ncia'];\r\n  \r\n  const data = partners.map(partner => [\r\n    partner.users?.name || '',\r\n    partner.users?.email || '',\r\n    partner.users?.whatsapp || '',\r\n    partner.type,\r\n    partner.status,\r\n    partner.total_indicados || 0,\r\n    partner.level || 0,\r\n    partner.referral_code || ''\r\n  ]);\r\n\r\n  exportToCSV({\r\n    filename: `parceiros_${new Date().toISOString().split('T')[0]}`,\r\n    headers,\r\n    data\r\n  });\r\n}\r\n\r\n/**\r\n * Exportar comissâ”œأپes para CSV\r\n */\r\nexport function exportCommissionsToCSV(commissions: any[], partnerName: string) {\r\n  const headers = ['Data', 'Tipo', 'Valor', 'Status', 'Descriâ”œآ؛â”œأ؛o'];\r\n  \r\n  const data = commissions.map(commission => [\r\n    new Date(commission.created_at).toLocaleDateString('pt-BR'),\r\n    commission.type.replace(/_/g, ' '),\r\n    `R$ ${commission.amount.toFixed(2)}`,\r\n    commission.status,\r\n    commission.description || ''\r\n  ]);\r\n\r\n  exportToCSV({\r\n    filename: `comissoes_${partnerName}_${new Date().toISOString().split('T')[0]}`,\r\n    headers,\r\n    data\r\n  });\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\lib\\debug\\auth-logger.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\lib\\debug\\session-validator.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\lib\\dynamicLabels.ts","messages":[{"ruleId":"react-hooks/rules-of-hooks","severity":2,"message":"React Hook \"useAuth\" is called in function \"getDynamicLabel\" that is neither a React function component nor a custom React Hook function. React component names must start with an uppercase letter. React Hook names must start with the w
ommission_generated' | 'commission_approved' | 'commission_paid' | 'referral_completed' | 'new_referral';\r\n  title: string;\r\n  message: string;\r\n  data?: Record<string, any>;\r\n  read: boolean;\r\n  created_at: string;\r\n}\r\n\r\n/**\r\n * Criar notificaâ”œآ؛â”œأ؛o para parceiro\r\n */\r\nexport async function createPartnerNotification(\r\n  partnerId: string,\r\n  type: PartnerNotification['type'],\r\n  title: string,\r\n  message: string,\r\n  data?: Record<string, any>\r\n): Promise<boolean> {\r\n  try {\r\n    const { error } = await (supabase as any)\r\n      .from('partner_notifications')\r\n      .insert([{\r\n        partner_id: partnerId,\r\n        type,\r\n        title,\r\n        message,\r\n        data,\r\n        read: false,\r\n      }]);\r\n\r\n    if (error) throw error;\r\n    return true;\r\n  } catch (error) {\r\n    console.error('Erro ao criar notificaâ”œآ؛â”œأ؛o:', error);\r\n    return false;\r\n  }\r\n}\r\n\r\n/**\r\n * Buscar notificaâ”œآ؛â”œأپes nâ”œأ؛o lidas de um parceiro\r\n */\r\nexport async function getUnreadNotifications(partnerId: string): Promise<PartnerNotification[]> {\r\n  try {\r\n    const { data, error } = await (supabase as any)\r\n      .from('partner_notifications')\r\n      .select('*')\r\n      .eq('partner_id', partnerId)\r\n      .eq('read', false)\r\n      .order('created_at', { ascending: false });\r\n\r\n    if (error) throw error;\r\n    return data || [];\r\n  } catch (error) {\r\n    console.error('Erro ao buscar notificaâ”œآ؛â”œأپes:', error);\r\n    return [];\r\n  }\r\n}\r\n\r\n/**\r\n * Buscar todas as notificaâ”œآ؛â”œأپes de um parceiro\r\n */\r\nexport async function getAllNotifications(partnerId: string, limit = 50): Promise<PartnerNotification[]> {\r\n  try {\r\n    const { data, error } = await (supabase as any)\r\n      .from('partner_notifications')\r\n      .select('*')\r\n      .eq('partner_id', partnerId)\r\n      .order('created_at', { ascending: false })\r\n      .limit(limit);\r\n\r\n    if (error) throw error;\r\n    return data || [];\r\n  } catch (error) {\r\n    console.error('Erro ao buscar notificaâ”œآ؛â”œأپes:', error);\r\n    return [];\r\n  }\r\n}\r\n\r\n/**\r\n * Marcar notificaâ”œآ؛â”œأ؛o como lida\r\n */\r\nexport async function markNotificationAsRead(notificationId: string): Promise<boolean> {\r\n  try {\r\n    const { error } = await (supabase as any)\r\n      .from('partner_notifications')\r\n      .update({ read: true })\r\n      .eq('id', notificationId);\r\n\r\n    if (error) throw error;\r\n    return true;\r\n  } catch (error) {\r\n    console.error('Erro ao marcar notificaâ”œآ؛â”œأ؛o como lida:', error);\r\n    return false;\r\n  }\r\n}\r\n\r\n/**\r\n * Marcar todas as notificaâ”œآ؛â”œأپes como lidas\r\n */\r\nexport async function markAllNotificationsAsRead(partnerId: string): Promise<boolean> {\r\n  try {\r\n    const { error } = await (supabase as any)\r\n      .from('partner_notifications')\r\n      .update({ read: true })\r\n      .eq('partner_id', partnerId)\r\n      .eq('read', false);\r\n\r\n    if (error) throw error;\r\n    return true;\r\n  } catch (error) {\r\n    console.error('Erro ao marcar notificaâ”œآ؛â”œأپes como lidas:', error);\r\n    return false;\r\n  }\r\n}\r\n\r\n/**\r\n * Deletar notificaâ”œآ؛â”œأ؛o\r\n */\r\nexport async function deleteNotification(notificationId: string): Promise<boolean> {\r\n  try {\r\n    const { error } = await (supabase as any)\r\n      .from('partner_notifications')\r\n      .delete()\r\n      .eq('id', notificationId);\r\n\r\n    if (error) throw error;\r\n    return true;\r\n  } catch (error) {\r\n    console.error('Erro ao deletar notificaâ”œآ؛â”œأ؛o:', error);\r\n    return false;\r\n  }\r\n}\r\n\r\n/**\r\n * Notificar parceiro sobre comissâ”œأ؛o gerada\r\n */\r\nexport async function notifyCommissionGenerated(\r\n  partnerId: string,\r\n  amount: number,\r\n  type: 'referral' | 'franchise_revenue' | 'network_revenue'\r\n): Promise<boolean> {\r\n  const typeLabel = {\r\n    referral: 'indicaâ”œآ؛â”œأ؛o',\r\n    franchise_revenue: 'franquia',\r\n    network_revenue: 'rede'\r\n  }[type];\r\n\r\n  return createPartnerNotification(\r\n    partnerId,\r\n    'commission_generated',\r\n    'Nova comissâ”œأ؛o gerada',\r\n    `Vocâ”œآ¬ ganhou R$ ${amount.toFixed(2)} de comissâ”œأ؛o por ${typeLabel}`,\r\n    { amount, type }\r\n  );\r\n}\r\n\r\n/**\r\n * Notificar parceiro sobre comissâ”œأ؛o aprovada\r\n */\r\nexport async function notifyCommissionApproved(\r\n  partnerId: string,\r\n  amount: number\r\n): Promise<boolean> {\r\n  return createPartnerNotification(\r\n    partnerId,\r\n    'commission_approved',\r\n    'Comissâ”œأ؛o aprovada',\r\n    `Sua comissâ”œأ؛o de R$ ${amount.toFixed(2)} foi aprovada e estâ”œأ­ pronta para pagamento`,\r\n    { amount }\r\n  );\r\n}\r\n\r\n/**\r\n * Notificar parceiro sobre comissâ”œأ؛o paga\r\n */\r\nexport async function notifyCommissionPaid(\r\n  partnerId: string,\r\n  amount: number\r\n): Promise<boolean> {\r\n  return createPartnerNotification(\r\n    partnerId,\r\n    'commission_paid',\r\n    'Comissâ”œأ؛o paga',\r\n    `Vocâ”œآ¬ recebeu R$ ${amount.toFixed(2)} de comissâ”œأ؛o`,\r\n    { amount }\r\n  );\r\n}\r\n\r\n/**\r\n * Notificar parceiro sobre nova indicaâ”œآ؛â”œأ؛o\r\n */\r\nexport async function notifyNewReferral(\r\n  partnerId: string,\r\n  referredName: string\r\n): Promise<boolean> {\r\n  return createPartnerNotification(\r\n    partnerId,\r\n    'new_referral',\r\n    'Nova indicaâ”œآ؛â”œأ؛o',\r\n    `${referredName} se cadastrou com seu câ”œâ”‚digo de referâ”œآ¬ncia`,\r\n    { referredName }\r\n  );\r\n}\r\n\r\n/**\r\n * Notificar parceiro sobre indicaâ”œآ؛â”œأ؛o completada\r\n */\r\nexport async function notifyReferralCompleted(\r\n  partnerId: string,\r\n  referredName: string,\r\n  amount: number\r\n): Promise<boolean> {\r\n  return createPartnerNotification(\r\n    partnerId,\r\n    'referral_completed',\r\n    'Indicaâ”œآ؛â”œأ؛o completada',\r\n    `${referredName} fez seu primeiro pagamento. Vocâ”œآ¬ ganhou R$ ${amount.toFixed(2)}`,\r\n    { referredName, amount }\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\services\\partnersService.ts","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":34,"column":48,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":34,"endColumn":51,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[873,876],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[873,876],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":67,"column":48,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":67,"endColumn":51,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1677,1680],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1677,1680],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":101,"column":48,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":101,"endColumn":51,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2388,2391],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2388,2391],"text":"
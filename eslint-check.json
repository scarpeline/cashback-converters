nents/contabilidade/AssinaturaContabilPanel\";\r\nimport UniversalChatPanel from \"@/components/shared/UniversalChatPanel\";\r\nimport CommissionsPanel from \"@/components/partners/CommissionsPanel\";\r\nimport ReferralsPanel from \"@/components/partners/ReferralsPanel\";\r\nimport ReferralCodeDisplay from \"@/components/partners/ReferralCodeDisplay\";\r\nimport { usePartnerByUserId } from \"@/hooks/usePartners\";\r\n\r\nconst AfiliadoDashboard = () => {\r\n  const { profile, signOut } = useAuth();\r\n  const location = useLocation();\r\n  const [sidebarOpen, setSidebarOpen] = useState(false);\r\n\r\n  const basePath = \"/afiliado-saas\";\r\n  \r\n  const navigation = [\r\n    { name: \"Dashboard\", href: basePath, icon: LayoutDashboard },\r\n    { name: \"Meus Indicados\", href: `${basePath}/indicados`, icon: Users },\r\n    { name: \"Comissâ”œأپes\", href: `${basePath}/comissoes`, icon: DollarSign },\r\n    { name: \"Conta Bancâ”œأ­ria\", href: `${basePath}/conta-bancaria`, icon: CreditCard },\r\n    { name: \"Serviâ”œآ؛os Contâ”œأ­beis\", href: `${basePath}/servicos-contabeis`, icon: FileText },\r\n    { name: \"Histâ”œâ”‚rico\", href: `${basePath}/historico`, icon: History },\r\n    { name: \"Meu Link\", href: `${basePath}/link`, icon: LinkIcon },\r\n    { name: \"Meu Perfil\", href: `${basePath}/perfil`, icon: User },\r\n  ];\r\n\r\n  const isActive = (href: string) => {\r\n    if (href === basePath) return location.pathname === basePath || location.pathname === `${basePath}/`;\r\n    return location.pathname.startsWith(href);\r\n  };\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background flex\">\r\n      {sidebarOpen && <div className=\"fixed inset-0 bg-black/50 z-40 lg:hidden\" onClick={() => setSidebarOpen(false)} />}\r\n      <aside className={`fixed lg:static inset-y-0 left-0 z-50 w-64 bg-sidebar border-r border-sidebar-border transform transition-transform duration-200 ease-in-out ${sidebarOpen ? \"translate-x-0\" : \"-translate-x-full lg:translate-x-0\"}`}>\r\n        <div className=\"flex flex-col h-full\">\r\n          <div className=\"p-4 border-b border-sidebar-border flex items-center justify-between\">\r\n            <Link to={basePath} className=\"flex items-center gap-2\">\r\n              <img src={logo} alt=\"Logo\" className=\"w-8 h-8\" />\r\n              <span className=\"font-display font-bold text-lg text-sidebar-primary\">Afiliado SaaS</span>\r\n            </Link>\r\n            <button className=\"lg:hidden text-sidebar-foreground/60\" onClick={() => setSidebarOpen(false)}><X className=\"w-5 h-5\" /></button>\r\n          </div>\r\n          <div className=\"p-4 border-b border-sidebar-border\">\r\n            <p className=\"font-medium truncate text-sidebar-foreground\">{profile?.name || \"Afiliado\"}</p>\r\n            <p className=\"text-sm text-sidebar-foreground/60 truncate\">{profile?.email}</p>\r\n          </div>\r\n          <nav className=\"flex-1 p-4 space-y-1 overflow-y-auto\">\r\n            {navigation.map((item) => (\r\n              <Link key={item.name} to={item.href} onClick={() => setSidebarOpen(false)}\r\n                className={`flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors ${isActive(item.href) ? \"bg-sidebar-primary text-sidebar-primary-foreground\" : \"text-sidebar-foreground/60 hover:bg-sidebar-accent/10 hover:text-sidebar-foreground\"}`}>\r\n                <item.icon className=\"w-5 h-5\" />{item.name}\r\n              </Link>\r\n            ))}\r\n          </nav>\r\n          <div className=\"p-4 border-t border-sidebar-border\">\r\n            <Button variant=\"ghost\" className=\"w-full justify-start gap-3 text-sidebar-foreground/60 hover:text-sidebar-foreground\" onClick={signOut}><LogOut className=\"w-5 h-5\" />Sair</Button>\r\n          </div>\r\n        </div>\r\n      </aside>\r\n      <div className=\"flex-1 flex flex-col min-w-0\">\r\n        <header className=\"h-16 border-b border-border flex items-center justify-between px-4 lg:px-6 bg-card\">\r\n          <button className=\"lg:hidden text-foreground\" onClick={() => setSidebarOpen(true)}><Menu className=\"w-6 h-6\" /></button>\r\n          <div className=\"flex-1\" />\r\n        </header>\r\n        <main className=\"flex-1 p-4 lg:p-6 overflow-auto\">\r\n          <Routes>\r\n            <Route index element={<DashboardHome />} />\r\n            <Route path=\"indicados\" element={<IndicadosPage />} />\r\n            <Route path=\"comissoes\" element={<ComissoesPage />} />\r\n            <Route path=\"conta-bancaria\" element={<ContaBancariaPage />} />\r\n            <Route path=\"servicos-contabeis/*\" element={<ContabeisHubAfiliadoPage />} />\r\n            <Route path=\"historico\" element={<HistoricoPage />} />\r\n            <Route path=\"link\" element={<LinkPage />} />\r\n            <Route path=\"perfil\" element={<PerfilPage />} />\r\n          </Routes>\r\n        </main>\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nconst TABS_AFILIADO = [\r\n  { key: \"solicitar\", label: \"Solicitar Serviâ”œآ؛o\", icon: \"آ­ئ’أ´أ¯\" },\r\n  { key: \"buscar\", label: \"Buscar Contador\", icon: \"آ­ئ’أ¶أ¬\" },\r\n  { key: \"pedidos\", label: \"Pedidos Antecipados\", icon: \"آ­ئ’أ¸أ†\" },\r\n  { key: \"assinatura\", label: \"Assinatura Mensal\", icon: \"آ­ئ’أ¶أ¤\" },\r\n  { key: \"chat\", label: \"Chat Contador\", icon: \"آ­ئ’أ†آ¼\" },\r\n];\r\n\r\nconst ContabeisHubAfiliadoPage = () => {\r\n  const { user } = useAuth();\r\n  const [tab, setTab] = useState(\"solicitar\");\r\n  const [chatContadorId, setChatContadorId] = useState<string | null>(null);\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <h1 className=\"font-display text-2xl font-bold flex items-center gap-2\">\r\n        <FileText className=\"w-6 h-6\" /> Serviâ”œآ؛os Contâ”œأ­beis\r\n      </h1>\r\n      <div className=\"flex flex-wrap gap-2 border-b border-border pb-2\">\r\n        {TABS_AFILIADO.map(t => (\r\n          <Button key={t.key} variant={tab === t.key ? \"gold\" : \"outline\"} size=\"sm\" onClick={() => setTab(t.key)}>\r\n            <span className=\"mr-1\">{t.icon}</span>{t.label}\r\n          </Button>\r\n        ))}\r\n      </div>\r\n      {tab === \"solicitar\" && <SolicitarServicoFiscalPage />}\r\n      {tab === \"buscar\" && (\r\n        <ContadorBuscaPanel\r\n          onAbrirChat={(cid) => { setChatContadorId(cid); setTab(\"chat\"); }}\r\n        />\r\n      )}\r\n      {tab === \"pedidos\" && <PedidoContabilPanel />}\r\n      {tab === \"assinatura\" && <AssinaturaContabilPanel />}\r\n      {tab === \"chat\" && chatContadorId && user && (\r\n        <ChatContadorPanel contadorId={chatContadorId} modo=\"usuario\" />\r\n      )}\r\n      {tab === \"chat\" && !chatContadorId && (\r\n        <div className=\"text-center py-12\">\r\n          <p className=\"text-muted-foreground\">Busque um contador e clique em Chat para iniciar conversa.</p>\r\n          <Button variant=\"outline\" className=\"mt-4\" onClick={() => setTab(\"buscar\")}>آ­ئ’أ¶أ¬ Buscar Contador</Button>\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n};\r\n\r\nconst AFFILIATE_LEVELS = [\r\n  { min: 0,   max: 50,   label: \"Explorador\",              color: \"bg-slate-100 text-slate-700\" },\r\n  { min: 51,  max: 100,  label: \"Visionâ”œأ­rio\",              color: \"bg-blue-100 text-blue-700\" },\r\n  { min: 101, max: 200,  label: \"Estrategista Visionâ”œأ­rio\", color: \"bg-purple-100 text-purple-700\" },\r\n  { min: 201, max: 400,  label: \"Lâ”œآ،der Supremo\",           color: \"bg-orange-100 text-orange-700\" },\r\n  { min: 401, max: 700,  label: \"Imperador Lâ”œآ،der\",         color: \"bg-red-100 text-red-700\" },\r\n  { min: 701, max: 9999, label: \"Sâ”œâ”‚cio PLM\",               color: \"bg-yellow-100 text-yellow-800\" },\r\n];\r\nfunction getLevel(n: number) { return AFFILIATE_LEVELS.find(l => n >= l.min && n <= l.max) || AFFILIATE_LEVELS[0]; }\r\n\r\nconst DashboardHome = () => {\r\n  const { user } = useAuth();\r\n  const [affiliate, setAffiliate] = useState<any>(null);\r\n\r\n  useEffect(() => {\r\n    if (!user) return;\r\n    (supabase as any).from(\"affiliates\").select(\"*\").eq(\"user_id\", user.id).maybeSingle().then(({ data }) => setAffiliate(data));\r\n  }, [user]);\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <div><h1 className=\"font-display text-2xl font-bold\">Dashboard do Afiliado</h1><p className=\"text-muted-foreground\">Acompanhe seus ganhos e indicaâ”œآ؛â”œأپes</p>\r\n        {affiliate && (\r\n          <span className={`inline-flex items-center gap-1 mt-2 px-3 py-1 rounded-full text-sm font-medium ${getLevel(affiliate.total_referrals || 0).color}`}>\r\n            أ”آ،أ‰ {getLevel(affiliate.total_referrals || 0).label} أ”أ‡أ³ {affiliate.total_referrals || 0} indicaâ”œآ؛â”œأپes\r\n          </span>\r\n        )}\r\n      </div>\r\n      <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4\">\r\n        <Card className=\"bg-gradient-card border-primary/20\">\r\n          <CardHeader className=\"pb-2\"><CardDescription>Ganhos Totais</CardDescription><CardTitle className=\"text-2xl text-gradient-gold\">R$ {Number(affiliate?.total_earnings || 0).toFixed(2)}</CardTitle></CardHeader>\r\n          <CardContent><p className=\"text-xs text-muted-foreground flex items-center gap-1\"><TrendingUp className=\"w-3 h-3\" /> Desde o inâ”œآ،cio</p></CardContent>\r\n        </Card>\r\n        <Card><CardHeader className=\"pb-2\"><CardDescription>Saldo Disponâ”œآ،vel</CardDescription><CardTitle className=\"text-2xl\">R$ {Number(affiliate?.pending_earnings || 0).toFixed(2)}</CardTitle></CardHeader><CardContent><p className=\"text-xs text-muted-foreground\">Para saque</p></CardContent></Card>\r\n        <Card><CardHeader className=\"pb-2\"><CardDescription>Empresas Ativas</CardDescription><CardTitle className=\"text-2xl\">{affiliate?.active_referrals || 0}</CardTitle></CardHeader><CardContent><p className=\"text-xs text-muted-foreground\">Mâ”œآ،nimo 3 para saque</p></CardContent></Card>\r\n        <Card><CardHeader className=\"pb-2\"><CardDescription>Ganhos Pendentes</CardDescription><CardTitle className=\"text-2xl\">R$ {Number(affiliate?.pending_earnings || 0).toFixed(2)}</CardTitle></CardHeader><CardContent><p className=\"text-xs text-muted-foreground\">Aguardando confirmaâ”œآ؛â”œأ؛o</p></CardContent></Card>\r\n      </div>\r\n      <Card><CardHeader><CardTitle>Como vocâ”œآ¬ ganha</CardTitle></CardHeader>\r\n        <CardContent>\r\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\r\n            <div className=\"p-4 bg-muted rounded-lg text-center\"><p className=\"text-2xl font-bold text-gradient-gold\">{affiliate?.commission_first || 60}%</p><p className=\"text-sm text-muted-foreground\">Primeira mensalidade</p></div>\r\n            <div className=\"p-4 bg-muted rounded-lg text-center\"><p className=\"text-2xl font-bold text-gradient-gold\">{affiliate?.commission_recurring || 20}%</p><p className=\"text-sm text-muted-foreground\">Mensalidades recorrentes</p></div>\r\n            <div className=\"p-4 bg-muted rounded-lg text-center\"><p className=\"text-2xl font-bold text-gradient-gold\">{affiliate?.commission_saas_tax || 10}%</p><p className=\"text-sm text-muted-foreground\">Taxa SaaS (0,5%)</p></div>\r\n          </div>\r\n        </CardContent>\r\n      </Card>\r\n      <Card><CardHeader><CardTitle className=\"flex items-center gap-2\"><Wallet className=\"w-5 h-5\" />Saque</CardTitle></CardHeader>\r\n        <CardContent>\r\n          <div className=\"flex items-center justify-between p-4 bg-muted rounded-lg\">\r\n            <div><p className=\"font-medium\">Vocâ”œآ¬ precisa de 3 empresas ativas</p><p className=\"text-sm text-muted-foreground\">para liberar saques</p></div>\r\n            <Button variant=\"gold\" disabled={(affiliate?.active_referrals || 0) < 3}>Solicitar Saque</Button>\r\n          </div>\r\n        </CardContent>\r\n      </Card>\r\n      <Card>\r\n        <CardHeader><CardTitle>Progressâ”œأ؛o de Nâ”œآ،vel</CardTitle></CardHeader>\r\n        <CardContent>\r\n          <div className=\"space-y-2\">\r\n            {AFFILIATE_LEVELS.map(l => {\r\n              const total = affiliate?.total_referrals || 0;\r\n              const isActive = total >= l.min && total <= l.max;\r\n              const isDone = total > l.max;\r\n              return (\r\n                <div key={l.label} className={`flex items-center gap-3 p-2 rounded-lg ${isActive ? 'bg-primary/10 border border-primary/30' : ''}`}>\r\n                  <span className={`w-3 h-3 rounded-full ${isDone ? 'bg-success' : isActive ? 'bg-primary' : 'bg-muted-foreground/30'}`} />\r\n                  <span className={`text-sm font-medium ${isActive ? 'text-primary' : isDone ? 'text-success' : 'text-muted-foreground'}`}>{l.label}</span>\r\n                  <span className=\"text-xs text-muted-foreground ml-auto\">{l.min}أ”أ‡أ´{l.max === 9999 ? '1000+' : l.max} indicaâ”œآ؛â”œأپes</span>\r\n                </div>\r\n              );\r\n            })}\r\n          </div>\r\n        </CardContent>\r\n      </Card>\r\n    </div>\r\n  );\r\n};\r\n\r\nconst IndicadosPage = () => {\r\n  const { user } = useAuth();\r\n  const { data: partner } = usePartnerByUserId(user?.id || '');\r\n\r\n  if (!partner) return (\r\n    <div className=\"space-y-6\">\r\n      <h1 className=\"font-display text-2xl font-bold\">Meus Indicados</h1>\r\n      <Card><CardContent className=\"py-12 text-center\"><Users className=\"w-12 h-12 text-muted-foreground mx-auto mb-4\" /><p className=\"text-muted-foreground\">Vocâ”œآ¬ ainda nâ”œأ؛o estâ”œأ­ cadastrado como parceiro.</p></CardContent></Card>\r\n    </div>\r\n  );\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <h1 className=\"font-display text-2xl font-bold\">Meus Indicados</h1>\r\n      <ReferralsPanel partnerId={partner.id} />\r\n    </div>\r\n  );\r\n};\r\n\r\nconst ComissoesPage = () => {\r\n  const { user } = useAuth();\r\n  const { data: partner } = usePartnerByUserId(user?.id || '');\r\n\r\n  if (!partner) return (\r\n    <div className=\"space-y-6\">\r\n      <h1 className=\"font-display text-2xl font-bold\">Minhas Comissâ”œأپes</h1>\r\n      <Card><CardContent className=\"py-12 text-center\"><DollarSign className=\"w-12 h-12 text-muted-foreground mx-auto mb-4\" /><p className=\"text-muted-foreground\">Vocâ”œآ¬ ainda nâ”œأ؛o estâ”œأ­ cadastrado como parceiro.</p></CardContent></Card>\r\n    </div>\r\n  );\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <h1 className=\"font-display text-2xl font-bold\">Minhas Comissâ”œأپes</h1>\r\n      <CommissionsPanel partnerId={partner.id} />\r\n    </div>\r\n  );\r\n};\r\n\r\n// ============ CONTA BANCâ”œأ¼RIA ============\r\nconst ContaBancariaPage = () => {\r\n  const { user, profile } = useAuth();\r\n  const [bankInfo, setBankInfo] = useState<any>(null);\r\n  const [loading, setLoading] = useState(true);\r\n  const [editing, setEditing] = useState(false);\r\n  const [saving, setSaving] = useState(false);\r\n  const [form, setForm] = useState({\r\n    bank_name: \"\", agency: \"\", account: \"\", account_type: \"corrente\",\r\n    cpf_cnpj: \"\", pix_key: \"\", pix_key_type: \"cpf\",\r\n  });\r\n\r\n  useEffect(() => {\r\n    if (!user) return;\r\n    (supabase as any).from(\"profiles\").select(\"bank_info, pix_key, cpf_cnpj, whatsapp, email\").eq(\"user_id\", user.id).maybeSingle().then(({ data }) => {\r\n      if (data?.bank_info) {\r\n        setBankInfo(data.bank_info);\r\n        setForm({ ...(data.bank_info as any), pix_key: data.pix_key || \"\", cpf_cnpj: data.cpf_cnpj || \"\" });\r\n      } else {\r\n        setForm(f => ({ ...f, pix_key: data?.pix_key || \"\", cpf_cnpj: data?.cpf_cnpj || \"\" }));\r\n      }\r\n      setLoading(false);\r\n    });\r\n  }, [user]);\r\n\r\n  const handleSave = async () => {\r\n    if (!form.cpf_cnpj || !form.pix_key) { toast.error(\"CPF/CNPJ e chave PIX sâ”œأ؛o obrigatâ”œâ”‚rios.\"); return; }\r\n    setSaving(true);\r\n    \r\n    const bankData = { bank_name: form.bank_name, agency: form.agency, account: form.account, account_type: form.account_type, pix_key_type: form.pix_key_type };\r\n\r\n    const { error } = await (supabase as any).from(\"profiles\").update({\r\n      bank_info: bankData, pix_key: form.pix_key, cpf_cnpj: form.cpf_cnpj,\r\n    }).eq(\"user_id\", user!.id);\r\n\r\n    if (error) { toast.error(\"Erro: \" + error.message); setSaving(false); return; }\r\n\r\n    // Try to register on gateway with all required fields\r\n    try {\r\n      const phoneDigits = (profile?.whatsapp || \"\").replace(/\\D/g, \"\");\r\n      const cleanCpfCnpj = form.cpf_cnpj.replace(/\\D/g, \"\");\r\n      await supabase.functions.invoke(\"process-payment\", {\r\n        body: {\r\n          action: \"create-wallet\",\r\n          user_id: user!.id,\r\n          cpf_cnpj: cleanCpfCnpj,\r\n          name: profile?.name,\r\n          email: profile?.email,\r\n          mobile_phone: phoneDigits.length >= 10 ? phoneDigits : undefined,\r\n          pix_key: form.pix_key,\r\n        },\r\n      });\r\n      toast.success(\"Conta bancâ”œأ­ria salva e carteira criada no gateway!\");\r\n    } catch {\r\n      toast.success(\"Conta bancâ”œأ­ria salva! Carteira serâ”œأ­ criada automaticamente.\");\r\n    }\r\n\r\n    setBankInfo(bankData);\r\n    setEditing(false);\r\n    setSaving(false);\r\n  };\r\n\r\n  if (loading) return <div className=\"flex justify-center py-12\"><Loader2 className=\"w-8 h-8 animate-spin text-primary\" /></div>;\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <h1 className=\"font-display text-2xl font-bold\">Conta Bancâ”œأ­ria / PIX</h1>\r\n      <Card className=\"border-primary/20 bg-primary/5\">\r\n        <CardHeader><CardTitle className=\"flex items-center gap-2\"><CreditCard className=\"w-5 h-5\" />Dados para Recebimento</CardTitle>\r\n          <CardDescription>Configure sua conta para receber saques automaticamente via gateway</CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-4\">\r\n          {!editing && bankInfo ? (\r\n            <>\r\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-3\">\r\n                <div className=\"p-3 bg-muted rounded-lg\"><p className=\"text-xs text-muted-foreground\">Banco</p><p className=\"font-medium\">{bankInfo.bank_name || \"-\"}</p></div>\r\n                <div className=\"p-3 bg-muted rounded-lg\"><p className=\"text-xs text-muted-foreground\">Agâ”œآ¬ncia</p><p className=\"font-medium\">{bankInfo.agency || \"-\"}</p></div>\r\n                <div className=\"p-3 bg-muted rounded-lg\"><p className=\"text-xs text-muted-foreground\">Conta</p><p className=\"font-medium\">{bankInfo.account || \"-\"} ({bankInfo.account_type})</p></div>\r\n                <div className=\"p-3 bg-muted rounded-lg\"><p className=\"text-xs text-muted-foreground\">Chave PIX</p><p className=\"font-medium\">{form.pix_key || \"-\"}</p></div>\r\n                <div className=\"p-3 bg-muted rounded-lg\"><p className=\"text-xs text-muted-foreground\">CPF/CNPJ</p><p className=\"font-medium\">{form.cpf_cnpj || \"-\"}</p></div>\r\n              </div>\r\n              <Button variant=\"gold\" onClick={() => setEditing(true)}>Editar Dados</Button>\r\n            </>\r\n          ) : (\r\n            <>\r\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-3\">\r\n                <div><Label>CPF/CNPJ *</Label><Input value={form.cpf_cnpj} onChange={e => setForm({ ...form, cpf_cnpj: formatCpfCnpjBR(e.target.value) })} placeholder=\"000.000.000-00\" className=\"mt-1\" /></div>\r\n                <div><Label>Tipo de Chave PIX</Label>\r\n                  <select className=\"flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm mt-1\" value={form.pix_key_type} onChange={e => setForm({ ...form, pix_key_type: e.target.value })}>\r\n                    <option value=\"cpf\">CPF/CNPJ</option><option value=\"email\">E-mail</option><option value=\"phone\">Telefone</option><option value=\"random\">Chave Aleatâ”œâ”‚ria</option>\r\n                  </select>\r\n                </div>\r\n                <div><Label>Chave PIX *</Label><Input value={form.pix_key} onChange={e => setForm({ ...form, pix_key: e.target.value })} placeholder=\"Sua chave PIX\" className=\"mt-1\" /></div>\r\n                <div><Label>Banco</Label><Input value={form.bank_name} onChange={e => setForm({ ...form, bank_name: e.target.value })} placeholder=\"Nome do banco\" className=\"mt-1\" /></div>\r\n                <div><Label>Agâ”œآ¬ncia</Label><Input value={form.agency} onChange={e => setForm({ ...form, agency: e.target.value })} placeholder=\"0001\" className=\"mt-1\" /></div>\r\n                <div><Label>Conta</Label><Input value={form.account} onChange={e => setForm({ ...form, account: e.target.value })} placeholder=\"12345-6\" className=\"mt-1\" /></div>\r\n              </div>\r\n              <div className=\"flex gap-2\">\r\n                <Button variant=\"gold\" onClick={handleSave} disabled={saving}>{saving ? <Loader2 className=\"w-4 h-4 animate-spin mr-2\" /> : <CreditCard className=\"w-4 h-4 mr-2\" />}{saving ? \"Salvando...\" : \"Salvar e Criar Conta no Gateway\"}</Button>\r\n                {bankInfo && <Button variant=\"ghost\" onClick={() => setEditing(false)}>Cancelar</Button>}\r\n              </div>\r\n            </>\r\n          )}\r\n        </CardContent>\r\n      </Card>\r\n    </div>\r\n  );\r\n};\r\n\r\nconst HistoricoPage = () => (\r\n  <div className=\"space-y-6\">\r\n    <h1 className=\"font-display text-2xl font-bold\">Histâ”œâ”‚rico</h1>\r\n    <Card><CardContent className=\"py-12 text-center\"><History className=\"w-12 h-12 text-muted-foreground mx-auto mb-4\" /><p className=\"text-muted-foreground\">Nenhuma atividade registrada.</p></CardContent></Card>\r\n  </div>\r\n);\r\n\r\nconst LinkPage = () => {\r\n  const { user } = useAuth();\r\n  const { data: partner } = usePartnerByUserId(user?.id || '');\r\n\r\n  if (!partner) return (\r\n    <div className=\"space-y-6\">\r\n      <h1 className=\"font-display text-2xl font-bold\">Meu Link de Indicaâ”œآ؛â”œأ؛o</h1>\r\n      <Card><CardContent className=\"py-12 text-center\"><LinkIcon className=\"w-12 h-12 text-muted-foreground mx-auto mb-4\" /><p className=\"text-muted-foreground\">Vocâ”œآ¬ ainda nâ”œأ؛o estâ”œأ­ cadastrado como parceiro.</p></CardContent></Card>\r\n    </div>\r\n  );\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <h1 className=\"font-display text-2xl font-bold\">Meu Link de Indicaâ”œآ؛â”œأ؛o</h1>\r\n      <ReferralCodeDisplay referralCode={partner.referral_code || ''} partnerName={partner.users?.name || 'Afiliado'} />\r\n    </div>\r\n  );\r\n};\r\n\r\nconst PerfilPage = () => {\r\n  const { profile, user } = useAuth();\r\n  const [editing, setEditing] = useState(false);\r\n  const [form, setForm] = useState({ name: \"\", whatsapp: \"\", cpf_cnpj: \"\", pix_key: \"\" });\r\n  const [saving, setSaving] = useState(false);\r\n  const [bankInfo, setBankInfo] = useState<any>(null);\r\n  const [avatarUrl, setAvatarUrl] = useState<string | null>(null);\r\n\r\n  useEffect(() => {\r\n    if (profile) setForm({ name: profile.name || \"\", whatsapp: profile.whatsapp || \"\", cpf_cnpj: profile.cpf_cnpj || \"\", pix_key: profile.pix_key || \"\" });\r\n    if (user) {\r\n      (supabase as any).from(\"profiles\").select(\"bank_info\").eq(\"user_id\", user.id).maybeSingle().then(({ data }) => {\r\n        if (data?.bank_info) setBankInfo(data.bank_info);\r\n      });\r\n    }\r\n  }, [profile, user]);\r\n\r\n  const saveProfile = async () => {\r\n    if (!user) return;\r\n    setSaving(true);\r\n    const { error } = await (supabase as any).from(\"profiles\").update({ name: form.name, whatsapp: form.whatsapp || null, cpf_cnpj: form.cpf_cnpj || null, pix_key: form.pix_key || null }).eq(\"user_id\", user.id);\r\n    setSaving(false);\r\n    if (error) { toast.error(\"Erro: \" + error.message); return; }\r\n    toast.success(\"Perfil atualizado!\"); setEditing(false);\r\n  };\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <h1 className=\"font-display text-2xl font-bold\">Meu Perfil</h1>\r\n      <Card>\r\n        <CardContent className=\"pt-6 space-y-4\">\r\n          <div className=\"flex items-center gap-4 mb-4\">\r\n            <ProfilePhotoUpload userId={user!.id} avatarUrl={avatarUrl ?? profile?.avatar_url ?? null} onUpdate={setAvatarUrl} size=\"lg\" />\r\n            <div><p className=\"font-bold\">{profile?.name || \"Afiliado\"}</p><p className=\"text-xs text-muted-foreground\">Passe o mouse e clique na câ”œأ³mera para alterar a foto</p></div>\r\n          </div>\r\n          {editing ? (\r\n            <>\r\n              <div><Label>Nome</Label><Input value={form.name} onChange={e => setForm({ ...form, name: e.target.value })} className=\"mt-1\" /></div>\r\n              <div><Label>WhatsApp</Label><Input value={form.whatsapp} onChange={e => setForm({ ...form, whatsapp: e.target.value })} className=\"mt-1\" /></div>\r\n              <div><Label>CPF/CNPJ</Label><Input value={form.cpf_cnpj} onChange={e => setForm({ ...form, cpf_cnpj: formatCpfCnpjBR(e.target.value) })} className=\"mt-1\" /></div>\r\n              <div><Label>Chave PIX</Label><Input value={form.pix_key} onChange={e => setForm({ ...form, pix_key: e.target.value })} className=\"mt-1\" /></div>\r\n              <div className=\"flex gap-2\"><Button variant=\"gold\" onClick={saveProfile} disabled={saving}>{saving ? \"Salvando...\" : \"Salvar\"}</Button><Button variant=\"outline\" onClick={() => setEditing(false)}>Cancelar</Button></div>\r\n            </>\r\n          ) : (\r\n            <>\r\n              <div><label className=\"text-sm text-muted-foreground\">Nome</label><p className=\"font-medium\">{profile?.name || \"-\"}</p></div>\r\n              <div><label className=\"text-sm text-muted-foregroun
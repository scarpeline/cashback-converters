eto\", placeholder: \"Nome conforme RG/CNH\", required: true },\r\n    { key: \"cpf\", label: \"CPF\", placeholder: \"000.000.000-00\", required: true },\r\n    { key: \"company_type\", label: \"Tipo de Empresa\", placeholder: \"\", type: \"select\", options: [\r\n      { value: \"mei\", label: \"MEI - Microempreendedor Individual\" },\r\n      { value: \"me\", label: \"ME - Microempresa (Simples Nacional)\" },\r\n    ], required: true },\r\n    { key: \"activity\", label: \"Atividade Principal (CNAE)\", placeholder: \"Ex: 9602-5/01 - Cabeleireiros, 9602-5/02 - Manicure\" },\r\n    { key: \"address\", label: \"Endereâ”œآ؛o Comercial\", placeholder: \"Rua, nâ”œâ•‘mero, bairro, cidade/UF, CEP\" },\r\n    { key: \"phone\", label: \"Telefone de Contato\", placeholder: \"(11) 99999-0000\" },\r\n    { key: \"start_date\", label: \"Data Prevista de Inâ”œآ،cio\", placeholder: \"Ex: 01/04/2026\" },\r\n  ],\r\n  mei_declaration: [\r\n    { key: \"cnpj\", label: \"CNPJ MEI\", placeholder: \"00.000.000/0001-00\", required: true },\r\n    { key: \"company_name\", label: \"Nome da Empresa\", placeholder: \"Razâ”œأ؛o social no CNPJ\" },\r\n    { key: \"year\", label: \"Ano-Calendâ”œأ­rio\", placeholder: \"Ex: 2025\", required: true },\r\n    { key: \"annual_revenue\", label: \"Faturamento Bruto Anual (R$)\", placeholder: \"Ex: 72.000,00\", required: true },\r\n    { key: \"had_employee\", label: \"Teve Funcionâ”œأ­rio?\", type: \"select\", placeholder: \"\", options: [\r\n      { value: \"no\", label: \"Nâ”œأ؛o\" },\r\n      { value: \"yes\", label: \"Sim\" },\r\n    ] },\r\n  ],\r\n  me_declaration: [\r\n    { key: \"cnpj\", label: \"CNPJ da Empresa\", placeholder: \"00.000.000/0001-00\", required: true },\r\n    { key: \"company_name\", label: \"Razâ”œأ؛o Social\", placeholder: \"Nome da empresa\" },\r\n    { key: \"year\", label: \"Ano-Calendâ”œأ­rio\", placeholder: \"Ex: 2025\", required: true },\r\n    { key: \"annual_revenue\", label: \"Faturamento Bruto Anual (R$)\", placeh
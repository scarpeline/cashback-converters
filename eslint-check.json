out(() => {\r\n                navigate(\"/login\");\r\n            }, 3000);\r\n        }, 2000);\r\n    };\r\n\r\n    if (success) {\r\n        return (\r\n            <div className=\"min-h-screen bg-background flex items-center justify-center p-4\">\r\n                <Card className=\"max-w-md w-full text-center py-8\">\r\n                    <CardContent className=\"space-y-4\">\r\n                        <div className=\"w-16 h-16 bg-success/10 rounded-full flex items-center justify-center mx-auto mb-4\">\r\n                            <CheckCircle2 className=\"w-10 h-10 text-success\" />\r\n                        </div>\r\n                        <CardTitle className=\"text-2xl font-bold\">Pagamento Confirmado!</CardTitle>\r\n                        <CardDescription className=\"text-lg\">\r\n                            Sua assinatura do plano <strong>{selectedPlan?.name || \"Premium\"}</strong> foi ativada com sucesso.\r\n                        </CardDescription>\r\n                        <div className=\"pt-8\">\r\n                            <p className=\"text-muted-foreground text-sm flex items-center justify-center gap-2\">\r\n                                <Loader2 className=\"w-4 h-4 animate-spin\" />\r\n                                Redirecionando para o login...\r\n                            </p>\r\n                        </div>\r\n                    </CardContent>\r\n                </Card>\r\n            </div>\r\n        );\r\n    }\r\n\r\n    return (\r\n        <div className=\"min-h-screen bg-background flex flex-col items-center justify-center p-4 relative overflow-hidden\">\r\n            <div className=\"absolute top-0 left-0 w-full h-1 bg-gradient-gold\" />\r\n\r\n            <Link to=\"/\" className=\"mb-8 flex items-center gap-2\">\r\n                <img src={logo} alt=\"Logo\" className=\"w-10 h-10\" />\r\n                <span className=\"font-display font-bold text-xl text-gradient-gold\">Salâ”œأ؛oCashBack</span>\r\n        
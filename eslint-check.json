Usuâ”œأ­rio nâ”œأ؛o encontrado';\r\n      }\r\n\r\n      toast.error(errorMessage, {\r\n        icon: <XCircle className=\"w-5 h-5 text-red-500\" />,\r\n      });\r\n    }\r\n  };\r\n\r\n  const handleChange = (field: string, value: string) => {\r\n    setFormData(prev => ({ ...prev, [field]: value }));\r\n    \r\n    // Clear error for this field when user starts typing\r\n    if (errors[field]) {\r\n      setErrors(prev => ({ ...prev, [field]: '' }));\r\n    }\r\n  };\r\n\r\n  const getTypeDescription = (type: string) => {\r\n    switch (type) {\r\n      case 'afiliado':\r\n        return 'Indica clientes e ganha comissâ”œأ؛o sobre vendas';\r\n      case 'franqueado':\r\n        return 'Gerencia uma unidade e ganha sobre faturamento';\r\n      case 'diretor':\r\n        return 'Coordena franqueados e ganha sobre rede';\r\n      default:\r\n        return '';\r\n    }\r\n  };\r\n\r\n  const activePartners = partners?.filter(p => p.status === 'ativo') || [];\r\n\r\n  return (\r\n    <Card>\r\n      <CardHeader>\r\n        <CardTitle className=\"flex items-center gap-2\">\r\n          <UserPlus className=\"w-5 h-5\" />\r\n          {defaultValues?.user_id ? 'Editar Parceiro' : 'Novo Parceiro'}\r\n        </CardTitle>\r\n      </CardHeader>\r\n      <CardContent>\r\n        <form onSubmit={handleSubmit} className=\"space-y-4\">\r\n          {/* User ID */}\r\n          <div className=\"space-y-2\">\r\n            <Label htmlFor=\"user_id\">\r\n              ID do Usuâ”œأ­rio <span className=\"text-destructive\">*</span>\r\n            </Label>\r\n            <Input\r\n              id=\"user_id\"\r\n              placeholder=\"Digite o ID do usuâ”œأ­rio (UUID)\"\r\n              value={formData.user_id}\r\n              onChange={(e) => handleChange('user_id', e.target.value)}\r\n              className={errors.user_id ? 'border-destructive' : ''}\r\n              disabled={!!defaultValues?.user_id}\r\n            />\r\n            {errors.user_id && (\r\n              <p className=\"text-sm text-destructive\">{errors.user_id}</p>\r\n            )}\r\n            <p className=\"text-xs text-muted-foreground\">\r\n              ID â”œâ•‘nico do usuâ”œأ­rio no sistema (geralmente do auth.users)\r\n            </p>\r\n          </div>\r\n\r\n          {/* Partner Type */}\r\n          <div className=\"space-y-2\">\r\n            <Label htmlFor=\"type\">\r\n              Tipo de Parceiro <span className=\"text-destructive\">*</span>\r\n            </Label>\r\n            <Select\r\n              value={formData.type}\r\n              onValueChange={(value: 'afiliado' | 'franqueado' | 'diretor') => \r\n                handleChange('type', value)\r\n              }\r\n            >\r\n              <SelectTrigger className={errors.type ? 'border-destructive' : ''}>\r\n                <SelectValue placeholder=\"Selecione o tipo\" />\r\n              </SelectTrigger>\r\n              <SelectContent>\r\n                <SelectItem value=\"afiliado\">\r\n                  <div className=\"flex items-center gap-2\">\r\n                    <div className=\"w-2 h-2 rounded-full bg-green-500\" />\r\n                    <span>Afiliado</span>\r\n                  </div>\r\n                </SelectItem>\r\n                <SelectItem value=\"franqueado\">\r\n                  <div className=\"flex items-center gap-2\">\r\n                    <div className=\"w-2 h-2 rounded-full bg-blue-500\" />\r\n                    <span>Franqueado</span>\r\n                  </div>\r\n                </SelectItem>\r\n                <SelectItem value=\"diretor\">\r\n                  <div className=\"flex items-center gap-2\">\r\n                    <div className=\"w-2 h-2 rounded-full bg-purple-500\" />\r\n                    <span>Diretor</span>\r\n                  </div>\r\n                </SelectItem>\r\n              </SelectContent>\r\n            </Select>\r\n            {errors.type && (\r\n              <p className=\"text-sm text-destructive\">{errors.type}</p>\r\n            )}\r\n            <p className=\"text-xs text-muted-foreground\">\r\n              {getTypeDescription(formData.type)}\r\n            </p>\r\n          </div>\r\n\r\n          {/* Parent Partner (Optional) */}\r\n          <div className=\"space-y-2\">\r\n            <Label htmlFor=\"parent_id\">Parceiro Pai (Opcional)</Label>\r\n            <Select\r\n              value={formData.parent_id}\r\n              onValueChange={(value) => handleChange('parent_id', value)}\r\n            >\r\n              <SelectTrigger>\r\n                <SelectValue placeholder=\"Selecione o parceiro pai\" />\r\n              </SelectTrigger>\r\n              <SelectContent>\r\n                <SelectItem value=\"\">Nenhum (Parceiro raiz)</SelectItem>\r\n                {activePartners.map(partner => (\r\n                  <SelectItem key={partner.id} value={partner.id}>\r\n                    <div className=\"flex items-center gap-2\">\r\n                      <span className=\"capitalize\">{partner.type}</span>\r\n                      <span className=\"text-muted-foreground text-xs\">\r\n                        - {partner.users?.name || 'Sem nome'}\r\n                      </span>\r\n                    </div>\r\n                  </SelectItem>\r\n                ))}\r\n              </SelectContent>\r\n            </Select>\r\n            <p className=\"text-xs text-muted-foreground\">\r\n              Selecione o parceiro que indicou este novo parceiro\r\n            </p>\r\n          </div>\r\n\r\n          {/* Form Actions */}\r\n          <div className=\"flex gap-2 pt-4\">\r\n            <Button\r\n              type=\"submit\"\r\n              disabled={createPartner.isPending}\r\n              className=\"flex-1\"\r\n            >\r\n              {createPartner.isPending ? (\r\n                <>\r\n                  <Loader2 className=\"w-4 h-4 mr-2 animate-spin\" />\r\n                  Criando...\r\n                </>\r\n              ) : (\r\n                <>\r\n                  <UserPlus className=\"w-4 h-4 mr-2\" />\r\n                  {defaultValues?.user_id ? 'Atualizar' : 'Criar Parceiro'}\r\n                </>\r\n              )}\r\n            </Button>\r\n\r\n            {onCancel && (\r\n              <Button\r\n                type=\"button\"\r\n                variant=\"outline\"\r\n                onClick={onCancel}\r\n                disabled={createPartner.isPending}\r\n              >\r\n                Cancelar\r\n              </Button>\r\n            )}\r\n          </div>\r\n\r\n          {/* Help Text */}\r\n          <div className=\"pt-4 border-t\">\r\n            <p className=\"text-sm text-muted-foreground\">\r\n              <strong>Importante:</strong> O usuâ”œأ­rio deve existir no sistema antes de ser cadastrado como parceiro.\r\n            </p>\r\n            <p className=\"text-xs text-muted-foreground mt-1\">\r\n              Apâ”œâ”‚s a criaâ”œآ؛â”œأ؛o, o parceiro aparecerâ”œأ­ na lista e poderâ”œأ­ comeâ”œآ؛ar a indicar clientes.\r\n            </p>\r\n          </div>\r\n        </form>\r\n      </CardContent>\r\n    </Card>\r\n  );\r\n}","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\components\\partners\\PartnerHierarchyTree.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\components\\partners\\PartnerList.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\components\\partners\\PartnerNotificationCenter.tsx","messa
essageId":"suggestUnknown","fix":{"range":[2598,2601],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2598,2601],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":100,"column":37,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":100,"endColumn":40,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2696,2699],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2696,2699],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":101,"column":18,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":101,"endColumn":21,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2726,2729],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2726,2729],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":8,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/**\r\n * Tratamento centralizado de erros do Supabase\r\n * Evita telas brancas e fornece feedback ao usuâ”œأ­rio\r\n */\r\n\r\nexport interface SupabaseError {\r\n  code?: string;\r\n  message: string;\r\n  details?: string;\r\n  hint?: string;\r\n}\r\n\r\nexport const handleSupabaseError = (error: any): string => {\r\n  if (!error) return \"Erro desconhecido\";\r\n\r\n  // Erro de conexâ”œأ؛o\r\n  if (error.message?.includes(\"Failed to fetch\")) {\r\n    return \"Erro de conexâ”œأ؛o. Verifique sua internet.\";\r\n  }\r\n\r\n  // Erro de autenticaâ”œآ؛â”œأ؛o\r\n  if (error.status === 401 || error.message?.includes(\"unauthorized\")) {\r\n    return \"Sessâ”œأ؛o expirada. Faâ”œآ؛a login novamente.\";\r\n  }\r\n\r\n  // Erro de permissâ”œأ؛o\r\n  if (error.status === 403 || error.message?.includes(\"permission denied\")) {\r\n    return \"Vocâ”œآ¬ nâ”œأ؛o tem permissâ”œأ؛o para acessar isso.\";\r\n  }\r\n\r\n  // Erro de tabela nâ”œأ؛o encontrada\r\n  if (error.code === \"PGRST116\" || error.message?.includes(\"relation does not exist\")) {\r\n    return \"Recurso nâ”œأ؛o disponâ”œآ،vel. Contate o suporte.\";\r\n  }\r\n\r\n  // Erro de constraint (chave estrangeira, unique, etc)\r\n  if (error.code?.startsWith(\"23\")) {\r\n    if (error.message?.includes(\"unique\")) {\r\n      return \"Este registro jâ”œأ­ existe.\";\r\n    }\r\n    if (error.message?.includes(\"foreign key\")) {\r\n      return \"Referâ”œآ¬ncia invâ”œأ­lida. Verifique os dados.\";\r\n    }\r\n    return \"Erro de validaâ”œآ؛â”œأ؛o dos dados.\";\r\n  }\r\n\r\n  // Erro genâ”œآ®rico\r\n  return error.message || \"Erro ao processar requisiâ”œآ؛â”œأ؛o\";\r\n};\r\n\r\n/**\r\n * Wrapper seguro para queries do Supabase\r\n * Retorna dados ou array vazio em caso de erro\r\n */\r\nexport const safeSupabaseQuery = async <T>(\r\n  query: Promise<{ data: T | null; error: any }>,\r\n  fallback: T = [] as any\r\n): Promise<T> => {\r\n  try {\r\n    const { data, error } = await query;\r\n    if (error) {\r\n      console.error(\"Supabase Error:\", error);\r\n      return fallback;\r\n    }\r\n    return data || fallback;\r\n  } catch (err) {\r\n    console.error(\"Query Error:\", err);\r\n    return fallback;\r\n  }\r\n};\r\n\r\n/**\r\n * Validar se tabela existe antes de fazer query\r\n */\r\nexport const tableExists = async (supabase: any, tableName: string): Promise<boolean> => {\r\n  try {\r\n    const { error } = await (supabase as any)\r\n      .from(tableName)\r\n      .select(\"1\")\r\n      .limit(1);\r\n    \r\n    // Se erro â”œآ® \"relation does not exist\", tabela nâ”œأ؛o existe\r\n    if (error?.code === \"PGRST116\") {\r\n      return false;\r\n    }\r\n    \r\n    return true;\r\n  } catch {\r\n    return false;\r\n  }\r\n};\r\n\r\n/**\r\n * Retry logic para queries que podem falhar temporariamente\r\n */\r\nexport const retrySupabaseQuery = async <T>(\r\n  queryFn: () => Promise<{ data: T | null; error: any }>,\r\n  maxRetries: number = 3,\r\n  delayMs: number = 1000\r\n): Promise<{ data: T | null; error: any }> => {\r\n  let lastError: any;\r\n\r\n  for (let i = 0; i < maxRetries; i++) {\r\n    try {\r\n      const result = await queryFn();\r\n      if (!result.error) {\r\n        return result;\r\n      }\r\n      lastError = result.error;\r\n\r\n      // Nâ”œأ؛o retry em erros de permissâ”œأ؛o ou autenticaâ”œآ؛â”œأ؛o\r\n      if (result.error?.status === 401 || result.error?.status === 403) {\r\n        return result;\r\n      }\r\n\r\n      // Aguarda antes de retry\r\n      if (i < maxRetries - 1) {\r\n        await new Promise(resolve => setTimeout(resolve, delayMs * (i + 1)));\r\n      }\r\n    } catch (err) {\r\n      lastError = err;\r\n    }\r\n  }\r\n\r\n  return { data: null, error: lastError };\r\n};\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\lib\\supabase-init-check.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\lib\\supabase.ts","messages":[],"suppress
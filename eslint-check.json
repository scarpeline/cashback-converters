bel: 'White Label',\r\n  dedicated_support: 'Suporte Dedicado',\r\n  unlimited_everything: 'Recursos Ilimitados'\r\n};\r\n\r\nexport function SubscriptionPlans() {\r\n  const { plans, loading, createSubscription } = useSubscriptionPlans();\r\n  const { user } = useAuth();\r\n  const [selectedPlan, setSelectedPlan] = useState<string | null>(null);\r\n  const [subscribing, setSubscribing] = useState(false);\r\n\r\n  const handleSubscribe = async (planId: string) => {\r\n    if (!user) {\r\n      toast.error('Vocâ”œآ¬ precisa estar logado para assinar um plano');\r\n      return;\r\n    }\r\n\r\n    setSubscribing(true);\r\n    setSelectedPlan(planId);\r\n\r\n    try {\r\n      const result = await createSubscription(planId, user.id);\r\n      \r\n      if (result) {\r\n        if (result.status === 'active') {\r\n          toast.success('Assinatura ativada com sucesso!');\r\n        } else {\r\n          toast.info('Redirecionando para pagamento...');\r\n        }\r\n      }\r\n    } catch (error) {\r\n      console.error('Erro ao assinar plano:', error);\r\n      toast.error('Erro ao processar assinatura');\r\n    } finally {\r\n      setSubscribing(false);\r\n      setSelectedPlan(null);\r\n    }\r\n  };\r\n\r\n  if (loading) {\r\n    return (\r\n      <div className=\"flex items-center justify-center p-8\">\r\n        <div className=\"animate-spin rounded-full h-8 w-8 border-b-2 border-primary\"></div>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  return (\r\n    <div className=\"space-y-8\">\r\n      <div className=\"text-center\">\r\n        <h2 className=\"text-3xl font-bold mb-4\">Escolha seu plano</h2>\r\n        <p className=\"text-muted-foreground\">\r\n          Comece grâ”œأ­tis e upgrade quando precisar\r\n        </p>\r\n      </div>\r\n\r\n      <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto\">\r\n        {plans.map((plan) => {\r\n          const isTrial = plan.duration_months === 0;\r\n          const isPopular = plan.sort_order === 2; // Trimestral\r\n          const isAnnual = plan.duration_months === 12;\r\n          \r\n          return (\r\n            <Card\r\n              key={plan.id}\r\n              className={`relative ${isPopular ? 'border-primary shadow-lg scale-105' : ''}`}\r\n            >\r\n              {isPopular && (\r\n                <div className=\"absolute -top-3 left-1/2 -translate-x-1/2\">\r\n                  <div className=\"bg-primary text-primary-foreground px-3 py-1 rounded-full text-sm font-medium\">\r\n                    Mais Popular\r\n                  </div>\r\n                </div>\r\n              )}\r\n\r\n              <CardHeader className=\"text-center\">\r\n                <CardTitle className=\"text-xl\">{plan.name}</CardTitle>\r\n                <CardDescription>\r\n                  {isTrial ? 'Teste por 7 dias grâ”œأ­tis' : `R$ ${plan.price.toFixed(2)}/${plan.duration_months === 1 ? 'mâ”œآ¬s' : plan.duration_months === 3 ? 'trimestre' : 'ano'}`}\r\n                </CardDescription>\r\n              </CardHeader>\r\n\r\n              <CardContent className=\"space-y-6\">\r\n                <div className=\"text-center\">\r\n                  <div className=\"text-3xl font-bold\">\r\n                    {isTrial ? 'GRâ”œأ¼TIS' : `R$ ${plan.price.toFixed(2)}`}\r\n                  </div>\r\n                  {!isTrial && (\r\n                    <div className=\"text-sm text-muted-foreground\">\r\n                      {plan.duration_months === 1 && 'por mâ”œآ¬s'}\r\n                      {plan.duration_months === 3 && `R$ ${(plan.price / 3).toFixed(2)} por mâ”œآ¬s`}\r\n                      {plan.duration_months === 12 && `R$ ${(plan.price / 12).toFixed(2)} por mâ”œآ¬s`}\r\n                    </div>\r\n                  )}\r\n                </div>\r\n\r\n                <div className=\"space-y-3\">\r\n                  <h4 className=\"font-medium text-sm\">Recursos incluâ”œآ،dos:</h4>\r\n                  <div className=\"space-y-2\">\r\n                    {/* Recursos bâ”œأ­sicos (todos os planos) */}\r\n                    <div className=\"flex items-center gap-2 text-sm\">\r\n                      <Check className=\"w-4 h-4 text-green-500\" />\r\n                      <span>Dashboard Completo</span>\r\n                    </div>\r\n                    <div className=\"flex items-center gap-2 text-sm\">\r\n                      <Check className=\"w-4 h-4 text-green-500\" />\r\n                      <span>Agendamentos Ilimitados</span>\r\n                    </div>\r\n                    <div className=\"flex items-center gap-2 text-sm\">\r\n                      <Check className=\"w-4 h-4 text-green-500\" />\r\n                      <span>Pagamentos PIX e Cartâ”œأ؛o</span>\r\n                    </div>\r\n                    <div className=\"flex items-center gap-2 text-sm\">\r\n                      <Check className=\"w-4 h-4 text-green-500\" />\r\n                      <span>Cashback Configurâ”œأ­vel</span>\r\n                    </div>\r\n                    <div className=\"flex items-center gap-2 text-sm\">\r\n                      <Check className=\"w-4 h-4 text-green-500\" />\r\n                      <span>Relatâ”œâ”‚rios Financeiros</span>\r\n                    </div>\r\n\r\n                    {/* Recursos premium (planos pagos) */}\r\n                    {!isTrial && (\r\n                      <>\r\n                        <div className=\"flex items-center gap-2 text-sm\">\r\n                          <Zap className=\"w-4 h-4 text-blue-500\" />\r\n                          <span>Acesso â”œأ، API</span>\r\n                        </div>\r\n                        {(plan.sort_order >= 2) && (\r\n                          <div className=\"flex items-center gap-2 text-sm\">\r\n                            <Crown className=\"w-4 h-4 text-purple-500\" />\r\n                            <span>Domâ”œآ،nio Personalizado</span>\r\n                          </div>\r\n                        )}\r\n                        {(plan.sort_order >= 2) && (\r\n                          <div className=\"flex items-center gap-2 text-sm\">\r\n                            <Shield className=\"w-4 h-4 text-orange-500\" />\r\n                            <span>Suporte Prioritâ”œأ­rio</span>\r\n                          </div>\r\n                        )}\r\n                        {isAnnual && (\r\n                          <>\r\n                            <div className=\"flex items-center gap-2 text-sm\">\r\n                              <Sparkles className=\"w-4 h-4 text-pink-500\" />\r\n                              <span>White Label</span>\r\n                            </div>\r\n                            <div className=\"flex items-center gap-2 text-sm\">\r\n                              <Sparkles className=\"w-4 h-4 text-yellow-500\" />\r\n                              <span>Recursos Ilimitados</span>\r\n                            </div>\r\n                          </>\r\n                        )}\r\n                      </>\r\n                    )}\r\n                  </div>\r\n                </div>\r\n\r\n                <Button\r\n                  className=\"w-full\"\r\n                  variant={isPopular ? 'default' : 'outline'}\r\n                  onClick={() => handleSubscribe(plan.id)}\r\n                  disabled={subscribing && selectedPlan !== plan.id}\r\n                >\r\n                  {subscribing && selectedPlan === plan.id ? (\r\n                    'Processando...'\r\n                  ) : isTrial ? (\r\n                    'Comeâ”œآ؛ar Grâ”œأ­tis'\r\n                  ) : (\r\n                    'Assinar Agora'\r\n                  )}\r\n                </Button>\r\n\r\n                {isTrial && (\r\n                  <p className=\"text-xs text-muted-foreground text-center\">\r\n                    7 dias grâ”œأ­tis أ”أ‡أ³ Sem cartâ”œأ؛o necessâ”œأ­rio\r\n                  </p>\r\n                )}\r\n\r\n                {!isTrial && isAnnual && (\r\n                  <p className=\"text-xs text-green-600 text-center font-medium\">\r\n                    Economia de 44% comparado ao plano mensal\r\n                  </p>\r\n                )}\r\n              </CardContent>\r\n            </Card>\r\n          );\r\n        })}\r\n      </div>\r\n\r\n      <div className=\"text-center text-sm text-muted-foreground\">\r\n        <p>Cancelamento a qualquer momento أ”أ‡أ³ Sem taxas ocultas أ”أ‡أ³ Suporte via chat</p>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\components\\subscription\\SubscriptionStatus.tsx","messages":[{"ruleId":"@typescript-eslint/ban-ts-comment","severity":2,"message":"Do not use \"@ts-nocheck\" because it alters compilation errors.","line":1,"column":1,"nodeType":"Line","messageId":"tsDirectiveComment","endLine":1,"endColumn":15}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"// @ts-nocheck\r\nimport { useState } from 'react';\r\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';\r\nimport { Button } from '@/components/ui/button';\r\nimport { Badge } from '@/components/ui/badge';\r\nimport { Progress } from '@/components/ui/progress';\r\nimport { CheckCircle, AlertCircle, Clock, Zap, Crown } from 'lucide-react';\r\nimport { useSubscription } from '@/contexts/SubscriptionContext';\r\nimport { useAuth } from '@/lib/auth';\r\nimport { format } from 'date-fns';\r\nimport { ptBR } from 'date-fns/locale';\r\n\r\nexport function SubscriptionStatus() {\r\n  const { subscription, loading, isActive, isExpired, daysUntilExpiry } = useSubscription();\r\n  const { user } = useAuth();\r\n\r\n  if (loading) {\r\n    return (\r\n      <Card>\r\n        <CardContent className=\"p-6\">\r\n          <div className=\"flex items-center justify-center\">\r\n            <div className=\"animate-spin rounded-full h-6 w-6 border-b-2 border-primary\"></div>\r\n          </div>\r\n        </CardContent>\r\n      </Card>\r\n    );\r\n  }\r\n\r\n  if (!subscription) {\r\n    return (\r\n      <Card>\r\n        <CardContent className=\"p-6\">\r\n          <div className=\"text-center space-y-4\">\r\n            <AlertCircle className=\"w-12 h-12 text-muted-foreground mx-auto\" />\r\n            <div>\r\n              <h3 className=\"font-semibold\">Sem Assinatura</h3>\r\n              <p className=\"text-sm text-muted-foreground\">\r\n                Comece com nosso plano trial de 7 dias grâ”œأ­tis\r\n              </p>\r\n            </div>\r\n            <Button onClick={() => window.location.href = '/pricing'}>\r\n              Ver Planos\r\n            </Button>\r\n          </div>\r\n        </CardContent>\r\n      </Card>\r\n    );\r\n  }\r\n\r\n  const getStatusColor = () => {\r\n    if (subscription.status === 'trial') return 'bg-blue-500';\r\n    if (isActive) return 'bg-green-500';\r\n    if (isExpired) return 'bg-red-500';\r\n    return 'bg-yellow-500';\r\n  };\r\n\r\n  const getStatusText = () => {\r\n    if (subscription.status === 'trial') return 'Trial Ativo';\r\n    if (isActive) return 'Ativo';\r\n    if (isExpired) return 'Expirado';\r\n    return 'Pendente';\r\n  };\r\n\r\n  const getStatusIcon = () => {\r\n    if (isActive) return <CheckCircle className=\"w-4 h-4\" />;\r\n    if (subscription.status === 'trial') return <Clock className=\"w-4 h-4\" />;\r\n    return <AlertCircle className=\"w-4 h-4\" />;\r\n  };\r\n\r\n  const getProgressValue = () => {\r\n    if (subscription.status === 'trial') {\r\n      return ((7 - daysUntilExpiry) / 7) * 100;\r\n    }\r\n    \r\n    const totalDays = subscription.duration_months * 30;\r\n    const daysUsed = totalDays - daysUntilExpiry;\r\n    return (daysUsed / totalDays) * 100;\r\n  };\r\n\r\n  return (\r\n    <Card>\r\n      <CardHeader>\r\n        <div className=\"flex items-center justify-between\">\r\n          <CardTitle className=\"text-lg\">Minha Assinatura</CardTitle>\r\n          <Badge variant=\"secondary\" className={`${getStatusColor()} text-white`}>\r\n            <div className=\"flex items-center gap-1\">\r\n              {getStatusIcon()}\r\n              {getStatusText()}\r\n            </div>\r\n          </Badge>\r\n        </div>\r\n      </CardHeader>\r\n      \r\n      <CardContent className=\"space-y-6\">\r\n        {/* Plano Atual */}\r\n        <div className=\"space-y-2\">\r\n          <div className=\"flex items-center justify-between\">\r\n            <span className=\"text-sm font-medium\">Plano Atual</span>\r\n            <div className=\"flex items-center gap-2\">\r\n              {subscription.subscription_plans.name === 'Anual' && <Crown className=\"w-4 h-4 text-yellow-500\" />}\r\n              <span className=\"font-semibold\">{subscription.subscription_plans.name}</span>\r\n            </div>\r\n          </div>\r\n          <div className=\"flex items-center justify-between text-sm text-muted-foreground\">\r\n            <span>Valor</span>\r\n            <span>\r\n              {subscription.subscription_plans.price === 0 \r\n                ? 'Grâ”œأ­tis' \r\n                : `R$ ${subscription.subscription_plans.price.toFixed(2)}/${subscription.subscription_plans.duration_months === 1 ? 'mâ”œآ¬s' : 'ano'}`\r\n              }\r\n            </span>\r\n          </div>\r\n        </div>\r\n\r\n        {/* Progresso do Perâ”œآ،odo */}\r\n        <div className=\"space-y-2\">\r\n          <div className=\"flex items-center justify-between text-sm\">\r\n            <span className=\"font-medium\">\r\n              {subscription.status === 'trial' ? 'Perâ”œآ،odo Trial' : 'Perâ”œآ،odo Atual'}\r\n            </span>\r\n            <span className=\"text-muted-foreground\">\r\n              {subscription.status === 'trial' \r\n                ? `${daysUntilExpiry} dias restantes`\r\n                : `Expira em ${daysUntilExpiry} dias`\r\n              }\r\n            </span>\r\n          </div>\r\n          <Progress value={getProgressValue()} className=\"h-2\" />\r\n          <div className=\"text-xs text-muted-foreground\">\r\n            Inâ”œآ،cio: {format(new Date(subscription.starts_at), \"dd/MM/yyyy\", { locale: ptBR })}\r\n            {' أ”أ‡أ³ '}\r\n            Tâ”œآ®rmino: {format(new Date(subscription.ends_at), \"dd/MM/yyyy\", { locale: ptBR })}\r\n          </div>\r\n        </div>\r\n\r\n        {/* Status do Pagamento */}\r\n        {subscription.last_payment_at && (\r\n          <div className=\"space-y-2\">\r\n            <div className=\"flex items-center justify-between text-sm\">\r\n              <span className=\"font-medium\">â”œأœltimo Pagamento</span>\r\n              <span className=\"text-muted-foreground\">\r\n                {format(new Date(subscription.last_payment_at), \"dd/MM/yyyy\", { locale: ptBR })}\r\n              </span>\r\n            </div>\r\n            {subscription.next_payment_at && (\r\n              <div className=\"flex items-center justify-between text-sm\">\r\n                <span className=\"font-medium\">Prâ”œâ”‚ximo Pagamento</span>\r\n                <span className=\"text-muted-foreground\">\r\n                  {format(new Date(subscription.next_payment_at), \"dd/MM/yyyy\", { locale: ptBR })}\r\n                </span>\r\n              </div>\r\n            )}\r\n          </div>\r\n        )}\r\n\r\n        {/* Recursos Disponâ”œآ،veis */}\r\n        <div className=\"space-y-3\">\r\n          <h4 className=\"font-medium text-sm\">Recursos Disponâ”œآ،veis</h4>\r\n          <div className=\"grid grid-cols-2 gap-3 text-sm\">\r\n            <div className=\"flex items-center gap-2\">\r\n              <Zap className=\"w-4 h-4 text-blue-500\" />\r\n              <span>API Access</span>\r\n            </div>\r\n            <div className=\"flex items-center gap-2\">\r\
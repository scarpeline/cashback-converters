ful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":9,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"// @ts-nocheck\r\nimport { useState, useEffect } from \"react\";\r\nimport { Routes, Route, Link, useLocation } from \"react-router-dom\";\r\nimport { useAuth } from \"@/lib/auth\";\r\nimport { supabase } from \"@/integrations/supabase/client\";\r\nimport { Button } from \"@/components/ui/button\";\r\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from \"@/components/ui/card\";\r\nimport { Input } from \"@/components/ui/input\";\r\nimport { Label } from \"@/components/ui/label\";\r\nimport {\r\n  LayoutDashboard,\r\n  Calendar,\r\n  DollarSign,\r\n  User,\r\n  Bell,\r\n  LogOut,\r\n  Menu,\r\n  X,\r\n  Clock,\r\n  CreditCard,\r\n  Video,\r\n  FileText,\r\n  Share2,\r\n  Plus,\r\n  QrCode,\r\n  Smartphone,\r\n  Loader2,\r\n  CheckCircle,\r\n  Lock,\r\n  Eye,\r\n  EyeOff,\r\n} from \"lucide-react\";\r\nimport logo from \"@/assets/logo.png\";\r\nimport { toast } from \"sonner\";\r\nimport { formatWhatsAppBR } from \"@/lib/input-masks\";\r\nimport { ProfilePhotoUpload } from \"@/components/shared/ProfilePhotoUpload\";\r\nimport ContaBancariaPage from \"@/components/profissional/ContaBancariaPage\";\r\nimport SolicitarServicoFiscalPage from \"@/components/shared/SolicitarServicoFiscalPage\";\r\nimport SejaAfiliadoPage from \"@/components/shared/SejaAfiliadoPage\";\r\nimport { ContadorBuscaPanel } from \"@/components/contabilidade/ContadorBuscaPanel\";\r\nimport { ChatContadorPanel } from \"@/components/contabilidade/ChatContadorPanel\";\r\nimport { PedidoContabilPanel } from \"@/components/contabilidade/PedidoContabilPanel\";\r\nimport { AssinaturaContabilPanel } from \"@/components/contabilidade/AssinaturaContabilPanel\";\r\nimport UniversalChatPanel from \"@/components/shared/UniversalChatPanel\";\r\nimport { isPaymentRequestSupported, processNfcPayment } from \"@/lib/nfc/payment\";\r\nimport { AgendaProfissional } from \"@/components/profissional/AgendaProfissional\";\r\nimport { NotificationBell } from \"@/components/notifications/NotificationBell\";\r\nimport { PostAppointmentNotificationsService } from \"@/services/notifications/PostAppointmentNotifications\";\r\nimport MarketingEmpresarial from \"@/components/marketing/MarketingEmpresarial\";\r\n\r\nconst ProfissionalDashboard = () => {\r\n  const { profile, signOut } = useAuth();\r\n  const location = useLocation();\r\n  const [sidebarOpen, setSidebarOpen] = useState(false);\r\n\r\n  // Iniciar serviâ”œآ؛o de notificaâ”œآ؛â”œأپes pâ”œâ”‚s-atendimento\r\n  useEffect(() => {\r\n    if (profile) {\r\n      PostAppointmentNotificationsService.startNotificationChecker();\r\n    }\r\n  }, [profile]);\r\n\r\n  const basePath = \"/painel-profissional\";\r\n\r\n  const navigation = [\r\n    { name: \"Dashboard\", href: basePath, icon: LayoutDashboard },\r\n    { name: \"Minha Agenda\", href: `${basePath}/agenda`, icon: Calendar },\r\n    { name: \"Meus Ganhos\", href: `${basePath}/ganhos`, icon: DollarSign },\r\n    { name: \"Receber Dâ”œآ،vida\", href: `${basePath}/receber-divida`, icon: DollarSign },\r\n    { name: \"Conta Bancâ”œأ­ria\", href: `${basePath}/conta-bancaria`, icon: CreditCard },\r\n    { name: \"Marketing Empresarial\", href: `${basePath}/marketing-empresarial`, icon: Video },\r\n    { name: \"Serviâ”œآ؛os Contâ”œأ­beis\", href: `${basePath}/servicos-contabeis`, icon: FileText },\r\n    { name: \"Seja Afiliado\", href: `${basePath}/seja-afiliado`, icon: Share2 },\r\n    { name: \"Meu Perfil\", href: `${basePath}/perfil`, icon: User },\r\n  ];\r\n\r\n  const isActive = (href: string) => {\r\n    if (href === basePath) return location.pathname === basePath || location.pathname === `${basePath}/`;\r\n    return location.pathname.startsWith(href);\r\n  };\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background flex\">\r\n      {sidebarOpen && (\r\n        <div\r\n          className=\"fixed inset-0 bg-black/50 z-40 lg:hidden\"\r\n          onClick={() => setSidebarOpen(false)}\r\n        />\r\n      )}\r\n\r\n      <aside className={`\r\n        fixed lg:static inset-y-0 left-0 z-50 w-64 bg-card border-r border-border\r\n        transform transition-transform duration-200 ease-in-out\r\n        ${sidebarOpen ? \"translate-x-0\" : \"-translate-x-full lg:translate-x-0\"}\r\n      `}>\r\n        <div className=\"flex flex-col h-full\">\r\n          <div className=\"p-4 border-b border-sidebar-border flex items-center justify-between\">\r\n            <Link to={basePath} className=\"flex items-center gap-2\">\r\n              <img src={logo} alt=\"Logo\" className=\"w-8 h-8\" />\r\n              <span className=\"font-display font-bold text-lg text-sidebar-primary\">Profissional</span>\r\n            </Link>\r\n            <button\r\n              className=\"lg:hidden text-muted-foreground\"\r\n              onClick={() => setSidebarOpen(false)}\r\n            >\r\n              <X className=\"w-5 h-5\" />\r\n            </button>\r\n          </div>\r\n          <div className=\"p-4 border-b border-sidebar-border\">\r\n            <p className=\"font-medium truncate text-sidebar-foreground\">{profile?.name || \"Profissional\"}</p>\r\n            <p className=\"text-sm text-sidebar-foreground/60 truncate\">{profile?.whatsapp || profile?.email}</p>\r\n          </div>\r\n          <nav className=\"flex-1 p-4 space-y-1 overflow-y-auto\">\r\n            {navigation.map((item) => (\r\n              <Link\r\n                key={item.name}\r\n                to={item.href}\r\n                onClick={() => setSidebarOpen(false)}\r\n                className={`\r\n                  flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium\r\n                  transition-colors\r\n                  ${isActive(item.href)\r\n                    ? \"bg-primary text-primary-foreground\"\r\n                    : \"text-muted-foreground hover:bg-muted hover:text-foreground\"}\r\n                `}\r\n              >\r\n                <item.icon className=\"w-5 h-5\" />\r\n                {item.name}\r\n              </Link>\r\n            ))}\r\n          </nav>\r\n\r\n          <div className=\"p-4 border-t border-border\">\r\n            <Button\r\n              variant=\"ghost\"\r\n              className=\"w-full justify-start gap-3 text-muted-foreground\"\r\n              onClick={signOut}\r\n            >\r\n              <LogOut className=\"w-5 h-5\" />\r\n              Sair\r\n            </Button>\r\n          </div>\r\n        </div>\r\n      </aside>\r\n      <div className=\"flex-1 flex flex-col min-w-0\">\r\n        <header className=\"h-16 border-b border-border flex items-center justify-between px-4 lg:px-6 bg-card\">\r\n          <button\r\n            className=\"lg:hidden text-foreground\"\r\n            onClick={() => setSidebarOpen(true)}\r\n          >\r\n            <Menu className=\"w-6 h-6\" />\r\n          </button>\r\n          <div className=\"flex-1 lg:flex-none\" />\r\n          <div className=\"flex items-center gap-4\">\r\n            <NotificationBell />\r\n          </div>\r\n        </header>\r\n        <main className=\"flex-1 p-4 lg:p-6 overflow-auto\">\r\n          <Routes>\r\n            <Route index element={<DashboardHome />} />\r\n            <Route path=\"agenda\" element={<AgendaPage />} />\r\n            <Route path=\"ganhos\" element={<GanhosPage />} />\r\n            <Route path=\"receber-divida\" element={<ReceberDividaProfPage />} />\r\n            <Route path=\"conta-bancaria\" element={<ContaBancariaPage />} />\r\n            <Route path=\"marketing-empresarial\" element={\r\n              <div className=\"p-6\">\r\n                <MarketingEmpresarial isOwner={false} />\r\n              </div>\r\n            } />\r\n            <Route path=\"servicos-contabeis/*\" element={<ContabeisHubProfPage />} />\r\n            <Route path=\"seja-afiliado\" element={<SejaAfiliadoPage />} />\r\n            <Route path=\"perfil\" element={<PerfilPage />} />\r\n          </Routes>\r\n        </main>\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nconst DashboardHome = () => {\r\n  const handleShare = () => {\r\n    const link = `${window.location.origin}/agendar`;\r\n    if (navigator.share) {\r\n      navigator.share({ title: \"Agende seu horâ”œأ­rio\", url: link });\r\n    } else {\r\n      navigator.clipboard?.writeText(link);\r\n      toast.success(\"Link de agendamento copiado!\");\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <div className=\"flex items-center justify-between\">\r\n        <div><h1 className=\"font-display text-2xl font-bold\">Olâ”œأ­! آ­ئ’أ¦أ¯</h1><p className=\"text-muted-foreground\">Sua agenda de hoje</p></div>\r\n        <Button variant=\"outline\" size=\"sm\" onClick={handleShare}><Share2 className=\"w-4 h-4 mr-1\" />Compartilhar Link</Button>\r\n      </div>\r\n      <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\r\n        <Card><CardHeader className=\"pb-2\"><CardDescription>Agendamentos Hoje</CardDescription><CardTitle className=\"text-2xl\">0</CardTitle></CardHeader></Card>\r\n        <Card><CardHeader className=\"pb-2\"><CardDescription>Ganhos Hoje</CardDescription><CardTitle className=\"text-2xl text-gradient-gold\">R$ 0,00</CardTitle></CardHeader></Card>\r\n        <Card><CardHeader className=\"pb-2\"><CardDescription>Prâ”œâ”‚ximo Cliente</CardDescription><CardTitle className=\"text-lg\">Nenhum</CardTitle></CardHeader></Card>\r\n      </div>\r\n      <Card><CardHeader><CardTitle>Prâ”œâ”‚ximos Atendimentos</CardTitle></CardHeader>\r\n        <CardContent className=\"text-center py-8\"><Clock className=\"w-12 h-12 text-muted-foreground mx-auto mb-4\" /><p className=\"text-muted-foreground\">Nenhum atendimento agendado para hoje.</p></CardContent>\r\n      </Card>\r\n    </div>\r\n  );\r\n};\r\n\r\n// ============ RECEBER Dâ”œأ¬VIDA - PROFISSIONAL ============\r\nconst ReceberDividaProfPage = () => {\r\n  const { user } = useAuth();\r\n  const [debts, setDebts] = useState<any[]>([]);\r\n  const [showForm, setShowForm] = useState(false);\r\n  const [saving, setSaving] = useState(false);\r\n  const [form, setForm] = useState({ client_name: \"\", client_whatsapp: \"\", amount: \"\", description: \"\" });\r\n  const [nfcLoadingId, setNfcLoadingId] = useState<string | null>(null);\r\n  const nfcSupported = isPaymentRequestSupported();\r\n\r\n  const reload = () => {\r\n    if (!user) return;\r\n    (supabase as any).from(\"debts\").select(\"*\").eq(\"professional_user_id\", user.id).order(\"created_at\", { ascending: false }).then(({ data }: any) => setDebts(data || []));\r\n  };\r\n\r\n  useEffect(() => { reload(); }, [user?.id]);\r\n\r\n  const handleCreate = async () => {\r\n    if (!form.client_name || !form.amount || !user) { toast.error(\"Preencha nome e valor.\"); return; }\r\n    setSaving(true);\r\n    const { error } = await (supabase as any).from(\"debts\").insert({\r\n      professional_user_id: user.id,\r\n      client_name: form.client_name,\r\n      client_whatsapp: form.client_whatsapp || null,\r\n      amount: Number(form.amount),\r\n      description: form.description || null,\r\n    });\r\n    setSaving(false);\r\n    if (error) { toast.error(\"Erro: \" + error.message); return; }\r\n    toast.success(\"Dâ”œآ،vida registrada!\");\r\n    setShowForm(false);\r\n    setForm({ client_name: \"\", client_whatsapp: \"\", amount: \"\", description: \"\" });\r\n    reload();\r\n  };\r\n\r\n  const handleReceivePix = async (debt: any) => {\r\n    try {\r\n      const { data, error } = await supabase.functions.invoke(\"process-payment\", {\r\n        body: { action: \"charge\", amount: Number(debt.amount), description: `Dâ”œآ،vida: ${debt.client_name}`, billing_type: \"PIX\", external_reference: debt.id },\r\n      });\r\n      if (error) throw error;\r\n      const code = data?.pix_copy_paste || data?.payment_link;\r\n      if (code) { navigator.clipboard?.writeText(code); toast.success(\"PIX copiado! Envie ao cliente.\"); }\r\n      else toast.success(\"Cobranâ”œآ؛a gerada!\");\r\n    } catch { toast.error(\"Erro ao gerar cobranâ”œآ؛a.\"); }\r\n  };\r\n\r\n  const totalPending = debts.filter(d => d.status === \"pending\").reduce((s, d) => s + Number(d.amount), 0);\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <div className=\"flex items-center justify-between flex-wrap gap-3\">\r\n        <h1 className=\"font-display text-2xl font-bold\">Receber Dâ”œآ،vida (Fiado)</h1>\r\n        <Button variant=\"gold\" onClick={() => setShowForm(!showForm)}><Plus className=\"w-4 h-4 mr-2\" />Nova Dâ”œآ،vida</Button>\r\n      </div>\r\n\r\n      <Card className=\"bg-gradient-card border-primary/20\">\r\n        <CardContent className=\"p-4 flex items-center justify-between\">\r\n          <div><p className=\"text-sm text-muted-foreground\">Total Pendente</p><p className=\"text-2xl font-bold text-gradient-gold\">R$ {totalPending.toFixed(2)}</p></div>\r\n          <Wallet className=\"w-8 h-8 text-primary\" />\r\n        </CardContent>\r\n      </Card>\r\n\r\n      {showForm && (\r\n        <Card className=\"border-primary/30\">\r\n          <CardHeader><CardTitle>Registrar Dâ”œآ،vida</CardTitle></CardHeader>\r\n          <CardContent className=\"space-y-4\">\r\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n              <div><Label>Nome do Cliente *</Label><Input placeholder=\"Nome\" value={form.client_name} onChange={e => setForm({ ...form, client_name: e.target.value })} className=\"mt-1\" /></div>\r\n              <div><Label>WhatsApp</Label><Input placeholder=\"(11) 99999-0000\" value={form.client_whatsapp} onChange={e => setForm({ ...form, client_whatsapp: formatWhatsAppBR(e.target.value) })} className=\"mt-1\" /></div>\r\n              <div><Label>Valor (R$) *</Label><Input type=\"number\" placeholder=\"50.00\" value={form.amount} onChange={e => setForm({ ...form, amount: e.target.value })} className=\"mt-1\" /></div>\r\n              <div><Label>Descriâ”œآ؛â”œأ؛o</Label><Input placeholder=\"Ex: Corte + Barba\" value={form.description} onChange={e => setForm({ ...form, description: e.target.value })} className=\"mt-1\" /></div>\r\n            </div>\r\n            <div className=\"flex gap-2\">\r\n              <Button variant=\"gold\" onClick={handleCreate} disabled={saving}>{saving ? \"Salvando...\" : \"Registrar\"}</Button>\r\n              <Button variant=\"outline\" onClick={() => setShowForm(false)}>Cancelar</Button>\r\n            </div>\r\n          </CardContent>\r\n        </Card>\r\n      )}\r\n\r\n      {debts.length === 0 ? (\r\n        <Card><CardContent className=\"py-12 text-center\"><Wallet className=\"w-12 h-12 text-muted-foreground mx-auto mb-4\" /><p className=\"text-muted-foreground\">Nenhuma dâ”œآ،vida registrada.</p></CardContent></Card>\r\n      ) : (\r\n        <div className=\"space-y-3\">\r\n          {debts.map(d => (\r\n            <Card key={d.id}><CardContent className=\"p-4\">\r\n              <div className=\"flex items-center justify-between mb-2\">\r\n                <div><p className=\"font-semibold\">{d.client_name}</p><p className=\"text-sm text-muted-foreground\">{d.description || \"Fiado\"}</p></div>\r\n                <div className=\"text-right\">\r\n                  <p className=\"font-bold text-lg\">R$ {Number(d.amount).toFixed(2)}</p>\r\n                  <span className={`text-xs px-2 py-0.5 rounded-full ${d.status === \"pending\" ? \"bg-yellow-500/10 text-yellow-600\" : \"bg-green-500/10 text-green-600\"}`}>{d.status === \"pending\" ? \"Pendente\" : \"Pago\"}</span>\r\n                </div>\r\n              </div>\r\n              {d.status === \"pending\" && (\r\n                <div className=\"flex flex-wrap gap-2 mt-3\">\r\n                  <Button size=\"sm\" variant=\"gold\" onClick={() => handleReceivePix(d)}><QrCode className=\"w-4 h-4 mr-1\" />PIX/QR</Button>\r\n                  {nfcSupported && (\r\n                    <Button size=\"sm\" variant=\"default\" className=\"bg-violet-600 hover:bg-violet-700 text-white\" disabled={nfcLoadingId === d.id}\r\n                      onClick={async () => {\r\n                        setNfcLoadingId(d.id);\r\n                        const result = await processNfcPayment({ amount: Number(d.amount), description: `Dâ”œآ،vida: ${d.client_name}` });\r\n                        setNfcLoadingId(null);\r\n                        if (result.success) {\r\n                          await (supabase as any).from(\"debts\").update({ status: \"paid\", paid_at: new Date().toISOString() }).eq(\"id\", d.id);\r\n                          toast.success(\"Pagamento NFC recebido!\"); reload();\r\n                        } else { toast.error(result.error || \"Falha no NFC\"); }\r\n                      }}\r\n                    >\r\n                      {nfcLoadingId === d.id ? <Loader2 className=\"w-4 h-4 animate-spin mr-1\" /> : <Smartphone className=\"w-4 h-4 mr-1\" />}NFC\r\n                    </Button>\r\n                  )}\r\n                  <Button size=\"sm\" variant=\"outline\" onClick={() => {\r\n                    (supabase as any).from(\"debts\").update({ status: \"paid\", paid_at: new Date().toISOString() }).eq(\"id\", d.id).then(() => { toast.success(\"Marcado como pago!\"); reload(); });\r\n                  }}><CheckCircle className=\"w-4 h-4 mr-1\" />Pago</Button>\r\n                </div>\r\n              )}\r\n            </CardContent></Card>\r\n          ))}\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n};\r\n\r\nconst TABS_PROF_CONT = [\r\n  { key: \"solicitar\", label: \"Solicitar Serviâ”œآ؛o\", icon: \"آ­ئ’أ´أ¯\" },\r\n  { key: \"buscar\", label: \"Buscar Contador\", icon: \"آ­ئ’أ¶أ¬\" },\r\n  { key: \"pedidos\", label: \"Pedidos Antecipados\", icon: \"آ­ئ’أ¸أ†\" },\r\n  { key: \"assinatura\", label: \"Assinatura Mensal\", icon: \"آ­ئ’أ¶أ¤\" },\r\n  { key: \"chat\", label: \"Chat Contador\", icon: \"آ­ئ’أ†آ¼\" },\r\n];\r\n\r\nconst ContabeisHubProfPage = () => {\r\n  const { user } = useAuth();\r\n  const [tab, setTab] = useState(\"solicitar\");\r\n  const [chatContadorId, setChatContadorId] = useState<string | null>(null);\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <h1 className=\"font-display text-2xl font-bold flex items-center gap-2\">\r\n        <FileText className=\"w-6 h-6\" /> Serviâ”œآ؛os Contâ”œأ­beis\r\n      </h1>\r\n      <div className=\"flex flex-wrap gap-2 border-b border-border pb-2\">\r\n        {TABS_PROF_CONT.map(t => (\r\n          <Button key={t.key} variant={tab === t.key ? \"gold\" : \"outline\"} size=\"sm\" onClick={() => setTab(t.key)}>\r\n            <span className=\"mr-1\">{t.icon}</span>{t.label}\r\n          </Button>\r\n        ))}\r\n      </div>\r\n      {tab === \"solicitar\" && <SolicitarServicoFiscalPage />}\r\n      {tab === \"buscar\" && <ContadorBuscaPanel onAbrirChat={(cid) => { setChatContadorId(cid); setTab(\"chat\"); }} />}\r\n      {tab === \"pedidos\" && <PedidoContabilPanel />}\r\n      {tab === \"assinatura\" && <AssinaturaContabilPanel />}\r\n      {tab === \"chat\" && chatContadorId && user && <UniversalChatPanel mode=\"usuario\" contadorId={chatContadorId} userType=\"profissional\" />}\r\n      {tab === \"chat\" && !chatContadorId && (\r\n        <div className=\"text-center py-12\">\r\n          <p className=\"text-muted-foreground\">Busque um contador e clique em Chat.</p>\r\n          <Button variant=\"outline\" className=\"mt-4\" onClick={() => setTab(\"buscar\")}>آ­ئ’أ¶أ¬ Buscar Contador</Button>\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n};\r\n\r\nconst AgendaPage = () => {\r\n  const { user } = useAuth();\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <AgendaProfissional />\r\n    </div>\r\n  );\r\n};\r\n\r\nconst GanhosPage = () => (\r\n  <div className=\"space-y-6\">\r\n    <h1 className=\"font-display text-2xl font-bold\">Meus Ganhos</h1>\r\n\r\n    <Card className=\"bg-gradient-card border-primary/20\">\r\n      <CardHeader>\r\n        <CardDescription>Ganhos do Mâ”œآ¬s</CardDescription>\r\n        <CardTitle className=\"text-3xl text-gradient-gold\">R$ 0,00</CardTitle>\r\n      </CardHeader>\r\n    </Card>\r\n\r\n    <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n      <Card>\r\n        <CardHeader>\r\n          <CardDescription>A Receber</CardDescription>\r\n          <CardTitle className=\"text-xl\">R$ 0,00</CardTitle>\r\n          <p className=\"text-[10px] text-muted-foreground mt-1\">Taxas integradas (Gateway + App) jâ”œأ­ descontadas.</p>\r\n        </CardHeader>\r\n      </Card>\r\n      <Card>\r\n        <CardHeader>\r\n          <CardDescription>Atendimentos do Mâ”œآ¬s</CardDescription>\r\n          <CardTitle className=\"text-xl\">0</CardTitle>\r\n        </CardHeader>\r\n      </Card>\r\n    </div>\r\n  </div>\r\n);\r\n\r\n// ContaBancariaPage is now imported from @/components/profissional/ContaBancariaPage\r\nconst PerfilPage = () => {\r\n  const { user, profile } = useAuth();\r\n  const [editing, setEditing] = useState(false);\r\n  const [saving, setSaving] = useState(false);\r\n  const [avatarUrl, setAvatarUrl] = useState<string | null>(null);\r\n  const [form, setForm] = useState({ name: \"\", whatsapp: \"\", pix_key: \"\" });\r\n  const [changingPw, setChangingPw] = useState(false);\r\n  const [savingPw, setSavingPw] = useState(false);\r\n  const [showPw, setShowPw] = useState(false);\r\n  const [pwForm, setPwForm] = useState({ newPassword: \"\", confirmPassword: \"\" });\r\n\r\n  const startEdit = () => {\r\n    setForm({\r\n      name: profile?.name || \"\",\r\n      whatsapp: profile?.whatsapp || \"\",\r\n      pix_key: profile?.pix_key || \"\",\r\n    });\r\n    setEditing(true);\r\n  };\r\n\r\n  const saveProfile = async () => {\r\n    if (!user) return;\r\n    setSaving(true);\r\n    const { error } = await (supabase as any).from(\"profiles\").update({\r\n      name: form.name,\r\n      whatsapp: form.whatsapp,\r\n      pix_key: form.pix_key,\r\n    }).eq(\"user_id\", user.id);\r\n    setSaving(false);\r\n    if (error) { toast.error(\"Erro ao salvar perfil\"); return; }\r\n    toast.success(\"Perfil atualizado!\");\r\n    setEditing(false);\r\n  };\r\n\r\n  const changePassword = async () => {\r\n    if (pwForm.newPassword.length < 6) { toast.error(\"Senha deve ter no mâ”œآ،nimo 6 caracteres\"); return; }\r\n    if (pwForm.newPassword !== pwForm.confirmPassword) { toast.error(\"Senhas nâ”œأ؛o conferem\"); return; }\r\n    setSavingPw(true);\r\n    const { error } = await supabase.auth.updateUser({ password: pwForm.newPassword });\r\n    setSavingPw(false);\r\n    if (error) { toast.error(\"Erro ao alterar senha\"); return; }\r\n    toast.success(\"Senha alterada com sucesso!\");\r\n    setChangingPw(false);\r\n    setPwForm({ newPassword: \"\", confirmPassword: \"\" });\r\n  };\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <h1 className=\"font-display text-2xl font-bold\">Meu Perfil</h1>\r\n      <Card>\r\n        <CardContent className=\"pt-6 space-y-4\">\r\n          <div className=\"flex items-center gap-4 mb-4\">\r\n            {user && <ProfilePhotoUpload userId={user.id} avatarUrl={avatarUrl ?? profile?.avatar_url ?? null} onUpdate={setAvatarUrl} size=\"lg\" />}\r\n            <div><p className=\"font-bold\">{profile?.name || \"Profissional\"}</p><p className=\"text-xs text-muted-foreground\">Clique na foto para alterar</p></div>\r\n          </div>\r\n          {editing ? (\r\n            <>\r\n              <div><Label>Nome</Label><Input value={form.name} onChange={e => setForm({ ...form, name: e.target.value })} className=\"mt-1\" /></div>\r\n              <div><Label>WhatsApp</Label><Input value={form.whatsapp} onChange={e => setForm({ ...form, whatsapp: formatWhatsAppBR(e.target.value) })} className=\"mt-1\" /></div>\r\n              <div><Label>Chave PIX</Label><Input value={form.pix_key} onChange={e => setForm({ ...form, pix_key: e.target.value })} className=\"mt-1\" /></div>\r\n              <div className=\"flex gap-2\"><Button variant=\"gold\" onClick={saveProfile} disabled={saving}>{saving ? \"Salvando...\" : \"Salvar\"}</Button><Button variant=\"outline\" onClick={() => setEditing(false)}>Cancelar</Button></div>\r\n            </>\r\n          ) : (\r\n            <>\r\n              <div className=\"grid gap-3\">\r\n                <div className=\"p-3 bg-muted rounded-lg\"><label className=\"text-xs text-muted-foreground\">Nome</label><p className=\"font-medium\">{profile?.name || \"-\"}</p></div>\r\n                <div className=\"p-3 bg-muted rounded-lg\"><label className=\"text-xs text-muted-foreground\">WhatsApp</label><p className=\"font-medium\">{profile?.whatsapp || \"-\"}</p></div>\r\n                <div className=\"p-3 bg-muted rounded-lg\"><label className=\"text-xs text-muted-foreground\">E-mail</label><p className=\"font-medium\">{profile?.email || \"-\"}</p></div>\r\n                <div className=\"p-3 bg-muted rounded-lg\"><label className=\"text-xs text-muted-foreground\">Chave PIX</label><p className=\"font-medium\">{profile?.pix_key || \"Nâ”œأ؛o configurada\"}</p></div>\r\n              </div>\r\n              <Button variant=\"gold\" className=\"w-full\" onClick={startEdit}>Editar Perfil</Button>\r\n            </>\r\n          )}\r\n        </CardContent>\r\n      </Card>\r\n\r\n      <Card>\r\n        <CardHeader><CardTitle><Lock className=\"w-5 h-5 inline mr-2\" />Alterar Senha</CardTitle></CardHeader>\r\n        <CardContent className=\"space-y-3\">\r\n          {changingPw ? (\r\n            <>\r\n              <div className=\"relative\">\r\n                <Label>Nova Senha</Label>\r\n                <Input type={showPw ? \"text\" : \"password\"} value={pwForm.newPassword} onChange={e => setPwForm({ ...pwForm, newPassword: e.target.value })} className=\"mt-1 pr-10\" placeholder=\"Mâ”œآ،nimo 6 caracteres\" />\r\n                <button type=\"button\" className=\"absolute right-3 top-8 text-muted-foreground\" onClick={() => setShowPw(!showPw)}>{showPw ? <EyeOff className=\"w-4 h-4\" /> : <Eye className=\"w-4 h-4\" />}</button>\r\n              </div>\r\n              <div><Label>Confirmar Senha</Label><Input type=\"password\" value={pwForm.confirmPassword} onChange={e => setPwForm({ ...pwForm, confirmPassword: e.target.value })} className=\"mt-1\" /></div>\r\n              <div className=\"flex gap-2\"><Button variant=\"gold\" onClick={changePassword} disabled={savingPw}>{savingPw ? \"Salvando...\" : \"Alterar Senha\"}</Button><Button variant=\"outline\" onClick={() => setChangingPw(false)}>Cancelar</Button></div>\r\n            </>\r\n          ) : (\r\n            <Button variant=\"outline\" className=\"w-full\" onClick={() => setChangingPw(true)}><Lock className=\"w-4 h-4 mr-2\" />Alterar Senha</Button>\r\n          )}\r\n        </CardContent>\r\n      </Card>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default ProfissionalDashboard;\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\pages\\dashboards\\SuperAdminDashboard.tsx","messages":[{"ruleId":"@typescript-eslint/ban-ts-comment","severity":2,"message":"Do not use \"@ts-nocheck\" because it alters compilation errors.","line":1,"column":1,"nodeType":"Line","messageId":"tsDirectiveComment","endLine":1,"endColumn":15},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":355,"column":20,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":355,"endColumn":23,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[12176,12179],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"
, description: e.target.value })}\r\n                  className=\"mt-1\"\r\n                />\r\n              </div>\r\n\r\n              <div>\r\n                <label htmlFor=\"phone\" className=\"text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70\">Telefone/WhatsApp</label>\r\n                <Input\r\n                  id=\"phone\"\r\n                  placeholder=\"(00) 00000-0000\"\r\n                  value={form.phone}\r\n                  onChange={(e) => setForm({ ...form, phone: formatWhatsAppBR(e.target.value) })}\r\n                  className=\"mt-1\"\r\n                />\r\n              </div>\r\n\r\n              <Button\r\n                variant=\"gold\"\r\n                className=\"w-full\"\r\n                onClick={() => {\r\n                  if (!form.name || form.name.length < 2) {\r\n                    setErrors({ name: \"Nome â”œآ® obrigatâ”œâ”‚rio\" });\r\n                    return;\r\n                  }\r\n                  setErrors({});\r\n                  setStep(2);\r\n                }}\r\n              >\r\n                Prâ”œâ”‚ximo\r\n              </Button>\r\n            </CardContent>\r\n          </Card>\r\n        )}\r\n\r\n        {step === 2 && (\r\n          <Card>\r\n            <CardHeader>\r\n              <div className=\"w-10 h-10 rounded-lg bg-secondary/10 flex items-center justify-center mb-2\">\r\n                <MapPin className=\"w-5 h-5 text-secondary\" />\r\n              </div>\r\n              <CardTitle>Endereâ”œآ؛o e Documentos</CardTitle>\r\n              <CardDescription>Informaâ”œآ؛â”œأپes fiscais e localizaâ”œآ؛â”œأ؛o</CardDescription>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-4\">\r\n              <div>\r\n                <label htmlFor=\"address\" className=\"text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70\">Endereâ”œآ؛o Completo *</label>\r\n                <Input\r\n 
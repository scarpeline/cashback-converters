ard>\r\n            <CardHeader className=\"pb-2\">\r\n              <CardTitle className=\"text-sm font-medium text-muted-foreground flex items-center gap-2\">\r\n                <TrendingUp className=\"w-4 h-4\" />\r\n                Total\r\n              </CardTitle>\r\n            </CardHeader>\r\n            <CardContent>\r\n              <div className=\"text-2xl font-bold\">{formatCurrency(stats.total)}</div>\r\n              <p className=\"text-xs text-muted-foreground mt-1\">\r\n                Todas as comissâ”œأپes\r\n              </p>\r\n            </CardContent>\r\n          </Card>\r\n        </div>\r\n      )}\r\n\r\n      {/* Management Panel */}\r\n      <CommissionManagementPanel />\r\n\r\n      {/* Info */}\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle className=\"text-sm\">Como funciona</CardTitle>\r\n          <CardDescription>\r\n            Fluxo de comissâ”œأپes\r\n          </CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-3 text-sm\">\r\n          <div className=\"flex gap-3\">\r\n            <div className=\"w-6 h-6 rounded-full bg-yellow-500/10 text-yellow-700 flex items-center justify-center font-bold text-xs\">1</div>\r\n            <div>\r\n              <p className=\"font-medium\">Pendente</p>\r\n              <p className=\"text-muted-foreground\">Comissâ”œأ؛o â”œآ® gerada automaticamente quando um pagamento â”œآ® confirmado</p>\r\n            </div>\r\n          </div>\r\n          <div className=\"flex gap-3\">\r\n            <div className=\"w-6 h-6 rounded-full bg-blue-500/10 text-blue-700 flex items-center justify-center font-bold text-xs\">2</div>\r\n            <div>\r\n              <p className=\"font-medium\">Aprovada</p>\r\n              <p className=\"text-muted-foreground\">Admin aprova a comissâ”œأ؛o apâ”œâ”‚s validaâ”œآ؛â”œأ؛o</p>\r\n            </div>\r\n          </div>\r\n          <div className=\"flex gap-3\">\r\n            <div className=\"w-6 h-6 round
."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":640,"column":62,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":640,"endColumn":65,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[20333,20336],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[20333,20336],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":706,"column":71,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":706,"endColumn":74,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[22499,22502],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[22499,22502],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":765,"column":26,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":765,"endColumn":29,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[24033,24036],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[24033,24036],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":771,"column":26,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":771,"endColumn":29,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[24219,24222],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[24219,24222],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":777,"column":26,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":777,"endColumn":29,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[24400,24403],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[24400,24403],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":783,"column":26,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":783,"endColumn":29,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[24585,24588],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[24585,24588],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":12,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"// @ts-nocheck\r\n/**\r\n * WaitlistTests - Testes Automatizados para Sistema de Fila Inteligente\r\n * \r\n * Testa todos os cenâ”œأ­rios crâ”œآ،ticos:\r\n * - Entrada na fila\r\n * - Liberaâ”œآ؛â”œأ؛o de vagas\r\n * - Antecipaâ”œآ؛â”œأ؛o automâ”œأ­tica\r\n * - Preâ”œآ؛o dinâ”œأ³mico\r\n * - Notificaâ”œآ؛â”œأپes\r\n * - Permissâ”œأپes\r\n */\r\n\r\nimport { waitlistManager, type WaitlistPreferences } from \"./WaitlistManager\";\r\nimport { anticipationManager } from \"../anticipation/AnticipationManager\";\r\nimport { waitlistNotifications } from \"../notifications/WaitlistNotifications\";\r\nimport { supabase } from \"@/integrations/supabase/client\";\r\n\r\nexport interface TestResult {\r\n  testName: string;\r\n  passed: boolean;\r\n  error?: string;\r\n  details?: any;\r\n  duration: number;\r\n}\r\n\r\nexport interface TestSuite {\r\n  name: string;\r\n  tests: TestResult[];\r\n  passed: number;\r\n  failed: number;\r\n  totalDuration: number;\r\n}\r\n\r\nclass WaitlistTests {\r\n  /**\r\n   * Executa todos os testes do sistema\r\n   */\r\n  async runAllTests(barbershopId: string): Promise<TestSuite[]> {\r\n    console.log(\"[TESTS] Iniciando testes do sistema de fila inteligente...\");\r\n    \r\n    const testSuites: TestSuite[] = [];\r\n    \r\n    // Suite 1: Testes de Fila de Espera\r\n    testSuites.push(await this.testWaitlistQueue(barbershopId));\r\n    \r\n    // Suite 2: Testes de Antecipaâ”œآ؛â”œأ؛o\r\n    testSuites.push(await this.testAnticipationSystem(barbershopId));\r\n    \r\n    // Suite 3: Testes de Preâ”œآ؛o Dinâ”œأ³mico\r\n    testSuites.push(await this.testDynamicPricing(barbershopId));\r\n    \r\n    // Suite 4: Testes de Notificaâ”œآ؛â”œأپes\r\n    testSuites.push(await this.testNotificationSystem(barbershopId));\r\n    \r\n    // Suite 5: Testes de Permissâ”œأپes\r\n    testSuites.push(await this.testPermissionSystem(barbershopId));\r\n    \r\n    // Suite 6: Testes de Integraâ”œآ؛â”œأ؛o\r\n    testSuites.push(await this.testIntegrationScenarios(barbershopId));\r\n    \r\n    console.log(\"[TESTS] Todos os testes concluâ”œآ،dos!\");\r\n    \r\n    return testSuites;\r\n  }\r\n\r\n  /**\r\n   * Testes de Fila de Espera\r\n   */\r\n  private async testWaitlistQueue(barbershopId: string): Promise<TestSuite> {\r\n    const tests: TestResult[] = [];\r\n    \r\n    // Test 1: Cliente entra na fila com preferâ”œآ¬ncia especâ”œآ،fica\r\n    tests.push(await this.runTest(\r\n      \"Cliente entra na fila - Apenas profissional especâ”œآ،fico\",\r\n      async () => {\r\n        const testClientId = \"test-client-1\";\r\n        const testServiceId = \"test-service-1\";\r\n        const testProfessionalId = \"test-professional-1\";\r\n        \r\n        const preferences: WaitlistPreferences = {\r\n          professional_preferred_id: testProfessionalId,\r\n          accepts_other_professional: false,\r\n          accepts_nearby_time: false,\r\n          accepts_any_time: false,\r\n          notes: \"Teste - apenas profissional especâ”œآ،fico\",\r\n        };\r\n        \r\n        const result = await waitlistManager.addToWaitlist(\r\n          barbershopId,\r\n          testClientId,\r\n          testServiceId,\r\n          \"2024-12-20\",\r\n          \"14:00\",\r\n          preferences\r\n        );\r\n        \r\n        if (!result.success) {\r\n          throw new Error(`Falha ao entrar na fila: ${result.error}`);\r\n        }\r\n        \r\n        // Verificar se foi criado corretamente\r\n        const { data: waitlist } = await (supabase as any)\r\n          .from(\"waitlist_queue\")\r\n          .select(\"*\")\r\n          .eq(\"id\", result.waitlistId)\r\n          .single();\r\n        \r\n        if (!waitlist || waitlist.status !== \"waiting\") {\r\n          throw new Error(\"Entrada na fila nâ”œأ؛o foi criada corretamente\");\r\n        }\r\n        \r\n        if (waitlist.accepts_other_professional !== false) {\r\n          throw new Error(\"Preferâ”œآ¬ncia de profissional nâ”œأ؛o foi salva corretamente\");\r\n        }\r\n        \r\n        return { waitlistId: result.waitlistId };\r\n      }\r\n    ));\r\n    \r\n    // Test 2: Cliente aceita qualquer profissional\r\n    tests.push(await this.runTest(\r\n      \"Cliente entra na fila - Aceita qualquer profissional\",\r\n      async () => {\r\n        const testClientId = \"test-client-2\";\r\n        const testServiceId = \"test-service-1\";\r\n        \r\n        const preferences: WaitlistPreferences = {\r\n          professional_preferred_id: null,\r\n          accepts_other_professional: true,\r\n          accepts_nearby_time: true,\r\n          accepts_any_time: true,\r\n          notes: \"Teste - aceita qualquer profissional\",\r\n        };\r\n        \r\n        const result = await waitlistManager.addToWaitlist(\r\n          barbershopId,\r\n          testClientId,\r\n          testServiceId,\r\n          \"2024-12-20\",\r\n          \"15:00\",\r\n          preferences\r\n        );\r\n        \r\n        if (!result.success) {\r\n          throw new Error(`Falha ao entrar na fila: ${result.error}`);\r\n        }\r\n        \r\n        // Verificar se foi criado corretamente\r\n        const { data: waitlist } = await (supabase as any)\r\n          .from(\"waitlist_queue\")\r\n          .select(\"*\")\r\n          .eq(\"id\", result.waitlistId)\r\n          .single();\r\n        \r\n        if (!waitlist || waitlist.accepts_other_professional !== true) {\r\n          throw new Error(\"Preferâ”œآ¬ncia de aceitar outros profissionais nâ”œأ؛o foi salva\");\r\n        }\r\n        \r\n        return { waitlistId: result.waitlistId };\r\n      }\r\n    ));\r\n    \r\n    // Test 3: Processamento de liberaâ”œآ؛â”œأ؛o de vaga\r\n    tests.push(await this.runTest(\r\n      \"Processamento de liberaâ”œآ؛â”œأ؛o de vaga\",\r\n      async () => {\r\n        // Simular liberaâ”œآ؛â”œأ؛o de vaga\r\n        const result = await waitlistManager.processSlotRelease(\r\n          barbershopId,\r\n          \"2024-12-20\",\r\n          \"14:00\",\r\n          \"test-professional-1\",\r\n          \"test-service-1\"\r\n        );\r\n        \r\n        if (!result.processed) {\r\n          throw new Error(\"Liberaâ”œآ؛â”œأ؛o de vaga nâ”œأ؛o foi processada\");\r\n        }\r\n        \r\n        return { processed: true, nextClientId: result.nextClientId };\r\n      }\r\n    ));\r\n    \r\n    // Test 4: Processamento de resposta do cliente\r\n    tests.push(await this.runTest(\r\n      \"Processamento de resposta - Aceite\",\r\n      async () => {\r\n        // Criar uma oferta simulada\r\n        const { data: waitlist } = await (supabase as any)\r\n          .from(\"waitlist_queue\")\r\n          .select(\"id\")\r\n          .eq(\"status\", \"offered\")\r\n          .limit(1)\r\n          .single();\r\n        \r\n        if (!waitlist) {\r\n          throw new Error(\"Nenhuma oferta encontrada para testar\");\r\n        }\r\n        \r\n        const result = await waitlistManager.processOfferResponse(\r\n          waitlist.id,\r\n          \"accepted\"\r\n        );\r\n        \r\n        if (!result.success) {\r\n          throw new Error(`Falha ao processar resposta: ${result.error}`);\r\n        }\r\n        \r\n        return { waitlistId: waitlist.id, response: \"accepted\" };\r\n      }\r\n    ));\r\n    \r\n    // Test 5: Cliente tenta entrar duplicado na fila\r\n    tests.push(await this.runTest(\r\n      \"Cliente duplicado na fila - Deve falhar\",\r\n      async () => {\r\n        const testClientId = \"test-client-duplicate\";\r\n        const testServiceId = \"test-service-1\";\r\n        \r\n        const preferences: WaitlistPreferences = {\r\n          professional_preferred_id: null,\r\n          accepts_other_professional: true,\r\n          accepts_nearby_time: false,\r\n          accepts_any_time: false,\r\n        };\r\n        \r\n        // Primeira entrada\r\n        const result1 = await waitlistManager.addToWaitlist(\r\n          barbershopId,\r\n          testClientId,\r\n          testServiceId,\r\n          \"2024-12-20\",\r\n          \"16:00\",\r\n          preferences\r\n        );\r\n        \r\n        if (!result1.success) {\r\n          throw new Error(\"Primeira entrada deveria funcionar\");\r\n        }\r\n        \r\n        // Segunda entrada (deve falhar)\r\n        const result2 = await waitlistManager.addToWaitlist(\r\n          barbershopId,\r\n          testClientId,\r\n          testServiceId,\r\n          \"2024-12-20\",\r\n          \"17:00\",\r\n          preferences\r\n        );\r\n        \r\n        if (result2.success) {\r\n          throw new Error(\"Segunda entrada deveria falhar\");\r\n        }\r\n        \r\n        return { firstEntry: result1.waitlistId, secondEntryFailed: true };\r\n      }\r\n    ));\r\n    \r\n    return this.createTestSuite(\"Fila de Espera\", tests);\r\n  }\r\n\r\n  /**\r\n   * Testes de Antecipaâ”œآ؛â”œأ؛o\r\n   */\r\n  private async testAnticipationSystem(barbershopId: string): Promise<TestSuite> {\r\n    const tests: TestResult[] = [];\r\n    \r\n    // Test 1: Busca oportunidades de antecipaâ”œآ؛â”œأ؛o\r\n    tests.push(await this.runTest(\r\n      \"Busca oportunidades de antecipaâ”œآ؛â”œأ؛o\",\r\n      async () => {\r\n        const opportunities = await anticipationManager.findAnticipationOpportunities(\r\n          barbershopId,\r\n          \"test-client-anticipation\",\r\n          4 // 4 horas de janela\r\n        );\r\n        \r\n        if (!Array.isArray(opportunities)) {\r\n          throw new Error(\"Resultado deveria ser um array\");\r\n        }\r\n        \r\n        return { opportunities, count: opportunities.length };\r\n      }\r\n    ));\r\n    \r\n    // Test 2: Envio de oferta de antecipaâ”œآ؛â”œأ؛o\r\n    tests.push(await this.runTest(\r\n      \"Envio de oferta de antecipaâ”œآ؛â”œأ؛o\",\r\n      async () => {\r\n        const opportunity = {\r\n          appointmentId: \"test-appointment-1\",\r\n          clientId: \"test-client-anticipation\",\r\n          currentScheduledAt: \"2024-12-20T19:00:00Z\",\r\n          earlierSlot: {\r\n            date: \"2024-12-20\",\r\n            time: \"17:30\",\r\n            professionalId: \"test-professional-1\",\r\n            serviceId: \"test-service-1\",\r\n          },\r\n          timeDifference: 90, // 90 minutos\r\n        };\r\n        \r\n        const result = await anticipationManager.sendAnticipationOffer(opportunity);\r\n        \r\n        if (!result.success) {\r\n          throw new Error(`Falha ao enviar oferta: ${result.error}`);\r\n        }\r\n        \r\n        return { offerId: result.offerId };\r\n      }\r\n    ));\r\n    \r\n    // Test 3: Processamento de aceite de antecipaâ”œآ؛â”œأ؛o\r\n    tests.push(await this.runTest(\r\n      \"Processamento de aceite de antecipaâ”œآ؛â”œأ؛o\",\r\n      async () => {\r\n        // Buscar oferta pendente\r\n        const { data: offer } = await (supabase as any)\r\n          .from(\"anticipation_offers\")\r\n          .select(\"id\")\r\n          .eq(\"status\", \"pending\")\r\n          .limit(1)\r\n          .single();\r\n        \r\n        if (!offer) {\r\n          throw new Error(\"Nenhuma oferta de antecipaâ”œآ؛â”œأ؛o encontrada\");\r\n        }\r\n        \r\n        const result = await anticipationManager.processAnticipationResponse(\r\n          offer.id,\r\n          \"accepted\"\r\n        );\r\n        \r\n        if (!result.success) {\r\n          throw new Error(`Falha ao processar aceite: ${result.error}`);\r\n        }\r\n        \r\n        return { offerId: offer.id, response: \"accepted\" };\r\n      }\r\n    ));\r\n    \r\n    return this.createTestSuite(\"Antecipaâ”œآ؛â”œأ؛o Automâ”œأ­tica\", tests);\r\n  }\r\n\r\n  /**\r\n   * Testes de Preâ”œآ؛o Dinâ”œأ³mico\r\n   */\r\n  private async testDynamicPricing(barbershopId: string): Promise<TestSuite> {\r\n    const tests: TestResult[] = [];\r\n    \r\n    // Test 1: Câ”œأ­lculo de preâ”œآ؛o dinâ”œأ³mico - horâ”œأ­rio normal\r\n    tests.push(await this.runTest(\r\n      \"Câ”œأ­lculo de preâ”œآ؛o dinâ”œأ³mico - Horâ”œأ­rio normal\",\r\n      async () => {\r\n        const result = await waitlistManager.calculateDynamicPrice(\r\n          barbershopId,\r\n          \"test-service-1\",\r\n          \"2024-12-18\", // Quarta-feira\r\n          \"10:00\", // Manhâ”œأ؛\r\n          50 // Preâ”œآ؛o base R$ 50\r\n        );\r\n        \r\n        if (result.finalPrice !== 50) {\r\n          throw new Error(`Preâ”œآ؛o deveria ser R$ 50, mas foi R$ ${result.finalPrice}`);\r\n        }\r\n        \r\n        return { basePrice: 50, finalPrice: result.finalPrice, adjustment: result.adjustment };\r\n      }\r\n    ));\r\n    \r\n    // Test 2: Câ”œأ­lculo de preâ”œآ؛o dinâ”œأ³mico - horâ”œأ­rio de pico\r\n    tests.push(await this.runTest(\r\n      \"Câ”œأ­lculo de preâ”œآ؛o dinâ”œأ³mico - Horâ”œأ­rio de pico\",\r\n      async () => {\r\n        // Criar regra de preâ”œآ؛o dinâ”œأ³mico para sexta â”œأ، noite\r\n        await waitlistManager.saveDynamicPricingRule({\r\n          barbershop_id: barbershopId,\r\n          service_id: null, // Aplica a todos os serviâ”œآ؛os\r\n          day_of_week: 5, // Sexta-feira\r\n          start_time: \"18:00\",\r\n          end_time: \"22:00\",\r\n          price_type: \"percentage\",\r\n          price_adjustment: 20, // +20%\r\n          is_active: true,\r\n          min_capacity_threshold: 80,\r\n          description: \"Teste - horâ”œأ­rio de pico\",\r\n        });\r\n        \r\n        const result = await waitlistManager.calculateDynamicPrice(\r\n          barbershopId,\r\n          \"test-service-1\",\r\n          \"2024-12-20\", // Sexta-feira\r\n          \"20:00\", // Noite (horâ”œأ­rio de pico)\r\n          50 // Preâ”œآ؛o base R$ 50\r\n        );\r\n        \r\n        const expectedPrice = 50 * 1.2; // R$ 60\r\n        if (Math.abs(result.finalPrice - expectedPrice) > 0.01) {\r\n          throw new Error(`Preâ”œآ؛o deveria ser R$ ${expectedPrice}, mas foi R$ ${result.finalPrice}`);\r\n        }\r\n        \r\n        return { basePrice: 50, finalPrice: result.finalPrice, adjustment: result.adjustment };\r\n      }\r\n    ));\r\n    \r\n    // Test 3: Preâ”œآ؛o dinâ”œأ³mico desativado\r\n    tests.push(await this.runTest(\r\n      \"Preâ”œآ؛o dinâ”œأ³mico desativado\",\r\n      async () => {\r\n        // Desativar preâ”œآ؛o dinâ”œأ³mico\r\n        await waitlistManager.updateAgendaSettings(barbershopId, {\r\n          enable_dynamic_pricing: false,\r\n        });\r\n        \r\n        const result = await waitlistManager.calculateDynamicPrice(\r\n          barbershopId,\r\n          \"test-service-1\",\r\n          \"2024-12-20\",\r\n          \"20:00\",\r\n          50\r\n        );\r\n        \r\n        if (result.finalPrice !== 50) {\r\n          throw new Error(\"Preâ”œآ؛o dinâ”œأ³mico desativado deveria manter preâ”œآ؛o base\");\r\n        }\r\n        \r\n        return { basePrice: 50, finalPrice: result.finalPrice };\r\n      }\r\n    ));\r\n    \r\n    return this.createTestSuite(\"Preâ”œآ؛o Dinâ”œأ³mico\", tests);\r\n  }\r\n\r\n  /**\r\n   * Testes de Notificaâ”œآ؛â”œأپes\r\n   */\r\n  private async testNotificationSystem(barbershopId: string): Promise<TestSuite> {\r\n    const tests: TestResult[] = [];\r\n    \r\n    // Test 1: Envio de notificaâ”œآ؛â”œأ؛o de oferta\r\n    tests.push(await this.runTest(\r\n      \"Envio de notificaâ”œآ؛â”œأ؛o de oferta\",\r\n      async () => {\r\n        const result = await waitlistNotifications.sendSlotOfferNotification(\r\n          \"test-waitlist-1\",\r\n          \"test-client-notification\",\r\n          \"2024-12-20\",\r\n          \"14:00\",\r\n          \"Profissional Teste\",\r\n          \"Corte Masculino\",\r\n          10\r\n        );\r\n        \r\n        if (!result.success) {\r\n          throw new Error(`Falha ao enviar notificaâ”œآ؛â”œأ؛o: ${result.error}`);\r\n        }\r\n        \r\n        return { notificationId: result.notificationId };\r\n      }\r\n    ));\r\n    \r\n    // Test 2: Envio de notificaâ”œآ؛â”œأ؛o de antecipaâ”œآ؛â”œأ؛o\r\n    tests.push(await this.runTest(\r\n      \"Envio de notificaâ”œآ؛â”œأ؛o de antecipaâ”œآ؛â”œأ؛o\",\r\n      async () => {\r\n        const result = await waitlistNotifications.sendAnticipationNotification(\r\n          \"test-appointment-1\",\r\n          \"test-client-notification\",\r\n          \"2024-12-20T19:00:00Z\",\r\n          \"2024-12-20T17:30:00Z\",\r\n          90,\r\n          \"Corte Masculino\",\r\n          10\r\n        );\r\n        \r\n        if (!result.success) {\r\n          throw new Error(`Falha ao enviar notificaâ”œآ؛â”œأ؛o: ${result.error}`);\r\n        }\r\n        \r\n        return { notificationId: result.notificationId };\r\n      }\r\n    ));\r\n    \r\n    // Test 3: Processamento de resposta de notificaâ”œآ؛â”œأ؛o\r\n    tests.push(await this.runTest(\r\n      \"Processamento de resposta de notificaâ”œآ؛â”œأ؛o\",\r\n      async () => {\r\n        const result = await waitlistNotifications.processNotificationResponse(\r\n          \"test-notification-1\",\r\n          \"accept_offer\",\r\n          { waitlistId: \"test-waitlist-1\" }\r\n        );\r\n        \r\n        if (!result.success) {\r\n          throw new Error(`Falha ao processar resposta: ${result.error}`);\r\n        }\r\n        \r\n        return { action: \"accept_offer\", processed: true };\r\n      }\r\n    ));\r\n    \r\n    return this.createTestSuite(\"Sistema de Notificaâ”œآ؛â”œأپes\", tests);\r\n  }\r\n\r\n  /**\r\n   * Testes de Permissâ”œأپes\r\n   */\r\n  private async testPermissionSystem(barbershopId: string): Promise<TestSuite> {\r\n    const tests: TestResult[] = [];\r\n    \r\n    // Test 1: Configuraâ”œآ؛â”œأپes de permissâ”œأپes\r\n    tests.push(await this.runTest(\r\n      \"Configuraâ”œآ؛â”œأپes de permissâ”œأپes\",\r\n      async () => {\r\n        const settings = await waitlistManager.getAgendaSettings(barbershopId);\r\n        \r\n        if (!settings) {\r\n          throw new Error(\"Configuraâ”œآ؛â”œأپes nâ”œأ؛o encontradas\");\r\n        }\r\n        \r\n        // Atualizar configuraâ”œآ؛â”œأپes\r\n        const updateResult = await waitlistManager.updateAgendaSettings(barbershopId, {\r\n          allow_professionals_view_queue: true,\r\n          allow_professionals_offer_slots: false,\r\n          enable_dynamic_pricing: true,\r\n          allow_professionals_view_dynamic_pricing: false,\r\n        });\r\n        \r\n        if (!updateResult.success) {\r\n          throw new Error(`Falha ao atualizar configuraâ”œآ؛â”œأپes: ${updateResult.error}`);\r\n        }\r\n        \r\n        // Verificar se foram salvas\r\n        const updatedSettings = await waitlistManager.getAgendaSettings(barbershopId);\r\n        \r\n        if (!updatedSettings || !updatedSettings.allow_professionals_view_queue) {\r\n          throw new Error(\"Configuraâ”œآ؛â”œأپes nâ”œأ؛o foram salvas corretamente\");\r\n        }\r\n        \r\n        return { settings: updatedSettings };\r\n      }\r\n    ));\r\n    \r\n    // Test 2: Regras de preâ”œآ؛o dinâ”œأ³mico\r\n    tests.push(await this.runTest(\r\n      \"CRUD de regras de preâ”œآ؛o dinâ”œأ³mico\",\r\n      async () => {\r\n        // Criar regra\r\n        const createResult = await waitlistManager.saveDynamicPricingRule({\r\n          barbershop_id: barbershopId,\r\n          service_id: \"test-service-1\",\r\n          day_of_week: 6, // Sâ”œأ­bado\r\n          start_time: \"09:00\",\r\n          end_time: \"12:00\",\r\n          price_type: \"fixed\",\r\n          price_adjustment: 10, // +R$ 10\r\n          is_active: true,\r\n          min_capacity_threshold: 90,\r\n          description: \"Teste - sâ”œأ­bado manhâ”œأ؛\",\r\n        });\r\n        \r\n        if (!createResult.success) {\r\n          throw new Error(`Falha ao criar regra: ${createResult.error}`);\r\n        }\r\n        \r\n        // Listar regras\r\n        const rules = await waitlistManager.getDynamicPricingRules(barbershopId);\r\n        \r\n        if (!Array.isArray(rules)) {\r\n          throw new Error(\"Lista de regras deveria ser um array\");\r\n        }\r\n        \r\n        // Excluir regra\r\n        const deleteResult = await waitlistManager.deleteDynamicPricingRule(\r\n          createResult.ruleId!,\r\n          barbershopId\r\n        );\r\n        \r\n        if (!deleteResult.success) {\r\n          throw new Error(`Falha ao excluir regra: ${deleteResult.error}`);\r\n        }\r\n        \r\n        return { \r\n          created: createResult.ruleId, \r\n          rulesCount: rules.length, \r\n          deleted: true \r\n        };\r\n      }\r\n    ));\r\n    \r\n    return this.createTestSuite(\"Sistema de Permissâ”œأپes\", tests);\r\n  }\r\n\r\n  /**\r\n   * Testes de Integraâ”œآ؛â”œأ؛o\r\n   */\r\n  private async testIntegrationScenarios(barbershopId: string): Promise<TestSuite> {\r\n    const tests: TestResult[] = [];\r\n    \r\n    // Test 1: Fluxo completo - Cliente entra na fila e recebe oferta\r\n    tests.push(await this.runTest(\r\n      \"Fluxo completo - Entrada na fila e oferta\",\r\n      async () => {\r\n        // 1. Cliente entra na fila\r\n        const preferences: WaitlistPreferences = {\r\n          professional_preferred_id: \"test-professional-1\",\r\n          accepts_other_professional: true,\r\n          accepts_nearby_time: true,\r\n          accepts_any_time: false,\r\n        };\r\n        \r\n        const waitlistResult = await waitlistManager.addToWaitlist(\r\n          barbershopId,\r\n          \"test-client-integration\",\r\n          \"test-service-1\",\r\n          \"2024-12-20\",\r\n          \"15:00\",\r\n          preferences\r\n        );\r\n        \r\n        if (!waitlistResult.success) {\r\n          throw new Error(`Falha ao entrar na fila: ${waitlistResult.error}`);\r\n        }\r\n        \r\n        // 2. Simular liberaâ”œآ؛â”œأ؛o de vaga\r\n        const slotResult = await waitlistManager.processSlotRelease(\r\n          barbershopId,\r\n          \"2024-12-20\",\r\n          \"14:30\",\r\n          \"test-professional-1\",\r\n          \"test-service-1\"\r\n        );\r\n        \r\n        if (!slotResult.processed) {\r\n          throw new Error(\"Liberaâ”œآ؛â”œأ؛o de vaga nâ”œأ؛o foi processada\");\r\n        }\r\n        \r\n        // 3. Verificar se oferta foi criada\r\n        const { data: updatedWaitlist } = await (supabase as any)\r\n          .from(\"waitlist_queue\")\r\n          .select(\"status, offered_at\")\r\n          .eq(\"id\", waitlistResult.waitlistId)\r\n          .single();\r\n        \r\n        if (!updatedWaitlist || updatedWaitlist.status !== \"offered\") {\r\n          throw new Error(\"Oferta nâ”œأ؛o foi criada corretamente\");\r\n        }\r\n        \r\n        return {\r\n          waitlistId: waitlistResult.waitlistId,\r\n          slotProcessed: slotResult.processed,\r\n          offerCreated: updatedWaitlist.status === \"offered\"\r\n        };\r\n      }\r\n    ));\r\n    \r\n    // Test 2: Fluxo de antecipaâ”œآ؛â”œأ؛o completa\r\n    tests.push(await this.runTest(\r\n      \"Fluxo completo - Antecipaâ”œآ؛â”œأ؛o automâ”œأ­tica\",\r\n      async () => {\r\n        // 1. Buscar oportunidades\r\n        const opportunities = await anticipationManager.findAnticipationOpportunities(\r\n          barbershopId,\r\n          \"test-client-integration\",\r\n          4\r\n        );\r\n        \r\n        // 2. Se houver oportunidade, enviar oferta\r\n        if (opportunities.length > 0) {\r\n          const offerResult = await anticipationManager.sendAnticipationOffer(\r\n            opportunities[0]\r\n          );\r\n          \r\n          if (!offerResult.success) {\r\n            throw new Error(`Falha ao enviar oferta de antecipaâ”œآ؛â”œأ؛o: ${offerResult.error}`);\r\n          }\r\n          \r\n          // 3. Processar aceite\r\n          const responseResult = await anticipationManager.processAnticipationResponse(\r\n            offerResult.offerId!,\r\n            \"accepted\"\r\n          );\r\n          \r\n          if (!responseResult.success) {\r\n            throw new Error(`Falha ao processar aceite: ${responseResult.error}`);\r\n          }\r\n          \r\n          return {\r\n            opportunitiesFound: opportunities.length,\r\n            offerSent: offerResult.success,\r\n            offerAccepted: responseResult.success\r\n          };\r\n        }\r\n        \r\n        return { opportunitiesFound: 0, message: \"Nenhuma oportunidade encontrada\" };\r\n      }\r\n    ));\r\n    \r\n    return this.createTestSuite(\"Cenâ”œأ­rios de Integraâ”œآ؛â”œأ؛o\", tests);\r\n  }\r\n\r\n  /**\r\n   * Executa um teste individual\r\n   */\r\n  private async runTest(testName: string, testFunction: () => Promise<any>): Promise<TestResult> {\r\n    const startTime = Date.now();\r\n    \r\n    try {\r\n      console.log(`[TEST] Executando: ${testName}`);\r\n      \r\n      const result = await testFunction();\r\n      \r\n      const duration = Date.now() - startTime;\r\n      \r\n      console.log(`[TEST] أ”آ£أ  ${testName} (${duration}ms)`);\r\n      \r\n      return {\r\n        testName,\r\n        passed: true,\r\n        details: result,\r\n        duration\r\n      };\r\n    } catch (error) {\r\n      const duration = Date.now() - startTime;\r\n      \r\n      console.log(`[TEST] أ”أکأ® ${testName} (${duration}ms): ${error}`);\r\n      \r\n      return {\r\n        testName,\r\n        passed: false,\r\n        error: error instanceof Error ? error.message : String(error),\r\n        duration\r\n      };\r\n    }\r\n  }\r\n\r\n  /**\r\n   * Cria uma suite de testes\r\n   */\r\n  private createTestSuite(name: string, tests: TestResult[]): TestSuite {\r\n    const passed = tests.filter(t => t.passed).length;\r\n    const failed = tests.filter(t => !t.passed).length;\r\n    const totalDuration = tests.reduce((sum, t) => sum + t.duration, 0);\r\n    \r\n    console.log(`[SUITE] ${name}: ${passed}/${tests.length} passaram (${totalDuration}ms)`);\r\n    \r\n    return {\r\n      name,\r\n      tests,\r\n      passed,\r\n      failed,\r\n      totalDuration\r\n    };\r\n  }\r\n\r\n  /**\r\n   * Limpa dados de teste\r\n   */\r\n  async cleanupTestData(barbershopId: string): Promise<void> {\r\n    try {\r\n      console.log(\"[CLEANUP] Limpando dados de teste...\");\r\n      \r\n      // Limpar entradas na fila de teste\r\n      await (supabase as any)\r\n        .from(\"waitlist_queue\")\r\n        .delete()\r\n        .like(\"client_id\", \"test-client-%\");\r\n      \r\n      // Limpar ofertas de antecipaâ”œآ؛â”œأ؛o de teste\r\n      await (supabase as any)\r\n        .from(\"anticipation_offers\")\r\n        .delete()\r\n        .like(\"client_id\", \"test-client-%\");\r\n      \r\n      // Limpar notificaâ”œآ؛â”œأپes de teste\r\n      await (supabase as any)\r\n        .from(\"notifications\")\r\n        .delete()\r\n        .like(\"user_id\", \"test-client-%\");\r\n      \r\n      // Limpar regras de preâ”œآ؛o dinâ”œأ³mico de teste\r\n      await (supabase as any)\r\n        .from(\"dynamic_pricing\")\r\n        .delete()\r\n        .like(\"description\", \"Teste - %\");\r\n      \r\n      console.log(\"[CLEANUP] Dados de teste limpos com sucesso\");\r\n    } catch (error) {\r\n      console.error(\"[CLEANUP] Erro ao limpar dados de teste:\", error);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * Gera relatâ”œâ”‚rio dos testes\r\n   */\r\n  generateReport(testSuites: TestSuite[]): string {\r\n    let report = \"# Relatâ”œâ”‚rio de Testes - Sistema de Fila Inteligente\\n\\n\";\r\n    \r\n    const totalTests = testSuites.reduce((sum, suite) => sum + suite.tests.length, 0);\r\n    const totalPassed = testSuites.reduce((sum, suite) => sum + suite.passed, 0);\r\n    const totalFailed = testSuites.reduce((sum, suite) => sum + suite.failed, 0);\r\n    const totalDuration = testSuites.reduce((sum, suite) => sum + suite.totalDuration, 0);\r\n    \r\n    report += `## Resumo\\n\\n`;\r\n    report += `- **Total de Testes**: ${totalTests}\\n`;\r\n    report += `- **Passaram**: ${totalPassed} أ”آ£أ \\n`;\r\n    report += `- **Falharam**: ${totalFailed} أ”أکأ®\\n`;\r\n    report += `- **Taxa de Sucesso**: ${((totalPassed / totalTests) * 100).toFixed(1)}%\\n`;\r\n    report += `- **Duraâ”œآ؛â”œأ؛o Total**: ${totalDuration}ms\\n\\n`;\r\n    \r\n    for (const suite of testSuites) {\r\n      report += `## ${suite.name}\\n\\n`;\r\n      report += `- **Passaram**: ${suite.passed}/${suite.tests.length}\\n`;\r\n      report += `- **Duraâ”œآ؛â”œأ؛o**: ${suite.totalDuration}ms\\n\\n`;\r\n      \r\n      for (const test of suite.tests) {\r\n        const status = test.passed ? \"أ”آ£أ \" : \"أ”أکأ®\";\r\n        report += `### ${status} ${test.testName}\\n`;\r\n        report += `- **Duraâ”œآ؛â”œأ؛o**: ${test.duration}ms\\n`;\r\n        \r\n        if (!test.passed) {\r\n          report += `- **Erro**: ${test.error}\\n`;\r\n        }\r\n        \r\n        report += \"\\n\";\r\n      }\r\n      \r\n      report += \"---\\n\\n\";\r\n    }\r\n    \r\n    return report;\r\n  }\r\n}\r\n\r\nexport const waitlistTests = new WaitlistTests();\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\services\\whatsAppAutomationService.ts","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":48,"column":19,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":48,"endColumn":22,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1733,1736],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1733,1736],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"mes
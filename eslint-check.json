\n    label: \"آ­ئ’أ¦أ‘ Painel de Clientes\",\r\n    desc: \"Preview do painel cliente\",\r\n  },\r\n  {\r\n    key: \"prova_social\",\r\n    label: \"أ”آ،أ‰ Prova Social (Popups)\",\r\n    desc: \"Popups de prova social na landing\",\r\n  },\r\n  {\r\n    key: \"planos\",\r\n    label: \"آ­ئ’أ†â”‚ Planos e Preâ”œآ؛os\",\r\n    desc: \"Seâ”œآ؛â”œأ؛o de planos de assinatura\",\r\n  },\r\n  { key: \"faq\", label: \"أ”أکأ´ FAQ\", desc: \"Perguntas frequentes\" },\r\n  {\r\n    key: \"depoimentos\",\r\n    label: \"آ­ئ’أ†آ¼ Depoimentos\",\r\n    desc: \"Seâ”œآ؛â”œأ؛o de depoimentos de clientes\",\r\n  },\r\n  {\r\n    key: \"contato\",\r\n    label: \"آ­ئ’أ´أ— Contato / WhatsApp\",\r\n    desc: \"Botâ”œأ؛o e seâ”œآ؛â”œأ؛o de contato\",\r\n  },\r\n];\r\n\r\nconst LandingVisibilidadePage = () => {\r\n  const [visibility, setVisibility] = useState<Record<string, boolean>>({});\r\n  const [loading, setLoading] = useState(true);\r\n  const [saving, setSaving] = useState(false);\r\n\r\n  useEffect(() => {\r\n    supabase\r\n      .from(\"integration_settings\")\r\n      .select(\"*\")\r\n      .eq(\"service_name\", \"landing_visibility\")\r\n      .eq(\"environment\", \"production\")\r\n      .maybeSingle()\r\n      .then(({ data }: any) => {\r\n        if (data?.config) {\r\n          setVisibility(data.config as Record<string, boolean>);\r\n        } else {\r\n          const defaults: Record<string, boolean> = {};\r\n          LANDING_SECTIONS.forEach((s) => {\r\n            defaults[s.key] = true;\r\n          });\r\n          setVisibility(defaults);\r\n        }\r\n        setLoading(false);\r\n      });\r\n  }, []);\r\n\r\n  const toggle = (key: string) => {\r\n    setVisibility((prev) => ({ ...prev, [key]: !prev[key] }));\r\n  };\r\n\r\n  const handleSave = async () => {\r\n    setSaving(true);\r\n    const { error } = await (supabase as any)\r\n      .from(\"integration_settings\")\r\n      .upsert(\r\n        {\r\n          service_name: \"landing_visibility\",\r\n          environment: \"production\",\r\n          config: visibility,\r\n          is_active: true,\r\n        },\r\n        { onConflict: \"service_name,environment\" },\r\n      );\r\n    setSaving(false);\r\n    if (error) {\r\n      toast.error(\"Erro ao salvar: \" + error.message);\r\n      return;\r\n    }\r\n    toast.success(\"Visibilidade da landing page salva!\");\r\n  };\r\n\r\n  if (loading)\r\n    return (\r\n      <div className=\"flex justify-center py-12\">\r\n        <Loader2 className=\"w-8 h-8 animate-spin text-primary\" />\r\n      </div>\r\n    );\r\n\r\n  const activeCount = Object.values(visibility).filter(Boolean).length;\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      <div className=\"flex items-center justify-between flex-wrap gap-3\">\r\n        <div>\r\n          <h1 className=\"font-display text-2xl font-bold\">\r\n            Visibilidade da Landing Page\r\n          </h1>\r\n          <p className=\"text-muted-foreground text-sm\">\r\n            Controle quais seâ”œآ؛â”œأپes aparecem para afiliados, painâ”œآ®is e visitantes\r\n          </p>\r\n        </div>\r\n        <Button variant=\"gold\" onClick={handleSave} disabled={saving}>\r\n          {saving ? (\r\n            <Loader2 className=\"w-4 h-4 animate-spin mr-2\" />\r\n          ) : (\r\n            <Eye className=\"w-4 h-4 mr-2\" />\r\n          )}\r\n          {saving ? \"Salvando...\" : \"Salvar Configuraâ”œآ؛â”œأ؛o\"}\r\n        </Button>\r\n      </div>\r\n\r\n      <Card className=\"border-primary/20 bg-primary/5\">\r\n        <CardContent className=\"py-3 flex items-center gap-3\">\r\n          <Activity className=\"w-5 h-5 text-primary\" />\r\n          <p className=\"text-sm\">\r\n            {activeCount} de {LANDING_SECTIONS.length} seâ”œآ؛â”œأپes visâ”œآ،veis na\r\n            landing page\r\n          </p>\r\n        </CardContent>\r\n      </Card>\r\n\r\n      <div className=\"grid gap-3\">\r\n        {LANDING_SECTIONS.map((section) => (\r\n          <Card\r\n            key={section.key}\r\n            className={`transition-all ${visibility[section.key] ? \"border-primary/30\" : \"border-border opacity-60\"}`}\r\n          >\r\n            <CardContent className=\"p-4 flex items-center justify-between gap-4\">\r\n              <div className=\"flex-1\">\r\n                <p className=\"font-medium\">{section.label}</p>\r\n                <p className=\"text-xs text-muted-foreground\">{section.desc}</p>\r\n              </div>\r\n              <div className=\"flex items-center gap-3\">\r\n                <span\r\n                  className={`text-xs px-2 py-0.5 rounded-full ${visibility[section.key] ? \"bg-success/10 text-success\" : \"bg-muted text-muted-foreground\"}`}\r\n                >\r\n                  {visibility[section.key] ? \"Visâ”œآ،vel\" : \"Oculto\"}\r\n                </span>\r\n                <Switch\r\n                  checked={!!visibility[section.key]}\r\n                  onCheckedChange={() => toggle(section.key)}\r\n                />\r\n              </div>\r\n            </CardContent>\r\n          </Card>\r\n        ))}\r\n      </div>\r\n\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle className=\"text-base\">\r\n            Links Râ”œأ­pidos أ”أ‡أ¶ Seâ”œآ؛â”œأپes de Painel\r\n          </CardTitle>\r\n          <CardDescription>\r\n            Configure quais CTAs aparecem para cada tipo de usuâ”œأ­rio\r\n          </CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-3\">\r\n          {[\r\n            { key: \"cta_afiliado\", label: 'Botâ”œأ؛o \"Seja Afiliado\" no header' },\r\n            { key: \"cta_dono\", label: 'Botâ”œأ؛o \"Abrir Barbearia\" no hero' },\r\n            {\r\n              key: \"cta_cliente\",\r\n              label: 'Botâ”œأ؛o \"Agendar Agora\" para clientes',\r\n            },\r\n            { key: \"banner_vitrine\", label: \"Banner de vitrine dos produtos\" },\r\n          ].map((item) => (\r\n            <div\r\n              key={item.key}\r\n              className=\"flex items-center justify-between p-3 border rounded-lg\"\r\n            >\r\n              <p className=\"text-sm\">{item.label}</p>\r\n              <div className=\"flex items-center gap-2\">\r\n                <span\r\n                  className={`text-xs px-2 py-0.5 rounded-full ${visibility[item.key] !== false ? \"bg-success/10 text-success\" : \"bg-muted text-muted-foreground\"}`}\r\n                >\r\n                  {visibility[item.key] !== false ? \"Ativo\" : \"Inativo\"}\r\n                </span>\r\n                <Switch\r\n                  checked={visibility[item.key] !== false}\r\n                  onCheckedChange={() => toggle(item.key)}\r\n                />\r\n              </div>\r\n            </div>\r\n          ))}\r\n        </CardContent>\r\n      </Card>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default SuperAdminDashboard;\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\pages\\onboarding\\OnboardingSelectionPage.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\pages\\partners\\NotificationsPage.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\pages\\public\\CostAnalysisPage.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛
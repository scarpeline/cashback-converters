:"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":4,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"// @ts-nocheck\r\nimport { createClient } from '@/lib/supabase';\r\nimport { Database } from '@/integrations/supabase/types';\r\n\r\ntype DatabaseType = Database;\r\n\r\nexport interface ActivityRule {\r\n  daysInactive: number;\r\n  penaltyPercentage: number;\r\n  level: number;\r\n  description: string;\r\n}\r\n\r\nexport interface RenewalNotification {\r\n  partnerId: string;\r\n  planType: 'mensal' | 'trimestral' | 'semestral' | 'anual';\r\n  renewalDate: string;\r\n  daysUntilRenewal: number;\r\n  message: string;\r\n}\r\n\r\nexport class ActivityService {\r\n  private supabase = createClient();\r\n\r\n  // Regras de atividade baseadas nos requisitos\r\n  private activityRules: ActivityRule[] = [\r\n    { daysInactive: 40, penaltyPercentage: 10, level: 1, description: '10% de reduâ”œآ؛â”œأ؛o nas comissâ”œأپes' },\r\n    { daysInactive: 60, penaltyPercentage: 15, level: 2, description: '15% de reduâ”œآ؛â”œأ؛o nas comissâ”œأپes' },\r\n    { daysInactive: 90, penaltyPercentage: 25, level: 3, description: '25% de reduâ”œآ؛â”œأ؛o nas comissâ”œأپes' },\r\n    { daysInactive: 120, penaltyPercentage: 40, level: 4, description: '40% de reduâ”œآ؛â”œأ؛o nas comissâ”œأپes' },\r\n  ];\r\n\r\n  /**\r\n   * Verifica e aplica regras de atividade para todos os parceiros\r\n   */\r\n  async checkAndApplyActivityRules(): Promise<void> {\r\n    try {\r\n      const { data: partners, error } = await this.supabase\r\n        .from('parceiros')\r\n        .select('*')\r\n        .eq('status', 'ativo');\r\n\r\n      if (error || !partners) {\r\n        console.error('Erro ao buscar parceiros:', error);\r\n        return;\r\n      }\r\n\r\n      for (const partner of partners) {\r\n        await this.checkPartnerActivity(partner.id);\r\n      }\r\n    } catch (error) {\r\n      console.error('Erro ao verificar regras de atividade:', error);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * Verifica atividade de um parceiro especâ”œآ،fico\r\n   */\r\n  async checkPartnerActivity(partnerId: string): Promise<void> {\r\n    try {\r\n      const { data: partner, error } = await this.supabase\r\n        .from('parceiros')\r\n        .select('*')\r\n        .eq('id', partnerId)\r\n        .single();\r\n\r\n      if (error || !partner) {\r\n        console.error('Erro ao buscar parceiro:', error);\r\n        return;\r\n      }\r\n\r\n      // Calcular dias desde â”œâ•‘ltima indicaâ”œآ؛â”œأ؛o\r\n      const daysSinceLastIndication = this.calculateDaysSinceLastIndication(partner.data_ultima_indicacao);\r\n      \r\n      // Encontrar regra aplicâ”œأ­vel\r\n      const applicableRule = this.findApplicableRule(daysSinceLastIndication);\r\n      \r\n      if (applicableRule) {\r\n        // Aplicar penalidade\r\n        await this.applyPenalty(partnerId, applicableRule, daysSinceLastIndication);\r\n        \r\n        // Enviar notificaâ”œآ؛â”œأ؛o\r\n        await this.sendActivityNotification(partner, applicableRule, daysSinceLastIndication);\r\n      } else if (daysSinceLastIndication < 40) {\r\n        // Resetar penalidades se estiver ativo\r\n        await this.resetPenalties(partnerId);\r\n      }\r\n\r\n      // Atualizar dias parado\r\n      await this.supabase\r\n        .from('parceiros')\r\n        .update({ dias_parado: daysSinceLastIndication })\r\n        .eq('id', partnerId);\r\n\r\n    } catch (error) {\r\n      console.error('Erro ao verificar atividade do parceiro:', error);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * Calcula dias desde â”œâ•‘ltima indicaâ”œآ؛â”œأ؛o\r\n   */\r\n  private calculateDaysSinceLastIndication(lastIndicationDate?: string): number {\r\n    if (!lastIndicationDate) {\r\n      // Se nunca indicou, contar desde a data de inâ”œآ،cio\r\n      return 999; // Valor alto para indicar inatividade prolongada\r\n    }\r\n\r\n    const lastDate = new Date(lastIndicationDate);\r\n    const today = new Date();\r\n    const diffTime = Math.abs(today.getTime() - lastDate.getTime());\r\n    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));\r\n    \r\n    return diffDays;\r\n  }\r\n\r\n  /**\r\n   * Encontra regra aplicâ”œأ­vel baseada nos dias de inatividade\r\n   */\r\n  private findApplicableRule(daysInactive: number): ActivityRule | null {\r\n    // Regra para alâ”œآ®m de 120 dias (10% adicionais a cada 30 dias)\r\n    if (daysInactive >= 120) {\r\n      const additionalPenalties = Math.floor((daysInactive - 120) / 30) * 10;\r\n      const totalPenalty = Math.min(40 + additionalPenalties, 90);\r\n      const additionalLevels = Math.floor((daysInactive - 120) / 30);\r\n      \r\n      return {\r\n        daysInactive,\r\n        penaltyPercentage: totalPenalty,\r\n        level: 4 + additionalLevels,\r\n        description: `${totalPenalty}% de reduâ”œآ؛â”œأ؛o nas comissâ”œأپes`\r\n      };\r\n    }\r\n\r\n    // Regras padrâ”œأ؛o\r\n    return this.activityRules\r\n      .slice()\r\n      .reverse()\r\n      .find(rule => daysInactive >= rule.daysInactive) || null;\r\n  }\r\n\r\n  /**\r\n   * Aplica penalidade ao parceiro\r\n   */\r\n  private async applyPenalty(partnerId: string, rule: ActivityRule, daysInactive: number): Promise<void> {\r\n    try {\r\n      await this.supabase\r\n        .from('parceiros')\r\n        .update({\r\n          nivel_penalidade: rule.penaltyPercentage,\r\n          dias_parado: daysInactive\r\n        })\r\n        .eq('id', partnerId);\r\n\r\n      // Registrar log\r\n      await this.logActivity(partnerId, 'penalidade_aplicada', `Penalidade de ${rule.penaltyPercentage}% aplicada: ${rule.description}`);\r\n\r\n      console.log(`Penalidade aplicada ao parceiro ${partnerId}: ${rule.description}`);\r\n    } catch (error) {\r\n      console.error('Erro ao aplicar penalidade:', error);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * Reseta penalidades do parceiro\r\n   */\r\n  private async resetPenalties(partnerId: string): Promise<void> {\r\n    try {\r\n      await this.supabase\r\n        .from('parceiros')\r\n        .update({\r\n          nivel_penalidade: 0,\r\n          dias_parado: 0\r\n        })\r\n        .eq('id', partnerId);\r\n\r\n      // Registrar log\r\n      await this.logActivity(partnerId, 'penalidade_resetada', 'Penalidades resetadas - Parceiro ativo');\r\n\r\n      console.log(`Penalidades resetadas para o parceiro ${partnerId}`);\r\n    } catch (error) {\r\n      console.error('Erro ao resetar penalidades:', error);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * Envia notificaâ”œآ؛â”œأ؛o de atividade ao parceiro\r\n   */\r\n  private async sendActivityNotification(partner: any, rule: ActivityRule, daysInactive: number): Promise<void> {\r\n    try {\r\n      // Registrar notificaâ”œآ؛â”œأ؛o no log (tabela notificacoes nâ”œأ؛o existe ainda)\r\n      await this.logActivity(partner.id, 'notificacao_atividade', `Alerta de atividade: ${rule.description}`);\r\n\r\n      // Enviar email (em produâ”œآ؛â”œأ؛o)\r\n      await this.sendActivityEmail(partner, rule, daysInactive);\r\n\r\n      console.log(`Notificaâ”œآ؛â”œأ؛o de atividade registrada para o parceiro ${partner.id}`);\r\n    } catch (error) {\r\n      console.error('Erro ao enviar notificaâ”œآ؛â”œأ؛o de atividade:', error);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * Gera mensagem de notificaâ”œآ؛â”œأ؛o de atividade\r\n   */\r\n  private generateActivityMessage(daysInactive: number, rule: ActivityRule): string {\r\n    if (daysInactive >= 120) {\r\n      return `Atenâ”œآ؛â”œأ؛o crâ”œآ،tica! Vocâ”œآ¬ estâ”œأ­ ${daysInactive} dias sem realizar uma indicaâ”œآ؛â”œأ؛o. Sua comissâ”œأ؛o foi reduzida em ${rule.penaltyPercentage}%. Para recuperar, ative 2 novos clientes.`;\r\n    }\r\n\r\n    if (daysInactive >= 90) {\r\n      return `Alerta importante! Vocâ”œآ¬ estâ”œأ­ ${daysInactive} dias sem realizar uma indicaâ”œآ؛â”œأ؛o. Sua comissâ”œأ؛o foi reduzida em ${rule.penaltyPercentage}%. Indique novos clientes para recuperar seu nâ”œآ،vel.`;\r\n    }\r\n\r\n    if (daysInactive >= 60) {\r\n      return `Atenâ”œآ؛â”œأ؛o! Vocâ”œآ¬ estâ”œأ­ ${daysInactive} dias sem realizar uma indicaâ”œآ؛â”œأ؛o. Sua comissâ”œأ؛o foi reduzida em ${rule.penaltyPercentage}%. Nâ”œأ؛o deixe sua rede esfriar!`;\r\n    }\r\n\r\n    if (daysInactive >= 40) {\r\n      return `Aviso: Vocâ”œآ¬ estâ”œأ­ ${daysInactive} dias sem realizar uma indicaâ”œآ؛â”œأ؛o. Sua comissâ”œأ؛o foi reduzida em ${rule.penaltyPercentage}%. Mantenha sua rede ativa!`;\r\n    }\r\n\r\n    return '';\r\n  }\r\n\r\n  /**\r\n   * Envia email de atividade (simulaâ”œآ؛â”œأ؛o)\r\n   */\r\n  private async sendActivityEmail(partner: any, rule: ActivityRule, daysInactive: number): Promise<void> {\r\n    // Em produâ”œآ؛â”œأ؛o, integrar com serviâ”œآ؛o de email\r\n    console.log(`Email de atividade enviado para ${partner.email}:`, {\r\n      subject: 'Alerta de Atividade - Salâ”œأ؛oCashBack',\r\n      message: this.generateActivityMessage(daysInactive, rule)\r\n    });\r\n  }\r\n\r\n  /**\r\n   * Processa recuperaâ”œآ؛â”œأ؛o de penalidade\r\n   */\r\n  async processPenaltyRecovery(partnerId: string, newClientsCount: number): Promise<void> {\r\n    try {\r\n      const { data: partner, error } = await this.supabase\r\n        .from('parceiros')\r\n        .select('*')\r\n        .eq('id', partnerId)\r\n        .single();\r\n\r\n      if (error || !partner) {\r\n        console.error('Erro ao buscar parceiro:', error);\r\n        return;\r\n      }\r\n\r\n      const currentLevel = partner.nivel_penalidade || 0;\r\n      \r\n      if (currentLevel > 0) {\r\n        // Cada 2 novos clientes reduzem 1 nâ”œآ،vel de penalidade\r\n        const levelsToRecover = Math.floor(newClientsCount / 2);\r\n        const newLevel = Math.max(0, currentLevel - (levelsToRecover * 10));\r\n\r\n        await this.supabase\r\n          .from('parceiros')\r\n          .update({ nivel_penalidade: newLevel })\r\n          .eq('id', partnerId);\r\n\r\n        // Registrar log\r\n        await this.logActivity(partnerId, 'penalidade_recuperada', `Recuperados ${levelsToRecover} nâ”œآ،veis com ${newClientsCount} novos clientes`);\r\n\r\n        console.log(`Recuperaâ”œآ؛â”œأ؛o de penalidade processada para parceiro ${partnerId}: nâ”œآ،vel ${currentLevel}% أ”أ¥أ† ${newLevel}%`);\r\n      }\r\n    } catch (error) {\r\n      console.error('Erro ao processar recuperaâ”œآ؛â”œأ؛o de penalidade:', error);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * Verifica renovaâ”œآ؛â”œأپes de assinaturas\r\n   */\r\n  async checkSubscriptionRenewals(): Promise<RenewalNotification[]> {\r\n    try {\r\n      const { data: partners, error } = await this.supabase\r\n        .from('parceiros')\r\n        .select('*')\r\n        .eq('status', 'ativo')\r\n        .not('data_renovacao', 'is', null);\r\n\r\n      if (error || !partners) {\r\n        console.error('Erro ao buscar parceiros com renovaâ”œآ؛â”œأپes:', error);\r\n        return [];\r\n      }\r\n\r\n      const notifications: RenewalNotification[] = [];\r\n      const today = new Date();\r\n\r\n      for (const partner of partners) {\r\n        if (partner.data_renovacao) {\r\n          const renewalDate = new Date(partner.data_renovacao);\r\n          const daysUntilRenewal = Math.ceil((renewalDate.getTime() - today.getTime()) / (1000 * 60 * 60 * 24));\r\n\r\n          // Enviar notificaâ”œآ؛â”œأپes em 30, 15 e 7 dias antes\r\n          if ([30, 15, 7].includes(daysUntilRenewal)) {\r\n            const notification = this.generateRenewalNotification(partner, daysUntilRenewal);\r\n            notifications.push(notification);\r\n\r\n            // Salvar notificaâ”œآ؛â”œأ؛o no banco\r\n            await this.saveRenewalNotification(notification);\r\n          }\r\n        }\r\n      }\r\n\r\n      return notifications;\r\n    } catch (error) {\r\n      console.error('Erro ao verificar renovaâ”œآ؛â”œأپes:', error);\r\n      return [];\r\n    }\r\n  }\r\n\r\n  /**\r\n   * Gera notificaâ”œآ؛â”œأ؛o de renovaâ”œآ؛â”œأ؛o\r\n   */\r\n  private generateRenewalNotification(partner: any, daysUntilRenewal: number): RenewalNotification {\r\n    const planNames = {\r\n      mensal: 'Plano Mensal',\r\n      trimestral: 'Plano Trimestral',\r\n      semestral: 'Plano Semestral',\r\n      anual: 'Plano Anual'\r\n    };\r\n\r\n    const planName = planNames[partner.plano_assinatura as keyof typeof planNames] || 'Plano';\r\n\r\n    let message = '';\r\n    if (daysUntilRenewal === 30) {\r\n      message = `Sua assinatura ${planName} serâ”œأ­ renovada em 30 dias. Prepare-se para a renovaâ”œآ؛â”œأ؛o automâ”œأ­tica.`;\r\n    } else if (daysUntilRenewal === 15) {\r\n      message = `Aviso: Sua assinatura ${planName} serâ”œأ­ renovada em 15 dias. Verifique seus dados de pagamento.`;\r\n    } else if (daysUntilRenewal === 7) {\r\n      message = `â”œأœltimo aviso: Sua assinatura ${planName} serâ”œأ­ renovada em 7 dias. Contate o suporte se necessâ”œأ­rio.`;\r\n    }\r\n\r\n    return {\r\n      partnerId: partner.id,\r\n      planType: partner.plano_assinatura,\r\n      renewalDate: partner.data_renovacao!,\r\n      daysUntilRenewal,\r\n      message\r\n    };\r\n  }\r\n\r\n  /**\r\n   * Salva notificaâ”œآ؛â”œأ؛o de renovaâ”œآ؛â”œأ؛o no log\r\n   */\r\n  private async saveRenewalNotification(notification: RenewalNotification): Promise<void> {\r\n    try {\r\n      // Registrar no log (tabela notificacoes nâ”œأ؛o existe ainda)\r\n      await this.logActivity(notification.partnerId, 'notificacao_renovacao', notification.message);\r\n\r\n      console.log(`Notificaâ”œآ؛â”œأ؛o de renovaâ”œآ؛â”œأ؛o registrada para parceiro ${notification.partnerId}`);\r\n    } catch (error) {\r\n      console.error('Erro ao salvar notificaâ”œآ؛â”œأ؛o de renovaâ”œآ؛â”œأ؛o:', error);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * Processa renovaâ”œآ؛â”œأ؛o de assinatura\r\n   */\r\n  async processSubscriptionRenewal(partnerId: string): Promise<void> {\r\n    try {\r\n      const { data: partner, error } = await this.supabase\r\n        .from('parceiros')\r\n        .select('*')\r\n        .eq('id', partnerId)\r\n        .single();\r\n\r\n      if (error || !partner) {\r\n        console.error('Erro ao buscar parceiro:', error);\r\n        return;\r\n      }\r\n\r\n      // Buscar preâ”œآ؛os dos planos\r\n      const { data: plans } = await this.supabase\r\n        .from('planos_parceiros')\r\n        .select('*')\r\n        .eq('nome', partner.plano_assinatura)\r\n        .eq('ativo', true)\r\n        .single();\r\n\r\n      if (!plans) {\r\n        console.error('Plano nâ”œأ؛o encontrado:', partner.plano_assinatura);\r\n        return;\r\n      }\r\n\r\n      // Calcular prâ”œâ”‚xima data de renovaâ”œآ؛â”œأ؛o\r\n      const renewalDate = new Date(partner.data_renovacao!);\r\n      const nextRenewalDate = new Date(renewalDate);\r\n      nextRenewalDate.setMonth(nextRenewalDate.getMonth() + plans.duracao_meses);\r\n\r\n      // Atualizar data de renovaâ”œآ؛â”œأ؛o\r\n      await this.supabase\r\n        .from('parceiros')\r\n        .update({\r\n          data_renovacao: nextRenewalDate.toISOString()\r\n        })\r\n        .eq('id', partnerId);\r\n\r\n      // Registrar log\r\n      await this.logActivity(partnerId, 'assinatura_renovada', `Plano ${partner.plano_assinatura} renovado por ${plans.duracao_meses} meses`);\r\n\r\n      console.log(`Renovaâ”œآ؛â”œأ؛o processada para parceiro ${partnerId}: ${partner.plano_assinatura}`);\r\n    } catch (error) {\r\n      console.error('Erro ao processar renovaâ”œآ؛â”œأ؛o:', error);\r\n    }\r\n  }\r\n\r\n  /**\r\n   * Registra atividade do parceiro\r\n   */\r\n  private async logActivity(partnerId: string, action: string, description: string): Promise<void> {\r\n    await this.supabase\r\n      .from('logs_atividade_parceiros')\r\n      .insert({\r\n        parceiro_id: partnerId,\r\n        tipo_acao: action,\r\n        descricao: description,\r\n        dados_adicionais: { timestamp: new Date().toISOString() },\r\n        data_acao: new Date().toISOString()\r\n      });\r\n  }\r\n\r\n  /**\r\n   * Obtâ”œآ®m estatâ”œآ،sticas de atividade do parceiro\r\n   */\r\n  async getPartnerActivityStats(partnerId: string) {\r\n    try {\r\n      const { data: partner } = await this.supabase\r\n        .from('parceiros')\r\n        .select('*')\r\n        .eq('id', partnerId)\r\n        .single();\r\n\r\n      if (!partner) return null;\r\n\r\n      // Buscar logs de atividade recentes\r\n      const { data: recentLogs } = await this.supabase\r\n        .from('logs_atividade_parceiros')\r\n        .select('*')\r\n        .eq('parceiro_id', partnerId)\r\n        .order('data_acao', { ascending: false })\r\n        .limit(10);\r\n\r\n      // Notificaâ”œآ؛â”œأپes nâ”œأ؛o lidas nâ”œأ؛o disponâ”œآ،veis ainda (tabela nâ”œأ؛o existe)\r\n      const unreadNotifications = [];\r\n\r\n      return {\r\n        partner,\r\n        activityStatus: this.getActivityStatus(partner.dias_parado || 0),\r\n        recentLogs: recentLogs || [],\r\n        unreadNotifications: unreadNotifications || [],\r\n        nextRenewal: partner.data_renovacao\r\n      };\r\n    } catch (error) {\r\n      console.error('Erro ao buscar estatâ”œآ،sticas de atividade:', error);\r\n      return null;\r\n    }\r\n  }\r\n\r\n  /**\r\n   * Obtâ”œآ®m status de atividade\r\n   */\r\n  private getActivityStatus(daysInactive: number): string {\r\n    if (daysInactive < 40) return 'ativo';\r\n    if (daysInactive < 60) return 'atencao';\r\n    if (daysInactive < 90) return 'penalizado';\r\n    return 'critico';\r\n  }\r\n}\r\n\r\nexport const activityService = new ActivityService();\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\lib\\activityTracker.ts","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":15,"column":24,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":15,"endColumn":27,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[476,479],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[476,479],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":32,"column":41,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":32,"endColumn":44,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[881,884],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[881,884],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/**\r\n * activityTracker.ts\r\n * Registra atividade do usuâ”œأ­rio e detecta inatividade para remarketing\r\n * Usa tabela notifications como log (sem criar tabela nova)\r\n */\r\nimport { supabase } from \"@/integrations/supabase/client\";\r\n\r\nexport type InactivityTrigger = \"1d\" | \"3d\" | \"7d\";\r\n\r\n/**\r\n * Registra uma aâ”œآ؛â”œأ؛o do usuâ”œأ­rio (silencioso, nâ”œأ؛o bloqueia UI)\r\n */\r\nexport async function trackActivity(userId: string, action: string): Promise<void> {\r\n  try {\r\n    await (supabase as any).from(\"notifications\").insert({\r\n      user_id: userId,\r\n      title: \"activity\",\r\n      message: action,\r\n      type: \"info\",\r\n      read: true,\r\n    });\r\n  } catch {\r\n    // silencioso\r\n  }\r\n}\r\n\r\n/**\r\n * Retorna quantos dias desde a â”œâ•‘ltima atividade do usuâ”œأ­rio\r\n */\r\nexport async function getDaysSinceLastActivity(userId: string): Promise<number> {\r\n  try {\r\n    const { data } = await (supabase as any)\r\n      .from(\"notifications\")\r\n      .select(\"created_at\")\r\n      .eq(\"user_id\", userId)\r\n      .order(\"created_at\", { ascending: false })\r\n      .limit(1)\r\n      .maybeSingle();\r\n\r\n    if (!data) return 999;\r\n    const diff = Date.now() - new Date(data.created_at).getTime();\r\n    return Math.floor(diff / (1000 * 60 * 60 * 24));\r\n  } catch {\r\n    return 999;\r\n  }\r\n}\r\n\r\n/**\r\n * Retorna o trigger de inatividade (1d, 3d, 7d) ou null se ativo\r\n */\r\nexport async function getInactivityTrigger(userId: string): Promise<InactivityTrigger | null> {\r\n  const days = await getDaysSinceLastActivity(userId);\r\n  if (days >= 7) return \"7d\";\r\n  if (days >= 3) return \"3d\";\r\n  if (days >= 1) return \"1d\";\r\n  return null;\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\lib\\adapters\\email-adapter.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\lib\\adapters\\index.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\lib\\adapters\\payment-adapter.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\patt
e);\r\n      }\r\n\r\n      const { data, error } = await query;\r\n      if (error) throw error;\r\n      return data || [];\r\n    },\r\n  });\r\n\r\n  const markAsReadMutation = useMutation({\r\n    mutationFn: markNotificationAsRead,\r\n    onSuccess: () => {\r\n      queryClient.invalidateQueries({ queryKey: ['partner-notifications'] });\r\n      toast.success('Notificaâ”œآ؛â”œأ؛o marcada como lida');\r\n    },\r\n  });\r\n\r\n  const deleteMutation = useMutation({\r\n    mutationFn: deleteNotification,\r\n    onSuccess: () => {\r\n      queryClient.invalidateQueries({ queryKey: ['partner-notifications'] });\r\n      toast.success('Notificaâ”œآ؛â”œأ؛o deletada');\r\n    },\r\n  });\r\n\r\n  const markAllAsReadMutation = useMutation({\r\n    mutationFn: () => markAllNotificationsAsRead(partnerId),\r\n    onSuccess: () => {\r\n      queryClient.invalidateQueries({ queryKey: ['partner-notifications'] });\r\n      toast.success('Todas as notificaâ”œآ؛â”œأپes marcadas como lidas');\r\n    },\r\n  });\r\n\r\n  const getIcon = (type: string) => {\r\n    switch (type) {\r\n      case 'commission_generated':\r\n      case 'commission_approved':\r\n      case 'commission_paid':\r\n        return <Gift className=\"w-5 h-5 text-green-500\" />;\r\n      case 'new_referral':\r\n      case 'referral_completed':\r\n        return <Users className=\"w-5 h-5 text-blue-500\" />;\r\n      default:\r\n        return <Bell className=\"w-5 h-5 text-gray-500\" />;\r\n    }\r\n  };\r\n\r\n  const getTypeLabel = (type: string) => {\r\n    switch (type) {\r\n      case 'commission_generated': return 'Comissâ”œأ؛o Gerada';\r\n      case 'commission_approved': return 'Comissâ”œأ؛o Aprovada';\r\n      case 'commission_paid': return 'Comissâ”œأ؛o Paga';\r\n      case 'new_referral': return 'Nova Indicaâ”œآ؛â”œأ؛o';\r\n      case 'referral_completed': return 'Indicaâ”œآ؛â”œأ؛o Completada';\r\n      default: return type;\r\n    }\r\n  };\r\n\r\n  const unreadCount = notifications?.filter((n: any) => !n.read).length || 0;\r\n\r\n  if (isLoading) {\r\n    return (\r\n      <div className=\"flex justify-center items-center py-12\">\r\n        <Loader2 className=\"w-8 h-8 animate-spin text-primary\" />\r\n      </div>\r\n    );\r\n  }\r\n\r\n  return (\r\n    <div className=\"space-y-4\">\r\n      {/* Header */}\r\n      <div className=\"flex items-center justify-between\">\r\n        <div>\r\n          <h2 className=\"text-2xl font-bold\">Notificaâ”œآ؛â”œأپes</h2>\r\n          {unreadCount > 0 && (\r\n            <p className=\"text-sm text-muted-foreground\">\r\n              {unreadCount} notificaâ”œآ؛â”œأ؛o{unreadCount !== 1 ? 's' : ''} nâ”œأ؛o lida{unreadCount !== 1 ? 's' : ''}\r\n            </p>\r\n          )}\r\n        </div>\r\n        {unreadCount > 0 && (\r\n          <Button\r\n            variant=\"outline\"\r\n            size=\"sm\"\r\n            onClick={() => markAllAsReadMutation.mutate()}\r\n            disabled={markAllAsReadMutation.isPending}\r\n          >\r\n            Marcar todas como lidas\r\n          </Button>\r\n        )}\r\n      </div>\r\n\r\n      {/* Filters */}\r\n      <div className=\"flex gap-2\">\r\n        <Button\r\n          variant={filter === 'all' ? 'default' : 'outline'}\r\n          size=\"sm\"\r\n          onClick={() => setFilter('all')}\r\n        >\r\n          Todas\r\n        </Button>\r\n        <Button\r\n          variant={filter === 'unread' ? 'default' : 'outline'}\r\n          size=\"sm\"\r\n          onClick={() => setFilter('unread')}\r\n        >\r\n          Nâ”œأ؛o lidas ({unreadCount})\r\n        </Button>\r\n      </div>\r\n\r\n      {/* Notifications List */}\r\n      <Card>\r\n        <CardContent className=\"p-0\">\r\n          {!notifications || notifications.length === 0 ? (\r\n            <div className=\"text-center py-12 text-muted-foreground\">\r\n              <Bell className=\"w-12 h-12 mx-auto mb-4 opacity-30\" />\r\n              <p>Nenhuma notificaâ”œآ؛â”œأ؛o</p>\r\n            </div>\r\n          ) : (\r\n            <div className=\"divide-y\">\r\n              {notifications.map((notification: any) => (\r\n                <div\r\n                  key={notification.id}\r\n                  className={`p-4 hover:bg-muted/50 transition ${\r\n                    !notification.read ? 'bg-blue-50/50' : ''\r\n                  }`}\r\n                >\r\n                  <div className=\"flex items-start gap-3\">\r\n                    <div className=\"mt-1\">\r\n                      {getIcon(notification.type)}\r\n                    </div>\r\n\r\n                    <div className=\"flex-1\">\r\n                      <div className=\"flex items-center gap-2 mb-1\">\r\n                        <p className=\"font-semibold\">\r\n                          {notification.title}\r\n                        </p>\r\n                        {!notification.read && (\r\n                          <Badge variant=\"default\" className=\"text-xs\">\r\n                            Novo\r\n                          </Badge>\r\n                        )}\r\n                      </div>\r\n\r\n                      <p className=\"text-sm text-muted-foreground mb-2\">\r\n                        {notification.message}\r\n                      </p>\r\n\r\n                      <div className=\"flex items-center justify-between\">\r\n                        <p className=\"text-xs text-muted-foreground\">\r\n                          {new Date(notification.created_at).toLocaleDateString('pt-BR', {\r\n                            year: 'numeric',\r\n                            month: 'short',\r\n                            day: 'numeric',\r\n                            hour: '2-digit',\r\n                            minute: '2-digit',\r\n                          })}\r\n                        </p>\r\n\r\n                        <div className=\"flex gap-2\">\r\n                          {!notification.read && (\r\n                            <Button\r\n         
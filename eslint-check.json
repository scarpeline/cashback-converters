Count":0,"source":"import { useState, useEffect } from \"react\";\r\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from \"@/components/ui/card\";\r\nimport { Button } from \"@/components/ui/button\";\r\nimport { Switch } from \"@/components/ui/switch\";\r\nimport { Label } from \"@/components/ui/label\";\r\nimport { Badge } from \"@/components/ui/badge\";\r\nimport { Progress } from \"@/components/ui/progress\";\r\nimport { \r\n  Settings, \r\n  Calendar, \r\n  Bell, \r\n  Shield, \r\n  AlertTriangle, \r\n  CheckCircle, \r\n  Info,\r\n  Users,\r\n  BarChart3,\r\n  Eye,\r\n  EyeOff\r\n} from \"lucide-react\";\r\nimport { supabase } from \"@/integrations/supabase/client\";\r\nconst db = supabase as any;\r\nimport { toast } from \"sonner\";\r\nimport { useBarbershop } from \"@/hooks/useBarbershop\";\r\n\r\ninterface AutomationSettings {\r\n  blockIfHasAppointment: boolean;\r\n  blockOnlyConfirmed: boolean;\r\n  enableLogging: boolean;\r\n  notifyOnBlock: boolean;\r\n}\r\n\r\ninterface BlockedLog {\r\n  id: string;\r\n  automation_type: string;\r\n  block_reason: string;\r\n  created_at: string;\r\n  client_name?: string;\r\n}\r\n\r\nexport const AutomationSettingsPanel = () => {\r\n  const { barbershop } = useBarbershop();\r\n  const [settings, setSettings] = useState<AutomationSettings>({\r\n    blockIfHasAppointment: true,\r\n    blockOnlyConfirmed: false,\r\n    enableLogging: true,\r\n    notifyOnBlock: false\r\n  });\r\n  const [saving, setSaving] = useState(false);\r\n  const [blockedLogs, setBlockedLogs] = useState<BlockedLog[]>([]);\r\n  const [loadingLogs, setLoadingLogs] = useState(false);\r\n  const [showLogs, setShowLogs] = useState(false);\r\n\r\n  useEffect(() => {\r\n    if (barbershop?.automation_schedule) {\r\n      const parsed = typeof barbershop.automation_schedule === 'object' \r\n        ? barbershop.automation_schedule as any \r\n        : {};\r\n      \r\n      setSettings({\r\n        blockIfHasAppointment: parsed.blockIfHasAppointment ?? true,\r\n        blockOnlyConfirmed: parsed.blockOnlyConfirmed ?? false,\r\n        enableLogging: parsed.enableLogging ?? true,\r\n        notifyOnBlock: parsed.notifyOnBlock ?? false\r\n      });\r\n    }\r\n  }, [barbershop]);\r\n\r\n  const loadBlockedLogs = async () => {\r\n    if (!barbershop?.id) return;\r\n    \r\n    setLoadingLogs(true);\r\n    try {\r\n      const { data, error } = await db\r\n        .from('automation_blocked_logs')\r\n        .select(`\r\n          *,\r\n          profiles:client_id(name)\r\n        `)\r\n        .eq('barbershop_id', barbershop.id)\r\n        .order('created_at', { ascending: false })\r\n        .limit(50);\r\n\r\n      if (error) throw error;\r\n      \r\n      const formattedLogs = (data || []).map(log => ({\r\n        ...log,\r\n        client_name: (log as any).profiles?.name || 'Cliente'\r\n      }));\r\n      \r\n      setBlockedLogs(formattedLogs);\r\n    } catch (error) {\r\n      console.error('Erro ao carregar logs de bloqueio:', error);\r\n      toast.error('Erro ao carregar logs');\r\n    } finally {\r\n      setLoadingLogs(false);\r\n    }\r\n  };\r\n\r\n  const saveSettings = async () => {\r\n    if (!barbershop?.id) {\r\n      toast.error('Barbearia nâ”œأ؛o encontrada');\r\n      return;\r\n    }\r\n\r\n    setSaving(true);\r\n    try {\r\n      const currentSchedule = typeof barbershop.automation_schedule === 'object' \r\n        ? barbershop.automation_schedule as any \r\n        : {};\r\n\r\n      const newSchedule = {\r\n        ...currentSchedule,\r\n        ...settings\r\n      };\r\n\r\n      const { error } = await (supabase as any)\r\n        .from('barbershops')\r\n        .update({ automation_schedule: newSchedule })\r\n        .eq('id', barbershop.id);\r\n\r\n      if (error) throw error;\r\n\r\n      toast.success('Configuraâ”œآ؛â”œأپes de automaâ”œآ؛â”œأ؛o salvas!');\r\n    } catch (error) {\r\n      console.error('Erro ao salvar configuraâ”œآ؛â”œأپes:', error);\r\n      toast.error('Erro ao salvar configuraâ”œآ؛â”œأپes');\r\n    } finally {\r\n      setSaving(false);\r\n    }\r\n  };\r\n\r\n  const getStats = () => {\r\n    const last7Days = blockedLogs.filter(log => {\r\n      const logDate = new Date(log.created_at);\r\n      const weekAgo = new Date();\r\n      weekAgo.setDate(weekAgo.getDate() - 7);\r\n      return logDate >= weekAgo;\r\n    });\r\n\r\n    const byType = last7Days.reduce((acc, log) => {\r\n      acc[log.automation_type] = (acc[log.automation_type] || 0) + 1;\r\n      return acc;\r\n    }, {} as Record<string, number>);\r\n\r\n    return { total: last7Days.length, byType };\r\n  };\r\n\r\n  const stats = getStats();\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      {/* Estatâ”œآ،sticas de Bloqueio */}\r\n      {settings.blockIfHasAppointment && (\r\n        <Card>\r\n          <CardHeader>\r\n            <CardTitle className=\"flex items-center gap-2\">\r\n              <AlertTriangle className=\"w-5 h-5\" />\r\n              Automaâ”œآ؛â”œأپes Bloqueadas (â”œأœltimos 7 dias)\r\n            </CardTitle>\r\n            <CardDescription>\r\n              Visualize o impacto das regras de bloqueio\r\n            </CardDescription>\r\n          </CardHeader>\r\n          <CardContent>\r\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4 mb-4\">\r\n              <div className=\"text-center p-4 border rounded-lg\">\r\n                <div className=\"text-2xl font-bold text-orange-600\">{stats.total}</div>\r\n                <div className=\"text-sm text-muted-foreground\">Total bloqueado</div>\r\n              </div>\r\n              <div className=\"text-center p-4 border rounded-lg\">\r\n                <div className=\"text-2xl font-bold text-green-600\">\r\n                  {stats.total > 0 ? Math.round((1 - stats.total / 100) * 100) : 100}%\r\n                </div>\r\n                <div className=\"text-sm text-muted-foreground\">Taxa de entrega</div>\r\n              </div>\r\n            </div>\r\n\r\n            {Object.keys(stats.byType).length > 0 && (\r\n              <div className=\"space-y-2\">\r\n                <Label className=\"text-sm font-medium\">Por tipo de automaâ”œآ؛â”œأ؛o:</Label>\r\n                {Object.entries(stats.byType).map(([type, count]) => (\r\n                  <div key={type} className=\"flex items-center justify-between p-2 border rounded\">\r\n                    <span className=\"text-sm\">{type}</span>\r\n                    <Badge variant=\"secondary\">{count}</Badge>\r\n                  </div>\r\n                ))}\r\n              </div>\r\n            )}\r\n\r\n            <Button\r\n              variant=\"outline\"\r\n              onClick={() => {\r\n                setShowLogs(!showLogs);\r\n                if (!showLogs) loadBlockedLogs();\r\n              }}\r\n              className=\"w-full mt-4\"\r\n            >\r\n              {showLogs ? <EyeOff className=\"w-4 h-4 mr-2\" /> : <Eye className=\"w-4 h-4 mr-2\" />}\r\n              {showLogs ? 'Ocultar Logs' : 'Ver Logs Detalhados'}\r\n            </Button>\r\n          </CardContent>\r\n        </Card>\r\n      )}\r\n\r\n      {/* Logs Detalhados */}\r\n      {showLogs && (\r\n        <Card>\r\n          <CardHeader>\r\n            <CardTitle>Logs de Bloqueio Detalhados</CardTitle>\r\n            <CardDescription>\r\n              Histâ”œâ”‚rico de automaâ”œآ؛â”œأپes bloqueadas\r\n            </CardDescription>\r\n          </CardHeader>\r\n          <CardContent>\r\n            {loadingLogs ? (\r\n              <div className=\"text-center py-8\">\r\n                <div className=\"animate-spin rounded-full h-8 w-8 border-b-2 border-primary mx-auto\"></div>\r\n              </div>\r\n            ) : blockedLogs.length === 0 ? (\r\n              <div className=\"text-center py-8 text-muted-foreground\">\r\n                <CheckCircle className=\"w-12 h-12 mx-auto mb-4\" />\r\n                <p>Nenhuma automaâ”œآ؛â”œأ؛o bloqueada no perâ”œآ،odo</p>\r\n              </div>\r\n            ) : (\r\n              <div className=\"space-y-2\">\r\n                {blockedLogs.map((log) => (\r\n                  <div key={log.id} className=\"p-3 border rounded-lg\">\r\n                    <div className=\"flex items-center justify-between\">\r\n                      <div className=\"flex items-center gap-2\">\r\n                        <Badge variant=\"outline\">{log.automation_type}</Badge>\r\n                        <span className=\"font-medium\">{log.client_name}</span>\r\n                      </div>\r\n                      <span className=\"text-xs text-muted-foreground\">\r\n                        {new Date(log.created_at).toLocaleString('pt-BR')}\r\n                      </span>\r\n                    </div>\r\n                    <p className=\"text-sm text-muted-foreground mt-1\">{log.block_reason}</p>\r\n                  </div>\r\n                ))}\r\n              </div>\r\n            )}\r\n          </CardContent>\r\n        </Card>\r\n      )}\r\n\r\n      {/* Informaâ”œآ؛â”œأپes Adicionais */}\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle className=\"flex items-center gap-2\">\r\n            <Info className=\"w-5 h-5\" />\r\n            Como Funciona\r\n          </CardTitle>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-4\">\r\n          <div className=\"p-4 bg-green-50 border border-green-200 rounded-lg\">\r\n            <h4 className=\"font-medium text-green-800 mb-2\">أ”آ£أ  Automaâ”œآ؛â”œأپes que SEMPRE funcionam:</h4>\r\n            <ul className=\"text-sm text-green-700 space-y-1\">\r\n              <li>أ”أ‡أ³ Lembretes de agendamento (24h, 12h, 7h, 5h, 2h, 1h antes)</li>\r\n              <li>أ”أ‡أ³ Confirmaâ”œآ؛â”œأ؛o de agendamento</li>\r\n              <li>أ”أ‡أ³ Avisos de alteraâ”œآ؛â”œأ؛o de horâ”œأ­rio</li>\r\n              <li>أ”أ‡أ³ Mensagens de cancelamento ou reagendamento</li>\r\n            </ul>\r\n          </div>\r\n\r\n          <div className=\"p-4 bg-orange-50 border border-orange-200 rounded-lg\">\r\n            <h4 className=\"font-medium text-orange-800 mb-2\">آ­ئ’أœآ½ Automaâ”œآ؛â”œأپes que podem ser bloqueadas:</h4>\r\n            <ul className=\"text-sm text-orange-700 space-y-1\">\r\n              <li>أ”أ‡أ³ Campanhas de marketing</li>\r\n              <li>أ”أ‡أ³ Reativaâ”œآ؛â”œأ؛o de clientes inativos</li>\r\n              <li>أ”أ‡أ³ Mensagens promocionais</li>\r\n              <li>أ”أ‡أ³ Agradecimento pâ”œâ”‚s-atendimento</li>\r\n              <li>أ”أ‡أ³ Disparos em massa</li>\r\n            </ul>\r\n          </div>\r\n        </CardContent>\r\n      </Card>\r\n\r\n      <Card>\r\n        <CardHeader>\r\n          <CardTitle className=\"flex items-center gap-2\">\r\n            <Settings className=\"w-5 h-5\" />\r\n            Configuraâ”œآ؛â”œأپes de Automaâ”œآ؛â”œأ؛o\r\n          </CardTitle>\r\n          <CardDescription>\r\n            Controle quando as automaâ”œآ؛â”œأپes devem ser enviadas para evitar spam em clientes jâ”œأ­ agendados\r\n          </CardDescription>\r\n        </CardHeader>\r\n        <CardContent className=\"space-y-6\">\r\n          <div className=\"flex items-center justify-between p-4 border rounded-lg bg-blue-50\">\r\n            <div className=\"flex items-center gap-3\">\r\n              <Shield className=\"w-5 h-5 text-blue-600\" />\r\n              <div>\r\n                <Label className=\"font-medium\">Bloquear automaâ”œآ؛â”œأپes para clientes com agendamento na semana</Label>\r\n                <p className=\"text-sm text-muted-foreground mt-1\">\r\n                  Evita enviar campanhas e lembretes para clientes que jâ”œأ­ tâ”œآ¬m horâ”œأ­rio marcado\r\n                </p>\r\n              </div>\r\n            </div>\r\n            <Switch\r\n              checked={settings.blockIfHasAppointment}\r\n              onCheckedChange={(checked) => setSettings({ ...settings, blockIfHasAppointment: checked })}\r\n            />\r\n          </div>\r\n\r\n          {settings.blockIfHasAppointment && (\r\n            <div className=\"flex items-center justify-between p-4 border rounded-lg bg-orange-50\">\r\n              <div className=\"flex items-center gap-3\">\r\n                <Calendar className=\"w-5 h-5 text-orange-600\" />\r\n                <div>\r\n                  <Label className=\"font-medium\">Bloquear apenas agendamentos confirmados</Label>\r\n                  <p className=\"text-sm text-muted-foreground mt-1\">\r\n                    Clientes com agendamentos pendentes ainda receberâ”œأ؛o automaâ”œآ؛â”œأپes\r\n                  </p>\r\n                </div>\r\n              </div>\r\n              <Switch\r\n                checked={settings.blockOnlyConfirmed}\r\n                onCheckedChange={(checked) => setSettings({ ...settings, blockOnlyConfirmed: checked })}\r\n              />\r\n            </div>\r\n          )}\r\n\r\n          <div className=\"flex items-center justify-between p-4 border rounded-lg\">\r\n            <div className=\"flex items-center gap-3\">\r\n              <BarChart3 className=\"w-5 h-5 text-green-600\" />\r\n              <div>\r\n                <Label className=\"font-medium\">Registrar logs de bloqueio</Label>\r\n                <p className=\"text-sm text-muted-foreground mt-1\">\r\n                  Salva histâ”œâ”‚rico de quando automaâ”œآ؛â”œأپes foram bloqueadas para anâ”œأ­lise\r\n                </p>\r\n              </div>\r\n            </div>\r\n            <Switch\r\n              checked={settings.enableLogging}\r\n              onCheckedChange={(checked) => setSettings({ ...settings, enableLogging: checked })}\r\n            />\r\n          </div>\r\n\r\n          <div className=\"flex items-center justify-between p-4 border rounded-lg\">\r\n            <div className=\"flex items-center gap-3\">\r\n              <Bell className=\"w-5 h-5 text-purple-600\" />\r\n              <div>\r\n                <Label className=\"font-medium\">Notificar sobre bloqueios</Label>\r\n                <p className=\"text-sm text-muted-foreground mt-1\">\r\n                  Receba alertas quando automaâ”œآ؛â”œأپes forem bloqueadas\r\n                </p>\r\n              </div>\r\n            </div>\r\n            <Switch\r\n              checked={settings.notifyOnBlock}\r\n              onCheckedChange={(checked) => setSettings({ ...settings, notifyOnBlock: checked })}\r\n            />\r\n          </div>\r\n\r\n          <Button onClick={saveSettings} disabled={saving} className=\"w-full\">\r\n            {saving ? 'Salvando...' : 'Salvar Configuraâ”œآ؛â”œأپes'}\r\n          </Button>\r\n        </CardContent>\r\n      </Card>\r\n    </div>\r\n  );\r\n};\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\components\\automation\\AutomationsPanel.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'fetchAutomations'. Either include it or remove the dependency array.","line":50,"column":6,"nodeType":"ArrayExpression","endLine":50,"endColumn":22,"suggestions":[{"desc":"Update the dependencies array to be: [barbershop?.id, fetchAutomations]","fix":{"range":[1825,1841],"text":"[barbershop?.id, fetchAutomations]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from \"react\";\r\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from \"@/components/ui/card\";\r\nimport { Button } from \"@/components/ui/button\";\r\nimport { Input } from \"@/components/ui/input\";\r\nimport { Switch } from \"@/components/ui/switch\";\r\nimport { Label } from \"@/components/ui/label\";\r\nimport { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from \"@/components/ui/select\";\r\nimport { Textarea } from \"@/components/ui/textarea\";\r\nimport { Dialog, DialogContent, DialogDescription, DialogFooter, DialogHeader, DialogTitle, DialogTrigger } from \"@/components/ui/dialog\";\r\nimport { Badge } from \"@/components/ui/badge\";\r\nimport { Loader2, Plus, Pencil, Trash2, Zap, ZapOff } from \"lucide-react\";\r\nimport { toast } from \"sonner\";\r\nimport { useAuth } from \"@/lib/auth\";\r\nimport {\r\n  getAutomations,\r\n  createAutomation,\r\n  updateAutomation,\r\n  deleteAutomation,\r\n  toggleAutomation,\r\n  TRIGGER_TYPES,\r\n  ACTION_TYPES,\r\n  getTriggerLabel,\r\n  getActionLabel,\r\n  Automation,\r\n} from \"@/services/automationService\";\r\n\r\nexport default function AutomationsPanel() {\r\n  const { barbershop } = useAuth();\r\n  const [loading, setLoading] = useState(true);\r\n  const [automations, setAutomations] = useState<Automation[]>([]);\r\n  const [dialogOpen, setDialogOpen] = useState(false);\r\n  const [editingAutomation, setEditingAutomation] = useState<Automation | null>(null);\r\n  const [saving, setSaving] = useState(false);\r\n\r\n  const [formData, setFormData] = useState({\r\n    name: \"\",\r\n    description: \"\",\r\n    trigger_type: \"booking_created\",\r\n    trigger_hours_before: 24,\r\n    action_type: \"send_whatsapp\",\r\n    template_message: \"\",\r\n    is_active: true,\r\n    priority: 0,\r\n  });\r\n\r\n  useEffect(() => {\r\n    if (barbershop?.id) {\r\n      fetchAutomations();\r\n    }\r\n  }, [barbershop?.id]);\r\n\r\n  const fetchAutomations = async () => {\r\n    if (!barbershop?.id) return;\r\n    setLoading(true);\r\n    try {\r\n      const data = await getAutomations(barbershop.id);\r\n      setAutomations(data);\r\n    } catch (error) {\r\n      console.error(\"Erro ao buscar automaâ”œآ؛â”œأپes:\", error);\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  const handleOpenDialog = (automation?: Automation) => {\r\n    if (automation) {\r\n      setEditingAutomation(automation);\r\n      setFormData({\r\n        name: automation.name,\r\n        description: automation.description || \"\",\r\n        trigger_type: automation.trigger_type,\r\n        trigger_hours_before: automation.trigger_hours_before || 24,\r\n        action_type: automation.action_type,\r\n        template_message: automation.template_message || \"\",\r\n        is_active: automation.is_active,\r\n        priority: automation.priority,\r\n      });\r\n    } else {\r\n      setEditingAutomation(null);\r\n      setFormData({\r\n        name: \"\",\r\n        description: \"\",\r\n        trigger_type: \"booking_created\",\r\n        trigger_hours_before: 24,\r\n        action_type: \"send_whatsapp\",\r\n        template_message: \"\",\r\n        is_active: true,\r\n        priority: 0,\r\n      });\r\n    }\r\n    setDialogOpen(true);\r\n  };\r\n\r\n  const handleSave = async () => {\r\n    if (!barbershop?.id) return;\r\n\r\n    if (!formData.name.trim()) {\r\n      toast.error(\"Nome â”œآ® obrigatâ”œâ”‚rio.\");\r\n      return;\r\n    }\r\n\r\n    setSaving(true);\r\n    try {\r\n      const automationData = {\r\n        name: formData.name,\r\n        description: formData.description || null,\r\n        trigger_type: formData.trigger_type,\r\n        trigger_hours_before: formData.trigger_type === \"reminder_before\" ? formData.trigger_hours_before : null,\r\n        trigger_days_inactive: formData.trigger_type === \"client_inactive\" ? formData.trigger_hours_before : null,\r\n        action_type: formData.action_type,\r\n        action_config: {},\r\n        template_message: formData.template_message || null,\r\n        is_active: formData.is_active,\r\n        priority: formData.priority,\r\n      };\r\n\r\n      let result;\r\n      if (editingAutomation) {\r\n        result = await updateAutomation(editingAutomation.id, automationData);\r\n      } else {\r\n        result = await createAutomation(barbershop.id, automationData);\r\n      }\r\n\r\n      if (result.success) {\r\n        setDialogOpen(false);\r\n        fetchAutomations();\r\n      }\r\n    } finally {\r\n      setSaving(false);\r\n    }\r\n  };\r\n\r\n  const handleDelete = async (automationId: string) => {\r\n    if (!confirm(\"Tem certeza que deseja deletar esta automaâ”œآ؛â”œأ؛o?\")) return;\r\n    await deleteAutomation(automationId);\r\n    fetchAutomations();\r\n  };\r\n\r\n  const handleToggle = async (automation: Automation) => {\r\n    await toggleAutomation(automation.id, !automation.is_active);\r\n    fetchAutomations();\r\n  };\r\n\r\n  if (loading) {\r\n    return (\r\n      <div className=\"flex items-center justify-center p-8\">\r\n        <Loader2 className=\"w-8 h-8 animate-spin text-primary\" />\r\n      </div>\r\n    );\r\n  }\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n              <div className=\"grid gap-4 md:grid-cols-2 lg:grid-cols-3\">\r\n                {automations.length === 0 ? (\r\n                  <p className=\"col-span-full text-center text-muted-foreground\">Nenhuma automaâ”œآ؛â”œأ؛o configurada ainda.</p>\r\n                ) : (\r\n                  automations.map((automation) => (\r\n                    <Card key={automation.id} className=\"relative\">\r\n                      <CardHeader className=\"flex flex-row items-center justify-between space-y-0 pb-2\">\r\n                        <CardTitle className=\"text-lg font-semibold\">{automation.name}</CardTitle>\r\n                        <Badge variant={automation.is_active ? \"default\" : \"secondary\"}>\r\n                          {automation.is_active ? \"Ativa\" : \"Inativa\"}\r\n                        </Badge>\r\n                      </CardHeader>\r\n                      <CardContent className=\"space-y-2\">\r\n                        <p className=\"text-sm text-muted-foreground\">{automation.description}</p>\r\n                        <div className=\"flex items-center text-sm text-muted-foreground\">\r\n                          <Zap className=\"mr-1 h-4 w-4\" />\r\n                          <span>Gatilho: {getTriggerLabel(automation.trigger_type)}</span>\r\n                        </div>\r\n                        <div className=\"flex items-center text-sm text-muted-foreground\">\r\n                          <ZapOff className=\"mr-1 h-4 w-4\" />\r\n                          <span>Aâ”œآ؛â”œأ؛o: {getActionLabel(automation.action_type)}</span>\r\n                        </div>\r\n                        <div className=\"flex justify-end gap-2 mt-4\">\r\n                          <Button variant=\"outline\" size=\"sm\" onClick={() => handleOpenDialog(automation)}>\r\n                            <Pencil className=\"h-4 w-4\" />\r\n                          </Button>\r\n                          <Button variant=\"destructive\" size=\"sm\" onClick={() => handleDelete(automation.id)}>\r\n                            <Trash2 className=\"h-4 w-4\" />\r\n                          </Button>\r\n                          <Switch\r\n                            checked={automation.is_active}\r\n                            onCheckedChange={(checked) => handleToggle(automation)}\r\n                            aria-label={`Toggle automation ${automation.name}`}\r\n                          />\r\n                        </div>\r\n                      </CardContent>\r\n                    </Card>\r\n                  ))\r\n                )}\r\n              </div>\r\n\r\n              <Card>\r\n                <CardHeader className=\"flex flex-row items-center justify-between space-y-0 pb-2\">\r\n                  <CardTitle className=\"text-2xl font-bold\">Automaâ”œآ؛â”œأپes</CardTitle>\r\n                  <Button onClick={() => handleOpenDialog()} size=\"sm\">\r\n                    <Plus className=\"mr-2 h-4 w-4\" /> Nova Automaâ”œآ؛â”œأ؛o\r\n                  </Button>\r\n                </CardHeader>\r\n                <CardContent>\r\n                  <CardDescription>\r\n                    Gerencie suas automaâ”œآ؛â”œأپes de mensagens e aâ”œآ؛â”œأپes para otimizar o fluxo do seu negâ”œâ”‚cio.\r\n                  </CardDescription>\r\n                </CardContent>\r\n              </Card>\r\n\r\n      <Dialog open={dialogOpen} onOpenChange={setDialogOpen}>\r\n        <DialogContent className=\"max-w-md\">\r\n          <DialogHeader>\r\n            <DialogTitle>\r\n              {editingAutomation ? \"Editar Automaâ”œآ؛â”œأ؛o\" : \"Nova Automaâ”œآ؛â”œأ؛o\"}\r\n            </DialogTitle>\r\n            <DialogDescription>\r\n              Configure quando e o que esta automaâ”œآ؛â”œأ؛o deve fazer.\r\n            </DialogDescription>\r\n          </DialogHeader>\r\n\r\n          <div className=\"space-y-4 py-4\">\r\n            <div className=\"space-y-2\">\r\n              <Label htmlFor=\"name\">Nome</Label>\r\n              <Input\r\n                id=\"name\"\r\n                value={formData.name}\r\n                onChange={(e) => setFormData({ ...formData, name: e.target.value })}\r\n                placeholder=\"Ex: Lembrete 24h antes\"\r\n              />\r\n            </div>\r\n\r\n            <div className=\"space-y-2\">\r\n              <Label htmlFor=\"trigger_type\">Gatilho</Label>\r\n              <Select\r\n                value={formData.trigger_type}\r\n                onValueChange={(value) => setFormData({ ...formData, trigger_type: value })}\r\n              >\r\n                <SelectTrigger>\r\n                  <SelectValue />\r\n                </SelectTrigger>\r\n                <SelectContent>\r\n                  {TRIGGER_TYPES.map((trigger) => (\r\n                    <SelectItem key={trigger.value} value={trigger.value}>\r\n                      {trigger.label}\r\n                    </SelectItem>\r\n                  ))}\r\n                </SelectContent>\r\n              </Select>\r\n            </div>\r\n\r\n            {formData.trigger_type === \"reminder_before\" && (\r\n              <div className=\"space-y-2\">\r\n                <Label htmlFor=\"trigger_hours_before\">Enviar lembrete X horas antes</Label>\r\n                <Input\r\n                  id=\"trigger_hours_before\"\r\n                  type=\"number\"\r\n                  min={1}\r\n                  value={formData.trigger_hours_before}\r\n                  onChange={(e) =>\r\n                    setFormData({ ...formData, trigger_hours_before: parseInt(e.target.value) || 24 })\r\n                  }\r\n                />\r\n              </div>\r\n            )}\r\n\r\n            <div className=\"space-y-2\">\r\n              <Label htmlFor=\"action_type\">Aâ”œآ؛â”œأ؛o</Label>\r\n              <Select\r\n                value={formData.action_type}\r\n                onValueChange={(value) => setFormData({ ...formData, action_type: value })}\r\n              >\r\n                <SelectTrigger>\r\n                  <SelectValue />\r\n                </SelectTrigger>\r\n                <SelectContent>\r\n                  {ACTION_TYPES.map((action) => (\r\n                    <SelectItem key={action.value} value={action.value}>\r\n                      {action.label}\r\n                    </SelectItem>\r\n                  ))}\r\n                </SelectContent>\r\n              </Select>\r\n            </div>\r\n\r\n            <div className=\"space-y-2\">\r\n              <Label htmlFor=\"template_message\">Mensagem (template)</Label>\r\n              <Textarea\r\n                id=\"template_message\"\r\n                value={formData.template_message}\r\n                onChange={(e) => setFormData({ ...formData, template_message: e.target.value })}\r\n                placeholder=\"Ex: Olâ”œأ­ {client_name}, lembrete do seu agendamento de {service_name} amanhâ”œأ؛ â”œأ،s {time}.\"\r\n                rows={4}\r\n              />\r\n              <p className=\"text-xs text-muted-foreground\">\r\n                Use variâ”œأ­veis como: {\"{client_name}\"}, {\"{service_name}\"}, {\"{date}\"}, {\"{time}\"}, {\"{professional_name}\"}\r\n              </p>\r\n            </div>\r\n\r\n            <div className=\"space-y-2\">\r\n              <Label htmlFor=\"priority\">Prioridade</Label>\r\n              <Input\r\n                id=\"priority\"\r\n                type=\"number\"\r\n                min={0}\r\n                value={formData.priority}\r\n                onChange={(e) => setFormData({ ...formData, priority: parseInt(e.target.value) || 0 })}\r\n              />\r\n              <p className=\"text-xs text-muted-foreground\">Automaâ”œآ؛â”œأپes com maior prioridade sâ”œأ؛o executadas primeiro.</p>\r\n            </div>\r\n\r\n            <div className=\"flex items-center justify-between\">\r\n              <Label htmlFor=\"is_active\">Ativa</Label>\r\n              <Switch\r\n                id=\"is_active\"\r\n                checked={formData.is_active}\r\n                onCheckedChange={(checked) => setFormData({ ...formData, is_active: checked })}\r\n              />\r\n            </div>\r\n          </div>\r\n\r\n          <DialogFooter>\r\n            <Button variant=\"outline\" onClick={() => setDialogOpen(false)}>\r\n              Cancelar\r\n            </Button>\r\n            <Button onClick={handleSave} disabled={saving}>\r\n              {saving && <Loader2 className=\"w-4 h-4 mr-2 animate-spin\" />}\r\n              {editingAutomation ? \"Salvar Alteraâ”œآ؛â”œأپes\" : \"Criar Automaâ”œآ؛â”œأ؛o\"}\r\n            </Button>\r\n          </DialogFooter>\r\n        </DialogContent>\r\n      </Dialog>\r\n    </div>\r\n  );\r\n}","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\pattydoamaral\\Desktop\\app agenda atualizaâ”œآ؛â”œأ؛o dia 27\\cashback-converters\\src\\components\\automation\\ClientReactivationDashboard.tsx","messages":[{"ruleId":null,"nodeType":null,"fatal":true,"severity":2,"message":"Parsing error: File appears to be binary.","line":1,"column":0}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":1,"warningCount":0,"fixableErrorCount":0,"fixableWarningCou